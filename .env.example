# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Required for the waitlist API (/api/waitlist).
# Get your connection string from console.neon.tech
# Add this as an environment variable in your Vercel project settings.
# Run `npm run db:setup` once locally (with DATABASE_URL set) to create the table.
# Or paste the SQL below into the Neon Console SQL Editor:
#
#   CREATE TABLE IF NOT EXISTS waitlist_applications (
#     id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
#     full_name TEXT NOT NULL, email TEXT NOT NULL,
#     company_name TEXT, website_url TEXT, role TEXT,
#     country_code TEXT, country_name TEXT, detected_country_code TEXT,
#     currency_shown TEXT, pricing_region TEXT,
#     industry TEXT, industry_context TEXT,
#     writing_needs JSONB NOT NULL DEFAULT '[]',
#     current_frustration TEXT,
#     workflow_pain_points JSONB NOT NULL DEFAULT '[]',
#     workflow_notes TEXT,
#     current_stack JSONB NOT NULL DEFAULT '[]',
#     monthly_volume TEXT, team_setup TEXT,
#     value_level TEXT, monthly_value_band TEXT, monthly_value_label TEXT,
#     timeline TEXT, final_notes TEXT,
#     consent_to_contact BOOLEAN NOT NULL DEFAULT FALSE,
#     open_to_call BOOLEAN NOT NULL DEFAULT FALSE,
#     source TEXT, status TEXT NOT NULL DEFAULT 'new',
#     user_agent TEXT, ip_hash TEXT,
#     created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
#     updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
#   );
#   CREATE INDEX IF NOT EXISTS idx_wl_email          ON waitlist_applications(email);
#   CREATE INDEX IF NOT EXISTS idx_wl_status         ON waitlist_applications(status);
#   CREATE INDEX IF NOT EXISTS idx_wl_created_at     ON waitlist_applications(created_at);
#   CREATE INDEX IF NOT EXISTS idx_wl_industry       ON waitlist_applications(industry);
#   CREATE INDEX IF NOT EXISTS idx_wl_timeline       ON waitlist_applications(timeline);
#   CREATE INDEX IF NOT EXISTS idx_wl_country_code   ON waitlist_applications(country_code);
#   CREATE INDEX IF NOT EXISTS idx_wl_pricing_region ON waitlist_applications(pricing_region);
#   CREATE INDEX IF NOT EXISTS idx_wl_value_band     ON waitlist_applications(monthly_value_band);
DATABASE_URL=

# ─── Resend (optional) ────────────────────────────────────────────────────────
# If set, an internal notification email is sent after each waitlist submission.
# If not set, submissions are stored in Neon only — the form still works.
RESEND_API_KEY=
WAITLIST_NOTIFY_TO=hello@example.com
WAITLIST_NOTIFY_FROM=noreply@wordpresto.com

# ─── Diagnostic token (optional) ──────────────────────────────────────────────
# Enables GET /api/waitlist?token=<value> health check endpoint.
# Set to any random string (e.g. openssl rand -hex 16). Leave blank to disable.
DIAGNOSTIC_TOKEN=

# ─── Microsoft Clarity (optional) ─────────────────────────────────────────────
# Enables Microsoft Clarity analytics (heatmaps and session recordings).
# Find your project ID in the Clarity dashboard (Settings → Overview), or in the
# project URL: https://clarity.microsoft.com/projects/view/<PROJECT_ID>.
# Must be prefixed PUBLIC_ so Astro exposes it to the browser. If left blank,
# Clarity does not load. Set the same variable in the Vercel project settings.
PUBLIC_CLARITY_PROJECT_ID=

# ─── Deployment: Vercel ───────────────────────────────────────────────────────
#
# Build command:    npm run build
# Output directory: .vercel/output  (set automatically by @astrojs/vercel)
# Install command:  npm install
# Do NOT use a custom start command — Vercel manages the runtime.
#
# Add DATABASE_URL (and optionally RESEND_*) as environment variables in
# the Vercel project dashboard under Settings → Environment Variables.
#
# Astro 5 note: output: 'hybrid' was removed. output: 'static' (the default)
# is now equivalent — pages prerender unless they set `export const prerender = false`.
# The Vercel adapter emits serverless functions for those on-demand routes.
