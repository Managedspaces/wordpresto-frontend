# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Required for the waitlist API (/api/waitlist).
# Get your connection string from console.neon.tech
# Run `npm run db:setup` once after setting this to create the table.
DATABASE_URL=

# ─── Resend (optional) ────────────────────────────────────────────────────────
# If set, an internal notification email is sent after each waitlist submission.
# If not set, submissions are stored in Neon only — the form still works.
RESEND_API_KEY=
WAITLIST_NOTIFY_TO=hello@example.com
WAITLIST_NOTIFY_FROM=noreply@wordpresto.com

# ─── Host / PORT (node adapter) ───────────────────────────────────────────────
# The @astrojs/node adapter in standalone mode reads these automatically.
HOST=0.0.0.0
PORT=3000

# ─── Production deployment notes ──────────────────────────────────────────────
#
# Build:   npm run build
# Start:   node ./dist/server/entry.mjs
#
# The build produces two output directories:
#   dist/client/   — prerendered HTML + static assets (CDN-ready)
#   dist/server/   — node server entry point that handles /api/* routes
#
# The node server serves both:
#   • static pages (index, waitlist) from prerendered HTML
#   • /api/waitlist POST requests against Neon Postgres
#
# Astro 5 note: `output: 'hybrid'` was removed. `output: 'static'` (the
# default) behaves identically — pages are prerendered unless they explicitly
# set `export const prerender = false`. The node adapter is still required to
# emit dist/server/entry.mjs for the server routes.
#
# If deploying to Vercel or Cloudflare, swap @astrojs/node for:
#   @astrojs/vercel   →  npm i @astrojs/vercel
#   @astrojs/cloudflare →  npm i @astrojs/cloudflare
# and update astro.config.mjs accordingly.
