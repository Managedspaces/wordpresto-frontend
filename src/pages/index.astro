---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { homePage } from '@/data/pages';
import { workers } from '@/data/workers';

const { pageTitle, seoTitle, metaDescription } = homePage;
---

<BaseLayout
  pageTitle={pageTitle}
  seoTitle={seoTitle}
  description={metaDescription}
  canonical="https://wordpresto.com/"
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href="/waitlist" class="nav-link">Sign in</a>
        <a href="#product" class="nav-link">Product</a>
        <a href="#capabilities" class="nav-link">Workflow</a>
      </nav>
      <a href="#top" class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href="#use-cases" class="nav-link">Use cases</a>
        <a href="#workers" class="nav-link">Workers</a>
        <a href="/waitlist" class="btn btn--primary btn--sm">Join the waitlist</a>
      </nav>
    </div>
  </header>

  <!-- ===================== 1. HERO ===================== -->
  <section id="top" class="section section--hero">
    <div class="container hero-grid">

      <div class="hero-copy">
        <div class="eyebrow eyebrow--strategy">the content engine behind publishing</div>
        <h1 class="hero-h1">Word Presto is the <span class="agentic-mark">agentic</span> content engine behind better publishing workflows.</h1>
        <p class="hero-body">{metaDescription}</p>
        <p class="hero-audience">Built for copywriters, business owners, website teams and agencies who need structure, quality control and momentum without handing judgement to a black box.</p>
        <div class="hero-ctas">
          <a href="/waitlist" class="btn btn--primary btn--lg">
            Join the waitlist
            <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/waitlist" class="btn btn--secondary btn--lg btn--tilt">Get early access</a>
        </div>
        <div class="hero-prepares">
          <span class="hero-prepares-label">prepares for</span>
          <span class="hero-prepares-item">WordPress</span>
          <span class="hero-dot" aria-hidden="true"></span>
          <span class="hero-prepares-item">Astro</span>
          <span class="hero-dot" aria-hidden="true"></span>
          <span class="hero-prepares-item">Payload</span>
          <span class="hero-dot" aria-hidden="true"></span>
          <span class="hero-prepares-item">Sanity</span>
        </div>
      </div>

      <!-- Paper mockup composition -->
      <div class="hero-paper" aria-hidden="true">

        <!-- Marked-up draft (back-left) -->
        <div class="paper-card paper-card--draft">
          <div class="paper-fold-corner"></div>
          <div class="paper-card-header">
            <span class="mono-label">02 · DRAFT</span>
            <span class="status-badge status-badge--review">In review</span>
          </div>
          <div class="paper-card-body paper-card-body--ruled">
            <div class="ruled-margin"></div>
            <h3 class="draft-heading">Why a structured brief beats a blank page</h3>
            <p class="draft-body">A clear brief gives every writer the same starting point: goal, audience and intent.</p>
            <p class="draft-body">It removes guesswork and keeps drafts consistent.</p>
            <span class="hand-note hand-note--amber">tighten intro</span>
          </div>
          <span class="paper-tag paper-tag--amber paper-tag--review">In review</span>
        </div>

        <!-- Content brief sheet (front-right) -->
        <div class="paper-card paper-card--brief">
          <span class="folder-tab">BRIEF</span>
          <div class="paper-fold-corner paper-fold-corner--lg"></div>
          <div class="brief-body">
            <div class="mono-label brief-id">01 · BRIEF · launch-guide</div>
            <h3 class="brief-heading">Content brief</h3>
            <dl class="brief-grid">
              <dt class="brief-dt">GOAL</dt>
              <dd class="brief-dd">Convert trial sign-ups</dd>
              <dt class="brief-dt">AUDIENCE</dt>
              <dd class="brief-dd">Website and content leads</dd>
              <dt class="brief-dt">INTENT</dt>
              <dd class="brief-dd">Commercial</dd>
              <dt class="brief-dt">SECTIONS</dt>
              <dd class="brief-dd">Intro · Proof · CTA</dd>
            </dl>
            <div class="brief-footer">
              <span class="worker-pill">
                <span class="worker-dot worker-dot--strategy"></span>
                Iris · Strategist
              </span>
              <span class="stamp stamp--signal stamp--rotate-neg">Approved</span>
            </div>
          </div>
        </div>

        <!-- Worker profile slip (bottom-left) -->
        <div class="paper-card paper-card--worker">
          <div class="paper-fold-corner paper-fold-corner--sm"></div>
          <div class="worker-slip">
            <img src="/agents/profiles/profile-21-192.webp" srcset="/agents/profiles/profile-21-192.webp 1x, /agents/profiles/profile-21-384.webp 2x" alt="" class="worker-slip-img" width="58" height="58" loading="eager" decoding="async" />
            <div class="worker-slip-info">
              <div class="worker-slip-meta">
                <span class="worker-dot worker-dot--governance"></span>
                <span class="mono-label">WORKER · REVIEW</span>
              </div>
              <div class="worker-slip-name">Audrey</div>
              <div class="worker-slip-role">Draft Quality Reviewer</div>
            </div>
          </div>
        </div>

        <!-- Review slip (mid-right) -->
        <div class="paper-card paper-card--review-slip">
          <span class="tape"></span>
          <div class="mono-label review-slip-id">03 · REVIEW</div>
          <div class="review-slip-item">
            <span class="review-dot review-dot--amber"></span>
            <span class="review-slip-text">Needs support — §3</span>
          </div>
          <div class="review-slip-item">
            <span class="review-dot review-dot--cyan"></span>
            <span class="review-slip-text">Add supporting page</span>
          </div>
        </div>

        <!-- CMS destination (bottom-right) -->
        <div class="paper-card paper-card--cms">
          <span class="folder-tab folder-tab--sm folder-tab--bottom">04 · CMS</span>
          <div class="cms-body">
            <div class="mono-label cms-label">PREPARE FOR</div>
            <div class="cms-item">
              <span class="cms-dot cms-dot--signal"></span>
              <span class="cms-name">WordPress</span>
              <span class="cms-status">ready</span>
            </div>
            <div class="cms-item">
              <span class="cms-dot cms-dot--empty"></span>
              <span class="cms-name cms-name--muted">Astro</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== 2. PROBLEM ===================== -->
  <section class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">The desk, before</div>
        <h2 class="section-h2">Content does not fail because people cannot write. It fails because the workflow is messy.</h2>
        <p class="section-body">Briefs are vague. Drafts arrive without structure. Good ideas get lost in notes, chats and half-finished documents.</p>
      </div>

      <div class="problem-grid">
        {[
          { title: 'Unclear brief', body: 'Writers start guessing what the page is even for.', note: 'vague?', rot: '-1.3deg' },
          { title: 'Draft lacks structure', body: 'No shared shape, so every draft reads differently.', rot: '0deg' },
          { title: 'Checks happen too late', body: 'Important questions surface after the page is already written.', rot: '0deg' },
          { title: 'Support missing', body: 'Important points move forward without enough support.', note: 'source?', noteColor: 'amber', rot: '1.1deg' },
          { title: 'Review unclear', body: 'No clear gate, so nobody knows what "done" means.', rot: '0deg' },
          { title: 'CMS prep left until the end', body: 'Page details and handoff notes become a last-minute scramble.', rot: '0.7deg' },
        ].map(({ title, body, note, noteColor, rot }) => (
          <div class="problem-card" style={`transform: rotate(${rot})`}>
            <div class="paper-fold-corner paper-fold-corner--sm"></div>
            <div class="problem-card-body">
              <div class="ruled-margin ruled-margin--sm"></div>
              <div class="problem-card-title">{title}</div>
              <div class="problem-card-text">{body}</div>
              {note && <span class={`hand-note hand-note--${noteColor ?? 'red'} hand-note--card`}>{note}</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 3. PRODUCT / WORKFLOW ===================== -->
  <section id="product" class="section section--border-top">
    <div class="container product-grid">
      <div>
        <div class="eyebrow eyebrow--strategy">How it works</div>
        <h2 class="section-h2">A structured place for content to move from idea to approval.</h2>
        <p class="section-body">Each stage has a clear role, output and review point.</p>
        <p class="section-note">Not a project board — a copy desk, where every piece of work has a folder it moves through.</p>
      </div>

      <div class="workflow-stack">
        {[
          { label: 'Plan', num: '01', indent: 0, state: 'done' },
          { label: 'Brief', num: '02', indent: 28, state: 'done' },
          { label: 'Draft', num: '03', indent: 56, state: 'done' },
          { label: 'Review', num: '', indent: 84, state: 'active' },
          { label: 'Improve', num: '05', indent: 56, state: 'pending' },
          { label: 'Approve', num: '06', indent: 28, state: 'pending' },
          { label: 'Prepare for CMS', num: '07', indent: 0, state: 'pending' },
        ].map(({ label, num, indent, state }) => (
          <div
            class={`workflow-row workflow-row--${state}`}
            style={`margin-left: ${indent}px`}
            aria-current={state === 'active' ? 'step' : undefined}
          >
            <div class="paper-fold-corner paper-fold-corner--sm"></div>
            <div class="ruled-margin ruled-margin--sm"></div>
            <span class={`workflow-dot workflow-dot--${state}`} aria-hidden="true">
              {state === 'done' && (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--wp-signal)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
              )}
            </span>
            <span class={`workflow-label workflow-label--${state}`}>{label}</span>
            {state === 'active'
              ? <span class="workflow-badge-now">Now</span>
              : <span class="workflow-num">{num}</span>
            }
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 4. CAPABILITIES ===================== -->
  <section id="capabilities" class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow eyebrow--strategy">Before the website</div>
        <h2 class="section-h2">Before it reaches the website.</h2>
        <p class="section-body">Most of the important work happens before anything is published. Word Presto gives that work a clearer path: from idea, to brief, to draft, to review, to improvement, to approval and handoff.</p>
      </div>

      <div class="checklist-sheet">
        <div class="checklist-header">
          <span class="checklist-title">Before it's published</span>
          <span class="mono-label">QA CHECKLIST</span>
        </div>
        <div class="checklist-body">
          {[
            { label: 'Plan the work', body: 'Turn loose ideas and business priorities into a clear direction for the page.', state: 'done' },
            { label: 'Create the brief', body: 'Give writers the goal, audience, angle and structure before anyone starts drafting.', state: 'done' },
            { label: 'Shape the draft', body: 'Help the first version follow the purpose of the page instead of starting from a blank document.', state: 'done' },
            { label: 'Review the work', body: 'Surface what needs attention before the piece reaches the website, CMS or client.', state: 'active' },
            { label: 'Improve the weak parts', body: 'Tighten sections that are unclear, thin, repetitive or not doing their job.', state: 'pending' },
            { label: 'Prepare the handoff', body: 'Package the approved work so it can move cleanly into a website, CMS or client review process.', state: 'pending' },
          ].map(({ label, body, state }, i, arr) => (
            <div class={`checklist-item${i < arr.length - 1 ? ' checklist-item--border' : ''}`}>
              <span class={`checklist-box checklist-box--${state}`} aria-hidden="true">
                {state === 'done' && (
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--wp-signal)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
                )}
                {state === 'active' && <span class="checklist-dot-amber"></span>}
              </span>
              <div class="checklist-text">
                <div class={`checklist-label${state === 'pending' ? ' checklist-label--muted' : ''}`}>
                  {label}
                  {state === 'active' && <span class="hand-note hand-note--amber hand-note--inline">in progress</span>}
                </div>
                <div class={`checklist-desc${state === 'pending' ? ' checklist-desc--muted' : ''}`}>{body}</div>
              </div>
            </div>
          ))}
        </div>
        <div class="checklist-footer">
          <span class="mono-label">checked before publishing</span>
          <span class="stamp stamp--signal stamp--rotate-neg">Ready to publish</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 5. USE CASES ===================== -->
  <section id="use-cases" class="section section--border-top">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow eyebrow--strategy">Three routes out</div>
        <h2 class="section-h2">Use Word Presto with the stack you have, or the one you are building next.</h2>
        <p class="section-body">One content engine. Three ways the finished work leaves the desk.</p>
      </div>

      <div class="destinations-grid">
        {[
          {
            num: 'DESTINATION 01',
            title: 'Automated Astro + CMS builds',
            body: 'The engine behind structured, content-led websites where pages, briefs, updates and handoff notes are planned before they become templates.',
            note: 'Astro delivery · structured pages',
          },
          {
            num: 'DESTINATION 02',
            title: 'CMS-connected workflows',
            body: 'Connect to WordPress, Payload, Sanity or a custom CMS so content is planned, reviewed and prepared before publishing.',
            note: 'WordPress · Payload · Sanity',
          },
          {
            num: 'DESTINATION 03',
            title: 'Standalone content engine',
            body: 'Manage briefs, drafts, reviews and approvals before handing content to a client, editor or website team.',
            note: 'Brief, review, hand-off',
          },
        ].map(({ num, title, body, note }) => (
          <div class="destination-wrap">
            <span class="folder-tab folder-tab--destination">{num}</span>
            <div class="destination-card">
              <div class="paper-fold-corner"></div>
              <h3 class="destination-title">{title}</h3>
              <p class="destination-body">{body}</p>
              <div class="destination-footer">
                <span class="destination-arrow">→</span>
                {note}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 6. WORKERS ===================== -->
  <section id="workers" class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">The team</div>
        <h2 class="section-h2">Specialist Workers for each stage of the content workflow.</h2>
        <p class="section-body">Each Worker is a specialist role with clear inputs, outputs and limits — covering planning, briefing, drafting, reviewing, improving, approving, compliance and handoff.</p>
      </div>

      <div class="worker-directory-header">
        <span>WORKER DIRECTORY</span>
        <span>11 SPECIALIST ROLES · ONE WORKFLOW</span>
      </div>

      <div class="workers-grid">
        {workers.map((w) => (
          <a href={`#workers`} class="worker-card">
            <div class="paper-fold-corner paper-fold-corner--sm"></div>
            <div class="worker-card-top">
              <img
                src={w.image}
                srcset={`${w.image} 1x, ${w.image2x} 2x`}
                alt={`${w.name} · ${w.role}`}
                class="worker-card-img"
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              />
              <div class="worker-card-info">
                <div class="worker-card-name">{w.name}</div>
                <div class="worker-card-role">{w.role}</div>
              </div>
            </div>
            <div class="worker-card-tags">
              <span class="worker-tag">
                <span class="worker-tag-dot" style={`background: ${w.teamColor}`}></span>
                {w.department}
              </span>
              <span class="worker-tag">Stage · {w.stage}</span>
            </div>
            <p class="worker-card-summary">{w.summary}</p>
            <div class="worker-card-footer">
              <div class="worker-output">
                <span class="worker-output-label">OUTPUT</span>
                <span class="worker-output-value">{w.output}</span>
              </div>
              <span class="worker-view-link">
                View profile
                <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 7. HUMAN APPROVAL ===================== -->
  <section class="section section--border-top section--overflow-hidden">
    <div class="container approval-grid">
      <div>
        <div class="eyebrow eyebrow--strategy">Human approval</div>
        <h2 class="section-h2">Faster content work, without removing human judgement.</h2>
        <p class="section-body approval-body">Workers plan, draft, check and suggest. People still approve what moves forward — nothing reaches the CMS without human sign-off. This is review-led publishing, not blind automation.</p>
        <ul class="approval-list" role="list">
          {[
            'Workers do not publish without approval.',
            'Outputs are structured for human review.',
            'Risks, gaps and weak sections are surfaced early.',
            'The system supports human judgement — it never overrides it.',
          ].map((item) => (
            <li class="approval-list-item">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--wp-signal)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="approval-check"><path d="m5 12 5 5L20 7"/></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Paper mockup: margin notes + approval sheet -->
      <div class="approval-paper" aria-hidden="true">
        <!-- Margin notes slip -->
        <div class="paper-card paper-card--margin-notes">
          <div class="mono-label">MARGIN NOTES</div>
          <div class="margin-note-item">
            <span class="review-dot review-dot--red"></span>
            <span>Do not publish yet</span>
          </div>
          <div class="margin-note-item">
            <span class="review-dot review-dot--amber"></span>
            <span>Needs support — §3</span>
          </div>
          <div class="margin-note-item">
            <span class="review-dot review-dot--cyan"></span>
            <span>Ready for review</span>
          </div>
        </div>

        <!-- Approval document -->
        <div class="paper-card paper-card--approval">
          <div class="approval-doc-header">
            <span class="approval-doc-title">Approval</span>
            <span class="mono-label">launch-guide.md</span>
          </div>
          <div class="approval-doc-body">
            <div class="approval-row">
              <span>Quality review</span>
              <span class="status-badge status-badge--ready">Ready</span>
            </div>
            <div class="approval-row">
              <span>Support check</span>
              <span class="status-badge status-badge--needs">Needs support</span>
            </div>
            <div class="approval-row approval-row--last">
              <span>Final sign-off</span>
              <span class="mono-label">awaiting human</span>
            </div>
          </div>
          <div class="approval-doc-footer">
            <span class="mono-label">approved by</span>
            <span class="hand-signature">A. Mercer</span>
          </div>
          <span class="stamp stamp--signal stamp--absolute">Approved</span>
        </div>

        <!-- Human approval required pill -->
        <span class="approval-pill">
          <span class="approval-pill-dot"></span>
          <span class="mono-label">human approval required</span>
        </span>
      </div>
    </div>
  </section>

  <!-- ===================== 8. AUDIENCE ===================== -->
  <section class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow eyebrow--strategy">Who it is for</div>
        <h2 class="section-h2">Built for the people responsible for content outcomes.</h2>
      </div>

      <div class="audience-grid">
        {[
          { group: 'Copywriters', body: 'Better briefs, clearer review notes and a structured way to improve drafts without losing your voice.' },
          { group: 'Business owners', body: 'A clear view of what content is being made, why it matters and whether it is ready to publish.' },
          { group: 'Website teams', body: 'A clearer handoff from draft to page, with the purpose, structure and review notes already attached.' },
          { group: 'Agencies', body: 'A repeatable content process that helps teams move faster while keeping review and approval visible.' },
        ].map(({ group, body }) => (
          <div class="audience-card">
            <div class="paper-fold-corner paper-fold-corner--sm"></div>
            <div class="audience-for">FOR</div>
            <h3 class="audience-title">{group}</h3>
            <p class="audience-body">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 9. FINAL CTA ===================== -->
  <section class="section section--cta section--border-top">
    <div class="cta-inner">
      <img src="/brand/horizontal-lockup-transparent.png" alt="Word Presto" class="cta-logo" width="174" height="auto" />
      <h2 class="cta-h2">Give your content workflow somewhere better to live.</h2>
      <p class="cta-body">Plan, produce, review and improve content before it reaches the CMS, website or client.</p>
      <div class="cta-buttons">
        <a href="/waitlist" class="btn btn--primary btn--lg">
          Join the waitlist
          <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/waitlist" class="btn btn--secondary btn--lg btn--tilt">Get early access</a>
      </div>
      <div class="cta-mark">
        <span class="cta-rule"></span>
        <span class="mono-label cta-mark-text">PAPER · INK · SIGNAL · CONTROL</span>
        <span class="cta-rule"></span>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="/brand/horizontal-lockup-transparent.png" alt="Word Presto" class="footer-logo" width="109" height="62" />
        <p class="footer-tagline">The content engine behind better publishing workflows.</p>
      </div>
      <nav class="footer-nav" aria-label="Product">
        <span class="footer-nav-heading">Product</span>
        <a href="#product" class="footer-link">How it works</a>
        <a href="#capabilities" class="footer-link">Workflow</a>
        <a href="#workers" class="footer-link">Workers</a>
      </nav>
      <nav class="footer-nav" aria-label="Use cases">
        <span class="footer-nav-heading">Use cases</span>
        <a href="#use-cases" class="footer-link">Astro + CMS builds</a>
        <a href="#use-cases" class="footer-link">CMS-connected</a>
        <a href="#use-cases" class="footer-link">Standalone engine</a>
      </nav>
      <nav class="footer-nav" aria-label="Audience">
        <span class="footer-nav-heading">Audience</span>
        <a href="#top" class="footer-link">Copywriters</a>
        <a href="#top" class="footer-link">Website teams</a>
        <a href="#top" class="footer-link">Agencies</a>
      </nav>
    </div>
    <div class="footer-bottom container">
      <span>© 2026 Word Presto</span>
      <span>Review-led publishing · Human approval</span>
    </div>
