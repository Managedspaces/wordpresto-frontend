---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  pageTitle="See rough thinking become review-ready"
  seoTitle="WordPresto workflow demo — rough notes to review-ready content"
  description="A writer's rough notes move through WordPresto. Brief, structure, voice, review and approval — without handing judgement to a machine."
  canonical="https://wordpresto.com/workflow-demo/"
  noindex={true}
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href="/waitlist" class="nav-link">Sign in</a>
        <a href="/#product" class="nav-link">Product</a>
        <a href="/workers/" class="nav-link">Workers</a>
      </nav>
      <a href="/" class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href="/#use-cases" class="nav-link">Use cases</a>
        <a href="/workers/" class="nav-link">Workers</a>
        <a href="/waitlist" class="btn btn--primary btn--sm">Join the waitlist</a>
      </nav>
    </div>
  </header>

  <!-- ===================== INTRO ===================== -->
  <section class="section section--intro">
    <div class="container">
      <div class="eyebrow eyebrow--demo">Workflow demo</div>
      <h1 class="demo-h1">See rough thinking become review-ready.</h1>
      <p class="demo-intro">A writer's rough notes move through WordPresto. Brief, structure, voice, review and approval — without handing judgement to a machine.</p>
      <p class="demo-note">Follow the steps below. Each one reveals a stage of the content workflow. Nothing is published at the end — human approval is required first.</p>
    </div>
  </section>

  <!-- ===================== DEMO AREA ===================== -->
  <section class="section section--demo section--border-top">
    <div class="container">

      <!-- Progress rail -->
      <div class="progress-rail" aria-label="Workflow progress" role="progressbar" aria-valuemin={0} aria-valuemax={9} aria-valuenow={0}>
        <div class="progress-rail-inner">
          {Array.from({ length: 10 }, (_, i) => (
            <span class={`progress-dot${i === 0 ? ' progress-dot--active' : ''}`} data-step={i} aria-label={`Step ${i}`}></span>
          ))}
        </div>
        <span class="progress-label mono-label">Step <span id="progress-current">0</span> of 9</span>
      </div>

      <!-- ===== STEP 0: Writer Primer ===== -->
      <div class="demo-step demo-step--visible" id="step-0" data-step="0">
        <div class="step-label mono-label">YOUR NOTES · CLINIC WEBSITE ARTICLE</div>
        <div class="primer-card">
          <div class="primer-margin"></div>
          <div class="primer-body">
            <p class="primer-line">I want to write about why clinic websites often fail before design even starts. The real problem is not colours or fonts. It is that nobody has worked out the patient journey, the qualification points, what the clinic actually wants from enquiries, or what should happen after someone fills in a form.</p>
            <p class="primer-line">A lot of agencies make nice pages but miss the operational bit.</p>
            <p class="primer-line primer-line--keep">Keep the phrase: "the website is not the workflow"</p>
            <span class="hand-annot hand-annot--keep">keep this phrase ↓</span>
            <p class="primer-line">Don't make it sound like I'm attacking designers.<br />I want this to feel useful to clinic owners — not salesy.</p>
            <p class="primer-line">Examples I want to use:<br />
            — WhatsApp enquiries that go nowhere<br />
            — Contact forms with no follow-up logic<br />
            — Unqualified consultations being booked<br />
            — No consent flow before treatment<br />
            — No follow-up after treatment</p>
            <p class="primer-line">Audience: clinic owners about to brief an agency, or who already have a site that is not converting.</p>
            <p class="primer-line">This should be practical. Not another "here is what a great website looks like" piece.</p>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="1">Shape this thinking →</button>
        </div>
      </div>

      <!-- ===== STEP 1: Omar ===== -->
      <div class="demo-step" id="step-1" data-step="1">
        <div class="worker-pill mono-label">STEP 1 OF 9 · OMAR · CONTENT ANALYST · STAGE: ANALYSE</div>
        <p class="worker-action">Reading your notes. Extracting what matters.</p>
        <div class="output-card">
          <div class="output-card-header">
            <span class="output-card-title">CONTENT ANALYSIS</span>
          </div>
          <div class="output-card-body">
            <div class="output-section">
              <div class="output-heading">Core argument identified</div>
              <p class="output-para">"The website is not the workflow" — this is the piece.<br />The design quality is secondary to operational readiness.</p>
            </div>
            <div class="output-section">
              <div class="output-heading">Strongest material in your notes</div>
              <p class="output-para output-list">— The operational gap (nobody prepares the workflow before briefing design)<br />— Concrete failure patterns: WhatsApp, forms, unqualified leads, consent, follow-up<br />— Practitioner-to-practitioner tone (not agency pitching to clients)</p>
            </div>
            <div class="output-section">
              <div class="output-heading">Your phrase is preserved</div>
              <p class="output-para">"the website is not the workflow" — keep exactly as written</p>
            </div>
            <div class="output-section">
              <div class="output-heading">What needs support</div>
              <p class="output-para output-list">— One real clinic-owner scenario (a specific journey, not a list)<br />— Evidence of the form/follow-up gap (or a credible proxy)</p>
            </div>
            <div class="output-section output-section--warning">
              <div class="output-heading output-heading--warning">Potential risk flagged</div>
              <p class="output-para">"A lot of agencies make nice pages but miss the operational bit"<br /><span class="output-indent">Could alienate agency readers. May need softening.</span></p>
            </div>
            <div class="output-section output-section--signal">
              <div class="output-heading output-heading--signal">Recommendation</div>
              <p class="output-para">Strong foundation. Proceed to brief.</p>
            </div>
          </div>
          <div class="voice-note">
            <span class="hand-note">"the website is not the workflow" — your strongest line</span>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="2">Follow the workflow →</button>
        </div>
      </div>

      <!-- ===== STEP 2: Luca ===== -->
      <div class="demo-step" id="step-2" data-step="2">
        <div class="worker-pill mono-label">STEP 2 OF 9 · LUCA · CONTENT BRIEF BUILDER · STAGE: BRIEF</div>
        <p class="worker-action">Turning your thinking into a brief that keeps what matters.</p>
        <div class="output-card output-card--brief">
          <span class="folder-tab">BRIEF</span>
          <div class="output-card-header output-card-header--ruled">
            <span class="output-card-title">CONTENT BRIEF</span>
            <span class="mono-label">01 · BRIEF · clinic-website-article</span>
          </div>
          <div class="output-card-body">
            <dl class="brief-dl">
              <dt class="brief-dt">GOAL</dt>
              <dd class="brief-dd">Help clinic owners see the operational gap before briefing an agency</dd>
              <dt class="brief-dt">AUDIENCE</dt>
              <dd class="brief-dd">Clinic owners commissioning or reviewing a website</dd>
              <dt class="brief-dt">INTENT</dt>
              <dd class="brief-dd">Useful, practical — not a sales piece</dd>
              <dt class="brief-dt">TONE</dt>
              <dd class="brief-dd">Practitioner-to-practitioner, direct, warm</dd>
              <dt class="brief-dt">WORD COUNT</dt>
              <dd class="brief-dd">800–1,100</dd>
            </dl>
            <div class="brief-divider"></div>
            <div class="output-section">
              <div class="output-heading">KEEP</div>
              <p class="output-para output-list">— Phrase: "the website is not the workflow"<br />— Practical examples from aesthetic clinics<br />— Conversational, not expert-to-layperson</p>
            </div>
            <div class="output-section">
              <div class="output-heading">AVOID</div>
              <p class="output-para output-list">— "Most agencies" generalisations<br />— Design criticism for its own sake<br />— Generic "here is what a good website looks like" conclusion</p>
            </div>
            <div class="output-section">
              <div class="output-heading">SECTIONS</div>
              <p class="output-para output-list">1. The problem that happens before design starts<br />2. What the patient journey actually looks like<br />3. The operational gaps: forms, WhatsApp, bookings, consent<br />4. The website is not the workflow<br />5. What to fix first</p>
            </div>
          </div>
          <div class="voice-note">
            <span class="hand-note">Keeps your "useful, not salesy" note — this brief matches your intent</span>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="3">Follow the workflow →</button>
        </div>
      </div>

      <!-- ===== STEP 3: Marcus ===== -->
      <div class="demo-step" id="step-3" data-step="3">
        <div class="worker-pill mono-label">STEP 3 OF 9 · MARCUS · STRUCTURE WORKER · STAGE: STRUCTURE</div>
        <p class="worker-action">Shaping a clear structure from your brief.</p>
        <div class="output-card">
          <div class="output-card-header">
            <span class="output-card-title">ARTICLE STRUCTURE</span>
          </div>
          <div class="output-card-body output-card-body--outline">
            <div class="outline-row outline-row--h1">
              <span class="outline-tag">H1</span>
              <span class="outline-text">Clinic websites often fail before design starts</span>
            </div>
            <div class="outline-row">
              <span class="outline-tag outline-tag--muted">INTRO</span>
              <span class="outline-text">The real problem is not colours or fonts</span>
            </div>
            <div class="outline-row outline-row--section">
              <span class="outline-tag">§ 1</span>
              <div class="outline-content">
                <span class="outline-text">What patients actually do when they arrive at a clinic site</span>
                <span class="outline-sub">(the journey most site briefs do not describe)</span>
              </div>
            </div>
            <div class="outline-row outline-row--section">
              <span class="outline-tag">§ 2</span>
              <div class="outline-content">
                <span class="outline-text">The operational gap no one talks about in the briefing room</span>
                <span class="outline-sub">— What the clinic actually wants from an enquiry<br />— What qualification looks like before booking</span>
              </div>
            </div>
            <div class="outline-row outline-row--section">
              <span class="outline-tag">§ 3</span>
              <div class="outline-content">
                <span class="outline-text">Where it breaks: WhatsApp, forms, bookings and consent</span>
                <span class="outline-sub">— The WhatsApp pattern (specific scenario)<br />— Weak forms and lost leads<br />— Unqualified consultations<br />— The consent and follow-up gap</span>
              </div>
            </div>
            <div class="outline-row outline-row--section outline-row--anchor">
              <span class="outline-tag">§ 4</span>
              <div class="outline-content">
                <span class="outline-text outline-text--preserved">The website is not the workflow</span>
                <span class="outline-sub">(your phrase as the section anchor — preserved)</span>
              </div>
            </div>
            <div class="outline-row outline-row--section">
              <span class="outline-tag">§ 5</span>
              <span class="outline-text">What to fix before you brief a designer</span>
            </div>
            <div class="outline-row outline-row--close">
              <span class="outline-tag outline-tag--muted">CLOSE</span>
              <div class="outline-content">
                <span class="outline-text">What good operational readiness looks like</span>
                <span class="outline-sub">(clinic owner leaves with something actionable)</span>
              </div>
            </div>
          </div>
          <div class="voice-note">
            <span class="hand-note">Your phrase becomes §4's anchor — not buried, not the headline, exactly where it lands hardest</span>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="4">Follow the workflow →</button>
        </div>
      </div>

      <!-- ===== STEP 4: Helena ===== -->
      <div class="demo-step" id="step-4" data-step="4">
        <div class="worker-pill mono-label">STEP 4 OF 9 · HELENA · VOICE &amp; STYLE WORKER · STAGE: VOICE</div>
        <p class="worker-action">Checking the structure and brief against your preferred voice.</p>
        <div class="output-card">
          <div class="output-card-header">
            <span class="output-card-title">VOICE &amp; STYLE GUIDANCE</span>
          </div>
          <div class="output-card-body">
            <div class="output-section">
              <div class="output-heading">Your voice identified as</div>
              <p class="output-para">Practitioner-to-practitioner. Direct without being blunt.<br />Practical, slightly wry. Not a lecture.</p>
            </div>
            <div class="output-section output-section--signal">
              <div class="output-heading output-heading--signal">Preserved</div>
              <p class="output-para output-list">— "the website is not the workflow" — exact phrasing, exact position<br />— Tone: useful, not salesy<br />— Implied reader: experienced, not being taught the basics</p>
            </div>
            <div class="output-section">
              <div class="output-heading">Suggestions</div>
              <p class="output-para output-list">— Open with a specific clinic scenario, not a general statement<br /><span class="output-indent">(Your WhatsApp example is the right opening move)</span><br />— "A lot of agencies make nice pages" → rephrase as observation,<br /><span class="output-indent">not criticism ("The brief rarely includes the workflow" works better)</span><br />— Avoid "most clinics" or "many websites" — use scenarios instead</p>
            </div>
            <div class="output-section">
              <div class="output-heading">Protect</div>
              <p class="output-para output-list">— The wry aside in your notes ("need examples from aesthetic clinics")<br /><span class="output-indent">signals your register — keep that energy in the draft</span><br />— Don't smooth this into a generic content-marketing tone</p>
            </div>
            <div class="output-section output-section--warning">
              <div class="output-heading output-heading--warning">Flags for writer</div>
              <p class="output-para output-list">— §3 needs your specific WhatsApp scenario — not a generalisation<br />— Conclusion needs one concrete "what good looks like" — not a listicle</p>
            </div>
          </div>
          <div class="voice-note">
            <span class="hand-note">"This sounds like the writer" — do not flatten</span>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="5">Follow the workflow →</button>
        </div>
      </div>

      <!-- ===== STEP 5: Ellis ===== -->
      <div class="demo-step" id="step-5" data-step="5">
        <div class="worker-pill mono-label">STEP 5 OF 9 · ELLIS · DRAFT REWRITE WORKER · STAGE: DRAFT</div>
        <p class="worker-action">Shaping the opening without losing the point.</p>
        <div class="output-card output-card--draft">
          <div class="output-card-header">
            <span class="output-card-title">DRAFT EXCERPT · INTRO + §1</span>
            <span class="status-badge status-badge--review">Draft</span>
          </div>
          <div class="output-card-body output-card-body--draft">
            <div class="draft-margin"></div>
            <p class="draft-text draft-text--heading">Clinic websites often fail before design starts</p>
            <p class="draft-text">The problem is rarely the colours or the fonts. Most of the time,
            it is that nobody has worked out what the clinic actually needs the
            website to do before they brief a designer to make it look good.</p>
            <p class="draft-text">There is no patient journey. No clear qualification point. No logic
            for what happens after someone fills in the contact form — or, more
            likely, sends a WhatsApp.</p>
            <p class="draft-text">The website gets built. It looks professional. And then the leads
            come in with no system to handle them.</p>
            <p class="draft-text">This is not a design problem.</p>
            <p class="draft-text draft-text--anchor">The website is not the workflow.</p>
            <p class="draft-text draft-text--subheading">§1 · What patients actually do</p>
            <p class="draft-text">A prospective patient finds the clinic online. They have a question —
            price, availability, whether the treatment is right for them.
            They do not fill in a form. They send a WhatsApp.</p>
            <p class="draft-text">What happens to that WhatsApp depends entirely on whether the clinic
            has a system for it. Most don't. So the lead sits in someone's phone.</p>
          </div>
          <div class="voice-note">
            <span class="hand-note">"The website is not the workflow" — kept exactly as written, placed exactly where it lands</span>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="6">Follow the workflow →</button>
        </div>
      </div>

      <!-- ===== STEP 6: Quinn ===== -->
      <div class="demo-step" id="step-6" data-step="6">
        <div class="worker-pill mono-label">STEP 6 OF 9 · QUINN · DRAFT QUALITY REVIEWER · STAGE: REVIEW</div>
        <p class="worker-action">Checking the draft against the brief. Surfacing what still needs you.</p>
        <div class="output-card">
          <div class="output-card-header">
            <span class="output-card-title">DRAFT QUALITY REVIEW</span>
          </div>
          <div class="output-card-body output-card-body--checklist">
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <div class="review-text">
                <span class="review-item">Opening paragraph</span>
                <span class="review-note">— clear, specific, strong</span>
              </div>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <div class="review-text">
                <span class="review-item">Core argument</span>
                <span class="review-note">— present from paragraph 3</span>
              </div>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <div class="review-text">
                <span class="review-item">"The website is not the workflow"</span>
                <span class="review-note">— positioned correctly</span>
              </div>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <div class="review-text">
                <span class="review-item">Tone</span>
                <span class="review-note">— practitioner-to-practitioner throughout</span>
              </div>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <div class="review-text">
                <span class="review-item">Brief alignment</span>
                <span class="review-note">— sections match the agreed structure</span>
              </div>
            </div>
            <div class="review-row review-row--warn">
              <span class="review-icon review-icon--warn">△</span>
              <div class="review-text">
                <span class="review-item">§3 WhatsApp scenario</span>
                <span class="review-note">— general statement, needs a specific scene</span>
                <span class="review-sub">Writer's notes mentioned: "WhatsApp enquiries going nowhere"<br />This needs to be a scenario, not a statistic</span>
              </div>
            </div>
            <div class="review-row review-row--warn">
              <span class="review-icon review-icon--warn">△</span>
              <div class="review-text">
                <span class="review-item">Conclusion</span>
                <span class="review-note">— currently ends on a list</span>
                <span class="review-sub">Brief called for "what good looks like" — needs a concrete example<br />(a clinic that fixed the operational gap, not a generic recommendation)</span>
              </div>
            </div>
            <div class="review-row review-row--fail">
              <span class="review-icon review-icon--fail">✗</span>
              <div class="review-text">
                <span class="review-item">"Most clinics don't" (§1, line 4)</span>
                <span class="review-note">— softening needed</span>
                <span class="review-sub">Vera has flagged this for claims review</span>
              </div>
            </div>
            <div class="review-status">
              <span class="review-status-label mono-label">STATUS</span>
              <span class="status-badge status-badge--review">Near-ready · 2 sections need writer input before approval</span>
            </div>
          </div>
          <div class="voice-note">
            <span class="hand-note">Two gaps both need the writer's own examples — not generic fill-in</span>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="7">Follow the workflow →</button>
        </div>
      </div>

      <!-- ===== STEP 7: Vera ===== -->
      <div class="demo-step" id="step-7" data-step="7">
        <div class="worker-pill mono-label">STEP 7 OF 9 · VERA · EDITORIAL RISK &amp; CLAIMS · STAGE: REVIEW</div>
        <p class="worker-action">Flagging what needs attention before this goes to approval.</p>
        <div class="output-card">
          <div class="output-card-header">
            <span class="output-card-title">RISK &amp; CLAIMS REVIEW</span>
            <span class="status-badge status-badge--ready">Low risk overall</span>
          </div>
          <div class="output-card-body output-card-body--checklist">
            <p class="risk-summary mono-label">LOW RISK OVERALL · 2 items for writer attention</p>
            <div class="review-row review-row--warn">
              <span class="review-icon review-icon--warn">⚠</span>
              <div class="review-text">
                <span class="review-item">"Most clinics don't [have a system]" — §1, line 4</span>
                <span class="review-sub">Unquantified generalisation. Soften to "many" or frame as<br />"in our experience" or remove the quantifier entirely.<br /><span class="review-risk-level">Risk level: Low · Easy fix</span></span>
              </div>
            </div>
            <div class="review-row review-row--warn">
              <span class="review-icon review-icon--warn">⚠</span>
              <div class="review-text">
                <span class="review-item">"A lot of agencies make nice pages but miss the operational bit"</span>
                <span class="review-sub">(retained from writer's original notes into §2 draft)<br />This generalisation could alienate agency readers.<br />Rephrase as an industry observation, not a verdict.<br /><span class="review-risk-level">Risk level: Low · Writer should reframe in their own words</span></span>
              </div>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <span class="review-item">No regulatory or medical claims</span>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <span class="review-item">No pricing, ROI or results claims</span>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <span class="review-item">No competitor names or comparisons</span>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <span class="review-item">No before/after treatment claims</span>
            </div>
            <div class="review-row review-row--pass">
              <span class="review-icon review-icon--pass">✓</span>
              <span class="review-item">No statistical claims requiring citation</span>
            </div>
            <div class="review-status">
              <span class="review-status-label mono-label">RECOMMENDATION</span>
              <span class="review-item">Safe to proceed to approval after writer addresses 2 flagged items. Nothing here blocks publication once reviewed.</span>
            </div>
          </div>
          <div class="voice-note">
            <span class="hand-note">Both flags are easy writer calls — not editorial blocks</span>
          </div>
        </div>
        <div class="step-cta-wrap">
          <button class="demo-cta" data-reveals="8">Follow the workflow →</button>
        </div>
      </div>

      <!-- ===== STEP 8: Audrey ===== -->
      <div class="demo-step" id="step-8" data-step="8">
        <div class="worker-pill mono-label">STEP 8 OF 9 · AUDREY · APPROVAL REPORT WORKER · STAGE: APPROVE</div>
        <p class="worker-action">Summarising what is ready and what still needs your decision.</p>
        <div class="output-card">
          <div class="output-card-header output-card-header--approval">
            <span class="output-card-title">APPROVAL REPORT</span>
          </div>
          <div class="output-card-body output-card-body--approval">
            <dl class="approval-dl">
              <dt class="approval-dt">ARTICLE</dt>
              <dd class="approval-dd">Clinic websites often fail before design starts</dd>
              <dt class="approval-dt">WRITER</dt>
              <dd class="approval-dd">[Your name]</dd>
              <dt class="approval-dt">DATE</dt>
              <dd class="approval-dd">Today</dd>
            </dl>
            <div class="approval-divider"></div>
            <div class="output-section output-section--signal">
              <div class="output-heading output-heading--signal">Ready for approval</div>
              <div class="approval-list">
