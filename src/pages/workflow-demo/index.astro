    font-size: var(--wp-text-sm);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .eyebrow--demo { color: var(--wp-amber); }
  .demo-h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--wp-ink);
    margin: 0 0 22px;
  }
  .demo-intro {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.5;
    margin: 0 0 14px;
    max-width: 660px;
  }
  .demo-note {
    font-size: var(--wp-text-base);
    color: var(--wp-text-tertiary);
    line-height: 1.65;
    margin: 0;
    max-width: 580px;
  }

  /* ===== SHARED ===== */
  .mono-label {
    font-size: var(--wp-text-xs);
    font-family: var(--wp-font-mono);
    color: var(--wp-text-muted);
    letter-spacing: 0.08em;
  }
  .hand-note {
    font-family: var(--wp-font-hand);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--wp-amber);
    line-height: 1.3;
  }
  .status-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    font-family: var(--wp-font-mono);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    white-space: nowrap;
  }
  .status-badge--review { border: 1.5px solid var(--wp-amber); color: var(--wp-amber); background: var(--wp-amber-soft); }
  .status-badge--ready { border: 1.5px solid var(--wp-signal); color: var(--wp-signal); background: var(--wp-signal-soft); }

  /* ===== PROGRESS RAIL ===== */
  .progress-rail {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 48px;
    padding: 14px 0;
    border-bottom: 1px solid var(--wp-line);
  }
  .progress-rail-inner {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
  }
  .progress-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--wp-line);
    background: transparent;
    transition: background 300ms, border-color 300ms;
    flex-shrink: 0;
  }
  .progress-dot--active {
    background: var(--wp-ink);
    border-color: var(--wp-ink);
  }
  .progress-dot--done {
    background: var(--wp-signal);
    border-color: var(--wp-signal);
  }
  .progress-label { white-space: nowrap; }

  /* ===== DEMO STEPS ===== */
  .demo-step {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 400ms ease, transform 400ms ease;
    margin-bottom: 56px;
    pointer-events: none;
  }
  .demo-step--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .demo-step--revealed {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .step-label {
    margin-bottom: 14px;
    display: block;
    letter-spacing: 0.1em;
  }

  /* ===== WORKER PILL ===== */
  .worker-pill {
    display: inline-block;
    background: var(--wp-paper-soft);
    border: 1px solid var(--wp-line);
    border-radius: 4px;
    padding: 6px 14px;
    font-family: var(--wp-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--wp-text-muted);
    margin-bottom: 8px;
  }
  .worker-action {
    font-size: var(--wp-text-base);
    color: var(--wp-text-tertiary);
    margin: 0 0 18px;
    font-style: italic;
  }

  /* ===== STEP CTA ===== */
  .step-cta-wrap {
    margin-top: 22px;
  }
  .demo-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--wp-ink);
    color: var(--wp-paper);
    border: none;
    border-radius: 5px;
    font-family: var(--wp-font-sans);
    font-size: var(--wp-text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    padding: 12px 22px;
    cursor: pointer;
    transition: transform 150ms, box-shadow 150ms;
    box-shadow: 0 2px 4px rgba(17,19,24,0.12), 0 10px 18px -8px rgba(17,19,24,0.22);
  }
  .demo-cta:hover { transform: translateY(-2px); box-shadow: 0 3px 6px rgba(17,19,24,0.16), 0 16px 26px -8px rgba(17,19,24,0.3); }
  .demo-cta--final {
    background: var(--wp-signal);
    border: 1px solid var(--wp-signal);
  }

  /* ===== PRIMER CARD ===== */
  .primer-card {
    position: relative;
    background: #FEFBF3;
    border: 1px solid #D8CEBC;
    box-shadow: 0 2px 5px rgba(54,44,24,0.06), 0 10px 30px -10px rgba(54,44,24,0.14);
    transform: rotate(-0.5deg);
    overflow: hidden;
    background-image:
      repeating-linear-gradient(
        transparent,
        transparent 27px,
        rgba(0,0,200,0.06) 27px,
        rgba(0,0,200,0.06) 28px
      );
    background-position: 0 36px;
  }
  .primer-margin {
    position: absolute;
    left: 42px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(194,65,58,0.28);
    z-index: 2;
  }
  .primer-body {
    position: relative;
    padding: 28px 28px 28px 58px;
    z-index: 1;
  }
  .primer-line {
    font-size: var(--wp-text-base);
    color: var(--wp-ink);
    line-height: 1.85;
    margin: 0 0 18px;
    font-family: Georgia, 'Times New Roman', serif;
  }
  .primer-line:last-child { margin-bottom: 0; }
  .primer-line--lead {
    font-size: var(--wp-text-lg);
    font-weight: 700;
    font-family: var(--wp-font-sans);
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--wp-ink);
    margin-bottom: 20px;
  }
  .primer-line--keep {
    font-style: italic;
    color: var(--wp-text-secondary);
    border-left: 3px solid var(--wp-amber);
    padding-left: 12px;
    margin-left: -15px;
  }
  .primer-divider {
    border: none;
    border-top: 1px solid rgba(0,0,180,0.09);
    margin: 22px 0;
  }
  .hand-annot {
    font-family: var(--wp-font-hand);
    font-weight: 600;
    color: var(--wp-amber);
    font-size: 1rem;
    line-height: 1;
    position: absolute;
  }
  .hand-annot--keep {
    top: 126px;
    right: 24px;
    transform: rotate(4deg);
    font-size: 1.05rem;
  }

  /* ===== OUTPUT CARDS ===== */
  .output-card {
    position: relative;
    background: #fff;
    border: 1px solid var(--wp-line);
    box-shadow: 0 2px 5px rgba(54,44,24,0.06), 0 10px 30px -10px rgba(54,44,24,0.14);
  }
  .output-card--brief {
    padding-top: 20px;
  }
  .output-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 24px;
    border-bottom: 2px solid var(--wp-ink);
  }
  .output-card-header--ruled {
    border-bottom: 1px solid var(--wp-line);
    flex-wrap: wrap;
    gap: 6px;
  }
  .output-card-header--approval { border-bottom: 2px solid var(--wp-ink); }
  .output-card-title {
    font-size: var(--wp-text-base);
    font-family: var(--wp-font-mono);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--wp-ink);
  }
  .output-card-body {
    padding: 22px 24px;
  }
  .output-card-body--draft {
    padding-left: 46px;
    position: relative;
  }
  .output-card-body--checklist { padding: 10px 24px 20px; }
  .output-card-body--outline { padding: 12px 24px 22px; }
  .output-card-body--approval { padding: 22px 24px; }

  /* ===== OUTPUT SECTIONS ===== */
  .output-section {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--wp-line);
  }
  .output-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .output-section--signal { background: var(--wp-signal-soft); border: 1px solid var(--wp-signal-border); padding: 14px 18px; border-radius: 3px; margin-bottom: 20px; }
  .output-section--warning { background: var(--wp-amber-soft); border: 1px solid rgba(196,122,28,0.22); padding: 14px 18px; border-radius: 3px; margin-bottom: 20px; }
  .output-heading {
    font-size: 11px;
    font-family: var(--wp-font-mono);
    letter-spacing: 0.1em;
    color: var(--wp-text-muted);
    margin-bottom: 7px;
    text-transform: uppercase;
  }
  .output-heading--signal { color: var(--wp-signal); }
  .output-heading--warning { color: var(--wp-amber); }
  .output-para {
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.65;
    margin: 0;
  }
  .output-list { white-space: pre-line; }
  .output-indent { display: inline-block; padding-left: 16px; }

  /* ===== FOLDER TAB ===== */
  .folder-tab {
    position: absolute;
    top: -17px; left: 22px;
    padding: 5px 16px;
    background: #E3D6B9;
    border: 1px solid #C7B488;
    border-bottom: none;
    border-radius: 6px 6px 0 0;
    font-size: var(--wp-text-xs);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.1em;
    color: #5E4F2E;
    white-space: nowrap;
    z-index: 2;
  }

  /* ===== BRIEF DL ===== */
  .brief-dl {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 12px 16px;
    margin: 0 0 18px;
    align-items: baseline;
  }
  .brief-dt {
    font-size: 11px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-muted);
    letter-spacing: 0.08em;
  }
  .brief-dd {
    font-size: var(--wp-text-base);
    color: var(--wp-ink);
    margin: 0;
    line-height: 1.4;
  }
  .brief-divider {
    border: none;
    border-top: 1px solid var(--wp-line);
    margin: 20px 0;
  }

  /* ===== VOICE NOTE ===== */
  .voice-note {
    padding: 14px 24px;
    border-top: 1px dashed var(--wp-line);
    background: var(--wp-paper-soft);
  }

  /* ===== OUTLINE ===== */
  .outline-row {
    display: flex;
    gap: 18px;
    padding: 12px 0;
    border-bottom: 1px solid var(--wp-line);
    align-items: flex-start;
  }
  .outline-row:last-child { border-bottom: none; }
  .outline-row--h1 { padding-bottom: 16px; }
  .outline-row--section { padding: 14px 0; }
  .outline-row--anchor { background: var(--wp-signal-soft); padding: 14px 12px; border: 1px solid var(--wp-signal-border); border-radius: 3px; margin-bottom: 2px; }
  .outline-tag {
    font-size: 11px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-muted);
    letter-spacing: 0.06em;
    min-width: 40px;
    flex-shrink: 0;
    padding-top: 1px;
  }
  .outline-tag--muted { color: var(--wp-text-muted); opacity: 0.6; }
  .outline-text {
    font-size: var(--wp-text-base);
    color: var(--wp-ink);
    line-height: 1.4;
    font-weight: 600;
  }
  .outline-text--preserved {
    color: var(--wp-signal);
    font-style: italic;
  }
  .outline-content { display: flex; flex-direction: column; gap: 5px; }
  .outline-sub {
    font-size: var(--wp-text-sm);
    color: var(--wp-text-tertiary);
    line-height: 1.6;
    white-space: pre-line;
  }

  /* ===== DRAFT CARD ===== */
  .draft-margin {
    position: absolute;
    left: 36px;
    top: 0; bottom: 0;
    width: 1px;
    background: rgba(194,65,58,0.3);
  }
  .draft-text {
    font-size: var(--wp-text-base);
    color: var(--wp-text-primary);
    line-height: 1.8;
    margin: 0 0 16px;
    font-family: Georgia, 'Times New Roman', serif;
  }
  .draft-text:last-child { margin-bottom: 0; }
  .draft-text--heading {
    font-size: var(--wp-text-xl);
    font-weight: 700;
    font-family: var(--wp-font-sans);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 20px;
    color: var(--wp-ink);
  }
  .draft-text--subheading {
    font-size: var(--wp-text-sm);
    font-family: var(--wp-font-mono);
    color: var(--wp-text-muted);
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-top: 20px;
    margin-bottom: 12px;
  }
  .draft-text--anchor {
    font-weight: 700;
    font-style: italic;
    color: var(--wp-ink);
    font-family: var(--wp-font-sans);
    font-size: var(--wp-text-lg);
  }
  .draft-text--anchor-placeholder {
    font-weight: 600;
    font-style: italic;
    color: var(--wp-amber);
    font-family: var(--wp-font-sans);
    font-size: var(--wp-text-base);
    border-left: 3px solid var(--wp-amber);
    padding-left: 12px;
    margin-left: -15px;
  }

  /* ===== REVIEW CHECKLIST ===== */
  .review-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid var(--wp-line);
    font-size: var(--wp-text-base);
  }
  .review-row:last-child { border-bottom: none; }
  .review-icon {
    font-size: 1rem;
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1.5;
    min-width: 18px;
    font-family: var(--wp-font-mono);
  }
  .review-icon--pass { color: var(--wp-signal); }
  .review-icon--warn { color: var(--wp-amber); }
  .review-icon--fail { color: var(--wp-red); }
  .review-text { display: flex; flex-direction: column; gap: 3px; flex: 1; }
  .review-item { font-size: var(--wp-text-base); color: var(--wp-ink); font-weight: 500; line-height: 1.4; }
  .review-note { font-size: var(--wp-text-sm); color: var(--wp-text-tertiary); }
  .review-sub { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.6; white-space: pre-line; }
  .review-risk-level { color: var(--wp-text-muted); font-family: var(--wp-font-mono); font-size: 11px; letter-spacing: 0.06em; }
  .review-status {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 0 4px;
    border-top: 2px solid var(--wp-ink);
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .review-status-label { color: var(--wp-text-muted); }
  .risk-summary {
    display: block;
    padding: 12px 0 16px;
    border-bottom: 1px solid var(--wp-line);
    margin-bottom: 4px;
    color: var(--wp-text-secondary);
  }

  /* ===== APPROVAL CARD ===== */
  .approval-dl {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 10px 14px;
    margin: 0 0 18px;
    align-items: baseline;
  }
  .approval-dt {
    font-size: 11px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-muted);
    letter-spacing: 0.08em;
  }
  .approval-dd {
    font-size: var(--wp-text-base);
    color: var(--wp-ink);
    margin: 0;
  }
  .approval-divider {
    border: none;
    border-top: 1px solid var(--wp-line);
    margin: 16px 0;
  }
  .approval-list { display: flex; flex-direction: column; gap: 6px; margin-top: 8px; }
  .approval-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.4;
  }
  .approval-icon { font-size: 0.95rem; font-weight: 700; flex-shrink: 0; font-family: var(--wp-font-mono); }
  .approval-icon--pass { color: var(--wp-signal); }
  .approval-icon--warn { color: var(--wp-amber); }
  .approval-summary-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 0;
    border-top: 1px solid var(--wp-line);
    flex-wrap: wrap;
  }
  .approval-summary-label { min-width: 120px; }
  .approval-summary-value { font-size: var(--wp-text-base); color: var(--wp-text-secondary); }
  .approval-stamp-block {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 2px solid var(--wp-ink);
    display: flex;
    align-items: flex-start;
    gap: 24px;
    flex-wrap: wrap;
  }
  .approval-stamp {
    border: 2px solid var(--wp-ink);
    padding: 12px 20px;
    border-radius: 3px;
    text-align: center;
    flex-shrink: 0;
  }
  .approval-stamp-title {
    font-family: var(--wp-font-mono);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.14em;
    color: var(--wp-ink);
  }
  .approval-stamp-sub {
    font-size: var(--wp-text-xs);
    font-family: var(--wp-font-mono);
    color: var(--wp-text-tertiary);
    letter-spacing: 0.06em;
    margin-top: 4px;
  }
  .approval-close {
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* ===== REVIEW SURFACE (Step 9) ===== */
  .review-surface {
    background: #fff;
    border: 1px solid var(--wp-line);
    box-shadow: 0 2px 5px rgba(54,44,24,0.06), 0 12px 40px -10px rgba(54,44,24,0.18);
  }
  .review-surface-header {
    padding: 28px 32px 24px;
    border-bottom: 2px solid var(--wp-ink);
  }
  .review-surface-eyebrow {
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.14em;
  }
  .review-surface-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--wp-ink);
    line-height: 1.15;
  }
  .review-surface-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .review-meta {
    padding: 26px 28px;
    border-right: 1px solid var(--wp-line);
  }
  .review-meta-dl {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 10px 12px;
    margin: 0 0 24px;
    align-items: baseline;
  }
  .review-meta-dl--sm { gap: 8px 12px; margin-bottom: 0; }
  .review-meta-dt {
    font-size: 11px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-muted);
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }
  .review-meta-dd {
    font-size: var(--wp-text-sm);
    color: var(--wp-text-secondary);
    margin: 0;
    line-height: 1.4;
  }
  .review-meta-dd--signal { color: var(--wp-signal); font-weight: 600; }
  .review-meta-dd--warn { color: var(--wp-amber); }
  .review-meta-dd--blocked {
    font-family: var(--wp-font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--wp-ink);
  }
  .review-meta-dd--mono {
    font-family: var(--wp-font-mono);
    font-size: 11px;
    color: var(--wp-text-tertiary);
    letter-spacing: 0.04em;
    word-break: break-all;
  }
  .review-cms-block {
    padding-top: 20px;
    border-top: 1px solid var(--wp-line);
    margin-bottom: 20px;
  }
  .review-cms-heading {
    display: block;
    margin-bottom: 12px;
    letter-spacing: 0.12em;
  }
  .review-next-block {
    padding-top: 18px;
    border-top: 1px solid var(--wp-line);
  }
  .review-next-heading {
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.12em;
  }
  .review-next-body {
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Draft preview (right column) */
  .review-draft {
    padding: 26px 28px;
  }
  .review-draft-card {
    background: var(--wp-paper-soft);
    border: 1px solid var(--wp-line);
  }
  .review-draft-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 12px 18px;
    border-bottom: 1px solid var(--wp-line);
    flex-wrap: wrap;
  }
  .review-draft-body {
    position: relative;
    padding: 18px 18px 18px 42px;
  }
  .review-draft-margin {
    position: absolute;
    left: 28px; top: 0; bottom: 0;
    width: 1px;
    background: rgba(194,65,58,0.25);
  }
  .review-draft-heading {
    font-size: var(--wp-text-lg);
    font-weight: 700;
    font-family: var(--wp-font-sans);
    letter-spacing: -0.02em;
    margin: 0 0 14px;
    color: var(--wp-ink);
    line-height: 1.2;
  }
  .review-draft-text {
    font-size: var(--wp-text-sm);
    color: var(--wp-text-secondary);
    line-height: 1.7;
    margin: 0 0 12px;
    font-family: Georgia, 'Times New Roman', serif;
  }
  .review-draft-text:last-child { margin-bottom: 0; }
  .review-draft-text--anchor {
    font-weight: 700;
