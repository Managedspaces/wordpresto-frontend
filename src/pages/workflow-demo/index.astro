  .review-meta-dd--signal { color: var(--wp-signal); font-weight: 600; }
  .review-meta-dd--warn { color: var(--wp-amber); }
  .review-meta-dd--blocked { font-family: var(--wp-font-mono); font-weight: 700; font-size: 11px; letter-spacing: 0.1em; color: var(--wp-ink); }

  /* ===== META PACK ===== */
  .review-meta-pack { margin-top: 16px; background: var(--wp-paper-soft); border: 1px solid var(--wp-line); padding: 14px 18px; }
  .meta-pack-row { display: flex; gap: 12px; padding: 8px 0; border-bottom: 1px solid var(--wp-line); align-items: flex-start; }
  .meta-pack-row:last-child { border-bottom: none; }
  .meta-pack-label { font-size: 10px; font-family: var(--wp-font-mono); color: var(--wp-text-muted); letter-spacing: 0.08em; min-width: 60px; flex-shrink: 0; padding-top: 2px; }
  .meta-pack-value { font-size: var(--wp-text-xs); color: var(--wp-text-secondary); line-height: 1.5; }
  .meta-pack-alt { font-size: 10px; color: var(--wp-text-muted); font-family: var(--wp-font-mono); display: block; margin-top: 2px; }

  .review-cms-block { padding-top: 20px; border-top: 1px solid var(--wp-line); margin-bottom: 20px; }
  .review-cms-heading { display: block; margin-bottom: 12px; letter-spacing: 0.12em; }
  .review-next-block { padding-top: 18px; border-top: 1px solid var(--wp-line); }
  .review-next-heading { display: block; margin-bottom: 10px; letter-spacing: 0.12em; }
  .review-next-body { font-size: var(--wp-text-base); color: var(--wp-text-secondary); line-height: 1.65; margin: 0; }

  /* Draft preview */
  .review-draft { padding: 26px 28px; }
  .review-draft-card { background: var(--wp-paper-soft); border: 1px solid var(--wp-line); }
  .review-draft-header { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 12px 18px; border-bottom: 1px solid var(--wp-line); flex-wrap: wrap; }
  .review-draft-body { position: relative; padding: 18px 18px 18px 42px; }
  .review-draft-margin { position: absolute; left: 28px; top: 0; bottom: 0; width: 1px; background: rgba(194,65,58,0.25); }
  .review-draft-heading { font-size: var(--wp-text-lg); font-weight: 700; font-family: var(--wp-font-sans); letter-spacing: -0.02em; margin: 0 0 14px; color: var(--wp-ink); line-height: 1.2; }
  .review-draft-text { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.7; margin: 0 0 12px; font-family: Georgia, 'Times New Roman', serif; }
  .review-draft-text:last-child { margin-bottom: 0; }
  .review-draft-text--anchor { font-weight: 700; font-style: italic; color: var(--wp-ink); font-family: var(--wp-font-sans); font-size: var(--wp-text-base); margin-top: 4px; }
  .hand-annot--draft { position: absolute; bottom: 18px; right: 16px; font-size: 0.95rem; color: var(--wp-signal); transform: rotate(-4deg); }

  /* Final statement */
  .review-final { padding: 36px 32px 40px; border-top: 2px solid var(--wp-ink); text-align: center; background: var(--wp-paper-soft); }
  .review-final-line { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.025em; color: var(--wp-text-tertiary); margin: 0 0 8px; line-height: 1.2; }
  .review-final-line--strong { color: var(--wp-ink); font-size: clamp(1.6rem, 3.4vw, 2.4rem); margin-top: 4px; margin-bottom: 28px; }
  .review-final-cta { margin-top: 4px; }

  /* ===== FINAL CTA SECTION ===== */
  .section--cta { padding: 96px 0 104px; }
  .cta-inner { max-width: 760px; margin: 0 auto; padding: 0 34px; text-align: center; }
  .cta-logo { display: block; width: 174px; height: auto; margin: 0 auto 30px; }
  .cta-h2 { font-size: clamp(2.2rem, 4.8vw, 3.4rem); font-weight: 700; letter-spacing: -0.03em; margin: 0; line-height: 1.05; color: var(--wp-ink); }
  .cta-body { font-size: var(--wp-text-xl); color: var(--wp-text-secondary); line-height: 1.5; margin: 20px auto 0; max-width: 520px; }
  .cta-buttons { display: flex; gap: 12px; justify-content: center; margin-top: 32px; flex-wrap: wrap; }
  .cta-mark { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 40px; }
  .cta-rule { height: 1px; width: 44px; background: var(--wp-line); }
  .cta-mark-text { letter-spacing: 0.14em; }

  /* ===== FOOTER ===== */
  .footer { background-color: var(--wp-paper-dark); background-image: var(--wp-texture-paper); border-top: 2px solid var(--wp-ink); padding: 58px 0 42px; }
  .footer-inner { width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 34px; display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 32px; }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; max-width: 300px; }
  .footer-logo { display: block; height: 90px; width: auto; align-self: flex-start; mix-blend-mode: multiply; }
  .footer-tagline { margin: 6px 0 0; font-size: var(--wp-text-base); color: var(--wp-text-tertiary); line-height: 1.5; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col-heading { font-size: var(--wp-text-sm); font-weight: 700; }
  .footer-link { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); transition: color 150ms; }
  .footer-link:hover { color: var(--wp-ink); }
  .footer-bottom { width: 100%; max-width: 1200px; margin: 46px auto 0; padding: 22px 34px 0; border-top: 1px solid var(--wp-line); display: flex; flex-wrap: wrap; gap: 10px; justify-content: space-between; font-size: var(--wp-text-sm); color: var(--wp-text-muted); }
  .footer-legal-links .footer-link { font-size: var(--wp-text-sm); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .container { padding: 0 24px; }
    .section { padding: 52px 0; }
    .section--intro { padding: 44px 0 40px; }
    .section--demo { padding: 40px 0 60px; }
    .masthead-nav { display: none; }
    .masthead-inner { grid-template-columns: 1fr; justify-items: center; padding: 10px 20px; }
    .review-surface-body { grid-template-columns: 1fr; }
    .review-meta { border-right: none; border-bottom: 1px solid var(--wp-line); }
    .review-meta-dl { grid-template-columns: 110px 1fr; }
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; max-width: none; }
  }

  @media (max-width: 480px) {
    .container { padding: 0 18px; }
    .section { padding: 40px 0; }
    .section--intro { padding: 36px 0 32px; }
    .masthead-inner { padding: 8px 18px; }
    .progress-rail { gap: 12px; }
    .progress-rail-inner { gap: 5px; }
    .progress-dot { width: 8px; height: 8px; }
    .brief-dl { grid-template-columns: 1fr; gap: 4px 0; }
    .brief-dt { margin-top: 10px; }
    .brief-dt:first-child { margin-top: 0; }
    .review-surface-header { padding: 20px 20px 16px; }
    .review-meta { padding: 20px 18px; }
    .review-meta-dl { grid-template-columns: 96px 1fr; font-size: 11px; gap: 8px 10px; }
    .review-draft { padding: 18px; }
    .review-draft-body { padding-left: 30px; }
    .review-draft-margin { left: 18px; }
    .review-final { padding: 24px 20px 28px; }
    .output-card-header { padding: 12px 18px; }
    .output-card-body { padding: 18px; }
    .output-card-body--draft { padding: 18px 18px 18px 34px; }
    .draft-margin { left: 22px; }
    .primer-body { padding: 22px 18px 22px 44px; }
    .primer-margin { left: 32px; }
    .section--cta { padding: 56px 0 64px; }
    .cta-inner { padding: 0 18px; }
    .cta-buttons { flex-direction: column; align-items: stretch; }
    .cta-buttons .btn { justify-content: center; }
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 6px; }
    .footer { padding: 40px 0 28px; }
    .approval-stamp-block { flex-direction: column; }
    .track-legend { gap: 12px; }
  }

  /* ===== OUTPUT LIST ===== */
  .output-ul { margin: 6px 0 0; padding-left: 18px; color: var(--wp-text-secondary); font-size: var(--wp-text-base); line-height: 1.65; }
  .output-ul li { margin-bottom: 5px; }
  .output-ul li:last-child { margin-bottom: 0; }

  /* ===== SEO OPTIONS (Step 12) ===== */
  .seo-options { display: flex; flex-direction: column; gap: 10px; }
  .seo-option { display: flex; gap: 12px; align-items: flex-start; padding: 10px 12px; background: var(--wp-paper-soft); border: 1px solid var(--wp-line); border-radius: 3px; }
  .seo-option-label { font-family: var(--wp-font-mono); font-weight: 700; font-size: 12px; color: var(--wp-text-muted); flex-shrink: 0; padding-top: 1px; }
  .seo-option-body { display: flex; flex-direction: column; gap: 3px; }
  .seo-option-text { font-size: var(--wp-text-base); color: var(--wp-ink); line-height: 1.4; }
  .seo-option-meta { font-size: 11px; color: var(--wp-text-muted); font-family: var(--wp-font-mono); letter-spacing: 0.04em; }

  /* ===== SIGNAL MAP (Omar Step 1) ===== */
  .signal-map { display: flex; flex-direction: column; }
  .signal-row { display: grid; grid-template-columns: 76px 1fr; gap: 10px 16px; padding: 14px 24px; border-bottom: 1px solid var(--wp-line); align-items: flex-start; }
  .signal-row:last-child { border-bottom: none; }
  .signal-row--search { background: var(--wp-signal-soft); }
  .signal-row--phrases { background: #FDFCF8; }
  .signal-label { font-size: 10px; font-family: var(--wp-font-mono); color: var(--wp-text-muted); letter-spacing: 0.1em; text-transform: uppercase; padding-top: 2px; }
  .signal-value { font-size: var(--wp-text-base); color: var(--wp-text-secondary); line-height: 1.6; display: flex; flex-direction: column; gap: 5px; }
  .signal-sub { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.5; }
  .signal-tension { font-size: var(--wp-text-sm); color: var(--wp-amber); font-style: italic; border-left: 2px solid var(--wp-amber); padding-left: 8px; margin-top: 4px; }
  .signal-phrase { display: flex; align-items: flex-start; gap: 8px; padding: 5px 0; }
  .signal-phrase-icon { font-family: var(--wp-font-mono); font-size: 0.8rem; color: var(--wp-signal); flex-shrink: 0; padding-top: 1px; }
  .signal-phrase-text { font-size: var(--wp-text-sm); color: var(--wp-ink); line-height: 1.5; font-style: italic; }
  .signal-phrase-note { font-size: 11px; color: var(--wp-text-muted); font-family: var(--wp-font-mono); letter-spacing: 0.04em; margin-top: 4px; }

  /* ===== VOICE PROFILE (Helena Step 8) ===== */
  .voice-profile { display: flex; flex-direction: column; }
  .voice-profile-header { padding: 16px 24px; border-bottom: 1px solid var(--wp-line); background: var(--wp-paper-soft); }
  .profile-name { display: block; font-size: var(--wp-text-base); font-weight: 700; color: var(--wp-ink); letter-spacing: -0.01em; margin-bottom: 4px; }
  .profile-register { font-size: 11px; color: var(--wp-text-muted); font-family: var(--wp-font-mono); letter-spacing: 0.06em; }
  .profile-body { display: grid; grid-template-columns: 1fr 1fr; }
  .profile-col { padding: 20px 24px; }
  .profile-col:first-child { border-right: 1px solid var(--wp-line); }
  .profile-section { margin-bottom: 20px; }
  .profile-section:last-child { margin-bottom: 0; }
  .profile-heading { font-size: 10px; font-family: var(--wp-font-mono); letter-spacing: 0.1em; color: var(--wp-text-muted); text-transform: uppercase; margin-bottom: 10px; }
  .profile-marker { display: flex; align-items: flex-start; padding: 5px 0; border-bottom: 1px solid var(--wp-line); }
  .profile-marker:last-child { border-bottom: none; }
  .profile-marker--protected { background: var(--wp-signal-soft); padding: 6px 10px; border: 1px solid var(--wp-signal-border); border-radius: 2px; margin-bottom: 3px; }
  .profile-marker-text { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.5; }
  .profile-marker--protected .profile-marker-text { color: var(--wp-signal); font-weight: 500; }
  .banned-pills { display: flex; flex-wrap: wrap; gap: 6px; }
  .banned-pill { background: rgba(196,122,28,0.1); border: 1px solid rgba(196,122,28,0.25); color: var(--wp-amber); font-size: 11px; font-family: var(--wp-font-mono); padding: 3px 8px; border-radius: 3px; }
  .profile-note { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.6; margin: 0; }

  /* ===== CLAIMS TABLE (Vera Step 11) ===== */
  .claims-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .claims-table { width: 100%; border-collapse: collapse; }
  .claims-thead { background: var(--wp-paper-soft); border-bottom: 2px solid var(--wp-ink); }
  .claims-th { padding: 10px 16px; font-size: 10px; font-family: var(--wp-font-mono); color: var(--wp-text-muted); letter-spacing: 0.08em; text-align: left; font-weight: 600; }
  .claims-th--narrow { width: 76px; }
  .claims-tbody .claims-tr:nth-child(even) { background: var(--wp-paper-soft); }
  .claims-td { padding: 10px 16px; font-size: var(--wp-text-sm); color: var(--wp-text-secondary); vertical-align: top; line-height: 1.5; border-bottom: 1px solid var(--wp-line); }
  .claims-tbody .claims-tr:last-child .claims-td { border-bottom: none; }
  .claims-footer { padding: 12px 16px; border-top: 2px solid var(--wp-ink); background: var(--wp-paper-soft); }
  .risk-pill { display: inline-flex; align-items: center; border-radius: 3px; font-family: var(--wp-font-mono); font-weight: 700; font-size: 10px; letter-spacing: 0.08em; padding: 3px 7px; white-space: nowrap; }
  .risk-pill--low { background: var(--wp-signal-soft); border: 1px solid var(--wp-signal-border); color: var(--wp-signal); }
  .risk-pill--medium { background: var(--wp-amber-soft); border: 1px solid rgba(196,122,28,0.3); color: var(--wp-amber); }
  .risk-pill--warn { background: rgba(194,65,58,0.08); border: 1px solid rgba(194,65,58,0.25); color: #b83a34; }

  /* ===== HANDOFF PANEL (Ravi Step 14 + Step 15) ===== */
  .handoff-panel { display: flex; flex-direction: column; }
  .handoff-row { display: grid; grid-template-columns: 72px 1fr auto; gap: 8px 14px; padding: 11px 20px; border-bottom: 1px solid var(--wp-line); align-items: flex-start; }
  .handoff-row:last-child { border-bottom: none; }
  .handoff-row--final { background: var(--wp-paper-soft); }
  .handoff-panel--compact .handoff-row { padding: 9px 14px; grid-template-columns: 64px 1fr; }
  .handoff-label { font-size: 10px; font-family: var(--wp-font-mono); color: var(--wp-text-muted); letter-spacing: 0.08em; text-transform: uppercase; padding-top: 2px; }
  .handoff-value { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.5; }
  .handoff-value--mono { font-family: var(--wp-font-mono); font-size: 12px; color: var(--wp-ink); }
  .handoff-note { display: block; font-size: 10px; color: var(--wp-text-muted); font-family: var(--wp-font-mono); letter-spacing: 0.04em; margin-top: 3px; }
  .handoff-status { font-size: 10px; font-family: var(--wp-font-mono); font-weight: 700; letter-spacing: 0.08em; white-space: nowrap; padding-top: 2px; flex-shrink: 0; }
  .handoff-status--ready { color: var(--wp-signal); }
  .handoff-status--pending { color: var(--wp-amber); }
  .handoff-status--blocked { color: var(--wp-ink); }

  /* ===== STATUS PILLS ===== */
  .status-pill { display: inline-flex; align-items: center; border-radius: 3px; font-family: var(--wp-font-mono); font-weight: 700; font-size: 10px; letter-spacing: 0.09em; padding: 3px 9px; white-space: nowrap; }
  .status-pill--ready { background: var(--wp-signal-soft); border: 1px solid var(--wp-signal-border); color: var(--wp-signal); }
  .status-pill--pending { background: var(--wp-amber-soft); border: 1px solid rgba(196,122,28,0.25); color: var(--wp-amber); }
  .status-pill--blocked { background: rgba(17,19,24,0.06); border: 1px solid rgba(17,19,24,0.18); color: var(--wp-ink); }

  /* ===== STEP 15 EXPANDED REVIEW SURFACE ===== */
  .review-surface-status-bar { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 14px; }
  .review-title-preview { padding: 20px 32px; border-bottom: 1px solid var(--wp-line); background: #FEFBF3; }
  .review-title-label { display: block; margin-bottom: 10px; letter-spacing: 0.1em; font-size: var(--wp-text-xs); color: var(--wp-text-muted); font-family: var(--wp-font-mono); text-transform: uppercase; }
  .review-title-chosen { font-size: var(--wp-text-lg); font-weight: 700; color: var(--wp-ink); letter-spacing: -0.02em; margin: 0 0 12px; line-height: 1.3; }
  .review-intro-para { font-size: var(--wp-text-base); color: var(--wp-text-secondary); line-height: 1.7; margin: 0; font-family: Georgia, 'Times New Roman', serif; }
  .review-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); border-bottom: 1px solid var(--wp-line); }
  .review-panel { padding: 20px 22px; border-right: 1px solid var(--wp-line); }
  .review-panel:last-child { border-right: none; }
  .review-panel-heading { font-size: 11px; font-family: var(--wp-font-mono); letter-spacing: 0.12em; color: var(--wp-ink); font-weight: 700; text-transform: uppercase; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 2px solid var(--wp-ink); }
  .review-panel-section { margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--wp-line); }
  .review-panel-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .review-panel-label { font-size: 10px; font-family: var(--wp-font-mono); letter-spacing: 0.1em; color: var(--wp-text-muted); text-transform: uppercase; margin-bottom: 7px; }
  .review-panel-note { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.55; margin: 0; }
  .review-panel-note--pass { color: var(--wp-signal); font-weight: 500; }
  .review-panel-list { margin: 0; padding-left: 16px; font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.55; }
  .review-panel-list li { margin-bottom: 5px; }
  .review-panel-list li:last-child { margin-bottom: 0; }
  .review-panel-list--warn li { color: var(--wp-amber); }
  .review-phrase-row { display: flex; gap: 10px; padding: 7px 0; border-bottom: 1px solid var(--wp-line); align-items: flex-start; }
  .review-phrase-row:last-child { border-bottom: none; }
  .review-phrase-status { font-family: var(--wp-font-mono); font-size: 0.85rem; flex-shrink: 0; padding-top: 1px; }
  .review-phrase-status--pass { color: var(--wp-signal); }
  .review-phrase-text { display: block; font-size: var(--wp-text-sm); color: var(--wp-ink); font-style: italic; font-weight: 600; line-height: 1.4; }
  .review-phrase-note { display: block; font-size: 11px; color: var(--wp-text-muted); font-family: var(--wp-font-mono); letter-spacing: 0.04em; margin-top: 3px; }
  .section-map { display: flex; flex-direction: column; gap: 2px; }
  .section-map-row { display: grid; grid-template-columns: 22px 1fr auto; gap: 7px; padding: 5px 0; border-bottom: 1px solid var(--wp-line); align-items: flex-start; }
  .section-map-row:last-child { border-bottom: none; }
  .section-map-row--anchor { background: var(--wp-signal-soft); padding: 5px 7px; border-radius: 2px; border: 1px solid var(--wp-signal-border); }
  .section-map-tag { font-size: 10px; font-family: var(--wp-font-mono); color: var(--wp-text-muted); padding-top: 1px; }
  .section-map-title { font-size: var(--wp-text-sm); color: var(--wp-ink); line-height: 1.35; }
  .section-map-flag { font-size: 9px; font-family: var(--wp-font-mono); letter-spacing: 0.06em; white-space: nowrap; padding-top: 2px; }
  .section-map-flag--pass { color: var(--wp-signal); }
  .section-map-flag--pending { color: var(--wp-amber); }
  .review-risk-strip { display: flex; flex-direction: column; gap: 6px; }
  .review-risk-row { display: flex; align-items: center; gap: 10px; }
  .review-risk-text { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.4; }
  .review-draft-full { border-top: 1px solid var(--wp-line); background: #FEFBF3; }
  .review-draft-full-header { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 12px 32px; border-bottom: 1px solid var(--wp-line); flex-wrap: wrap; }
  .review-draft-full-body { position: relative; padding: 22px 32px 28px 58px; }
  .review-draft-text--placeholder { font-weight: 600; font-style: italic; color: var(--wp-amber); font-family: var(--wp-font-sans); font-size: var(--wp-text-base); border-left: 3px solid var(--wp-amber); padding-left: 12px; margin-left: -15px; }
  .review-approval-strip { display: flex; flex-wrap: wrap; border-top: 2px solid var(--wp-ink); background: var(--wp-paper-soft); }
  .approval-strip-item { display: flex; align-items: center; gap: 8px; padding: 11px 18px; font-size: var(--wp-text-sm); border-right: 1px solid var(--wp-line); }
  .approval-strip-item:last-child { border-right: none; }
  .approval-strip-icon { font-family: var(--wp-font-mono); font-weight: 700; font-size: 0.9rem; flex-shrink: 0; }
  .approval-strip-item--pass { color: var(--wp-text-secondary); }
  .approval-strip-item--pass .approval-strip-icon { color: var(--wp-signal); }
  .approval-strip-item--warn { color: var(--wp-amber); }
  .approval-strip-item--warn .approval-strip-icon { color: var(--wp-amber); }

  /* ===== RESPONSIVE ADDITIONS ===== */
