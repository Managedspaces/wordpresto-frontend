<script>
  (function () {
    function revealStep(stepNum: number) {
      const el = document.getElementById('step-' + stepNum);
      if (!el) return;

      el.classList.add('demo-step--revealed');

      requestAnimationFrame(() => {
        setTimeout(() => {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
      });

      updateProgress(stepNum);

      if (stepNum === 15) {
        const ctaSection = document.getElementById('demo-cta-section');
        if (ctaSection) ctaSection.style.display = '';
      }
    }

    function updateProgress(activeStep: number) {
      const dots = document.querySelectorAll('.progress-dot');
      dots.forEach((dot, i) => {
        dot.classList.remove('progress-dot--active', 'progress-dot--done');
        if (i < activeStep) {
          dot.classList.add('progress-dot--done');
        } else if (i === activeStep) {
          dot.classList.add('progress-dot--active');
        }
      });
      const label = document.getElementById('progress-current');
      if (label) label.textContent = String(activeStep);
    }

    document.addEventListener('click', function (e) {
      const target = e.target as HTMLElement;
      const btn = target.closest('[data-reveals]') as HTMLElement | null;
      if (!btn) return;
      const revealNum = parseInt((btn as HTMLElement).dataset['reveals'] ?? '', 10);
      if (!isNaN(revealNum)) {
        revealStep(revealNum);
      }
    });
  })();
</script>

