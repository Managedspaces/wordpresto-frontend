---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { approvalGovernanceTeam as meta } from '@/data/staticPages';
import { getWorkersByTeam, TEAM_META } from '@/data/workerRegistry';

const team = TEAM_META.governance;
const workers = getWorkersByTeam('governance');
---

<BaseLayout
  pageTitle={meta.h1}
  seoTitle={meta.seoTitle}
  description={meta.metaDescription}
  canonical="https://wordpresto.com/specialists/approval-governance/"
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href="/waitlist" class="nav-link">Sign in</a>
        <a href="/#product" class="nav-link">Product</a>
        <a href="/#capabilities" class="nav-link">Workflow</a>
      </nav>
      <a href="/" class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href="/#use-cases" class="nav-link">Use cases</a>
        <a href="/workers/" class="nav-link">Workers</a>
        <a href="/waitlist" class="btn btn--primary btn--sm">Join the waitlist</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="section section--hero">
    <div class="container">
      <nav class="wp-breadcrumb" aria-label="Breadcrumb">
        <a href="/specialists/" class="wp-breadcrumb-back">&#8592;</a>
        <a href="/specialists/" class="wp-breadcrumb-link">SPECIALISTS</a>
        <span class="wp-breadcrumb-sep">/</span>
        <span class="wp-breadcrumb-current">APPROVAL / GOVERNANCE</span>
      </nav>

      <div class="eyebrow" style={`color: ${team.color}`}>{team.name}</div>
      <h1 class="page-h1">{meta.h1}</h1>
      <p class="page-intro">{meta.intro}</p>
      <div class="worker-directory-header">
        <span>TEAM DIRECTORY</span>
        <span>{workers.length} SPECIALIST ROLE{workers.length === 1 ? "" : "S"}</span>
      </div>

      <div class="specialists-grid">
        {workers.map((w) => (
          <div class="specialist-card">
            <div class="specialist-card-top">
              <div class="specialist-card-name">{w.name}</div>
              <div class="specialist-card-role">{w.roleTitle}</div>
            </div>
            <div class="specialist-card-tags">
              <span class="specialist-tag">
                <span class="specialist-tag-dot" style={`background: ${team.color}`}></span>
                {w.department}
              </span>
              {w.status === 'planned' && <span class="specialist-tag specialist-tag--planned">Planned</span>}
            </div>
            {w.slug ? (
              <a href={`/workers/${w.slug}/`} class="specialist-card-link">
                View profile
                <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            ) : (
              <span class="specialist-card-pending">Profile page coming soon</span>
            )}
          </div>
        ))}
      </div>

      <div class="specialists-note">
        <p>The Approval / Governance Team checks risk, evidence and approval state before anything is marked ready. Their findings inform the Editor; only the Editor gives final approval.</p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/brand/main-logo.png" alt="Word Presto" class="footer-logo" loading="lazy" />
        <p class="footer-tagline">The content engine behind better publishing workflows.</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Product</span>
        <a href="/#product" class="footer-link">How it works</a>
        <a href="/#capabilities" class="footer-link">Workflow</a>
        <a href="/workers/" class="footer-link">Workers</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Use cases</span>
        <a href="/#use-cases" class="footer-link">Astro + CMS builds</a>
        <a href="/#use-cases" class="footer-link">CMS-connected</a>
        <a href="/#use-cases" class="footer-link">Standalone engine</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Company</span>
        <a href="/waitlist" class="footer-link">Join the waitlist</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 WordPresto</span>
      <span>Review-led publishing · Human approval</span>
      <a href="/sitemap/" class="footer-link footer-sitemap-link">Sitemap</a>
    </div>
  </footer>

</BaseLayout>

<style>
  /* ===== MASTHEAD ===== */
  .masthead {
    position: sticky;
    top: 0;
    z-index: 60;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
    border-bottom: 2px solid var(--wp-ink);
    transform: translateZ(0);
  }
  .masthead-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 34px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 28px;
  }
  .masthead-logo img { display: block; height: 48px; width: auto; mix-blend-mode: multiply; }
  .masthead-nav { display: flex; align-items: center; gap: 24px; }
  .masthead-nav--left { justify-content: flex-start; }
  .masthead-nav--right { justify-content: flex-end; }
  .nav-link { font-size: var(--wp-text-md); font-weight: 500; color: var(--wp-text-secondary); }
  .nav-link:hover { color: var(--wp-ink); }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--wp-text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    border-radius: 5px;
    text-decoration: none;
  }
  .btn--primary {
    padding: 14px 24px;
    background: var(--wp-ink);
    color: #FAF7F0;
    border: 1px solid var(--wp-ink);
    box-shadow: 0 2px 4px rgba(54,44,24,0.12), 0 10px 18px -8px rgba(54,44,24,0.22);
  }
  .btn--sm { padding: 8px 16px; font-size: var(--wp-text-sm); }

  /* ===== LAYOUT ===== */
  .section {
    padding: 92px 0;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
  }
  .section--hero { padding: 56px 0 80px; }
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
  }
  .wp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 22px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.06em;
    color: var(--wp-text-tertiary);
  }
  .wp-breadcrumb-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px; height: 22px;
    border: 1px solid var(--wp-line);
    border-radius: 4px;
    color: var(--wp-text-secondary);
  }
  .wp-breadcrumb-link { color: var(--wp-text-secondary); }
  .wp-breadcrumb-link:hover { color: var(--wp-ink); }
  .wp-breadcrumb-sep { color: var(--wp-text-muted); }
  .wp-breadcrumb-current { color: var(--wp-ink); font-weight: 700; }
  .eyebrow {
    font-size: var(--wp-text-sm);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .page-h1 {
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.04;
    color: var(--wp-ink);
    margin: 0 0 20px;
    max-width: 720px;
  }
  .page-intro {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.5;
    margin: 0 0 36px;
    max-width: 600px;
  }

  /* ===== SPECIALIST DIRECTORY ===== */
  .worker-directory-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--wp-border-strong);
    border-bottom: 1px solid var(--wp-border-strong);
    padding: 10px 2px;
    margin-bottom: 24px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.08em;
    color: var(--wp-text-tertiary);
  }
  .specialists-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }
  .specialist-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(54,44,24,0.05), 0 12px 24px -16px rgba(54,44,24,0.14);
    padding: 16px;
  }
  .specialist-card-name { font-size: var(--wp-text-lg); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
  .specialist-card-role { font-size: var(--wp-text-sm); color: var(--wp-text-tertiary); margin-top: 3px; }
  .specialist-card-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .specialist-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border: 1px solid var(--wp-line);
    border-radius: var(--wp-radius-pill);
    font-size: 10px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-tertiary);
    letter-spacing: 0.04em;
  }
  .specialist-tag-dot { width: 6px; height: 6px; border-radius: 50%; }
  .specialist-tag--planned { color: var(--wp-text-tertiary); border-style: dashed; }
  .specialist-card-link {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--wp-text-xs);
    font-weight: 600;
    color: var(--wp-ink);
  }
  .specialist-card-pending {
    margin-top: auto;
    font-size: var(--wp-text-xs);
    font-style: italic;
    color: var(--wp-text-muted);
  }

  .specialists-note {
    margin-top: 30px;
    padding: 18px 22px;
    background: #FFF;
    border: 1px dashed var(--wp-border-strong);
    max-width: 720px;
  }
  .specialists-note p { margin: 0; font-size: var(--wp-text-base); color: var(--wp-text-secondary); line-height: 1.6; }

  /* ===== FOOTER ===== */
  .footer {
    background-color: var(--wp-paper-dark);
    background-image: var(--wp-texture-paper);
    border-top: 2px solid var(--wp-ink);
    padding: 58px 0 42px;
  }
  .footer-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 32px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; max-width: 300px; }
  .footer-logo { display: block; height: 90px; width: auto; align-self: flex-start; mix-blend-mode: multiply; }
  .footer-tagline { margin: 6px 0 0; font-size: var(--wp-text-base); color: var(--wp-text-tertiary); line-height: 1.5; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col-heading { font-size: var(--wp-text-sm); font-weight: 700; }
  .footer-link { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); }
  .footer-link:hover { color: var(--wp-ink); }
  .footer-bottom {
    width: 100%;
    max-width: 1200px;
    margin: 46px auto 0;
    padding: 22px 34px 0;
    border-top: 1px solid var(--wp-border-strong);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: space-between;
    font-size: var(--wp-text-sm);
    color: var(--wp-text-muted);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 940px) {
    .masthead-nav { display: none; }
    .masthead-inner { grid-template-columns: 1fr; justify-items: center; padding: 10px 20px; }
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .container { padding: 0 20px; }
    .specialists-grid { grid-template-columns: 1fr; }
    .worker-directory-header { flex-direction: column; align-items: flex-start; gap: 2px; }
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>
