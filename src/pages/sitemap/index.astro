---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { workerProfiles } from '@/data/workerProfiles';
import { mainRoutes, machineRoutes } from '@/data/siteRoutes';

const seoTitle = 'Site map | WordPresto';
const metaDescription = 'A complete map of the WordPresto site — main pages, Workers and resources.';

// Worker profiles are split to mirror the two directory pages they live under:
// /workers/ and /workers/seo/ both render getWorkersByTeam() from
// workerRegistry.ts (the real org team), so the split here matches by
// `profile.team` too. Governance and operations profiles have no equivalent
// /workers/{team}/ directory page (only /specialists/{team}/), so they get
// their own sitemap section below instead of being silently omitted.
const contentWorkers = workerProfiles.filter((w) => w.team === 'content');
const seoWorkers = workerProfiles.filter((w) => w.team === 'seo');
const governanceOpsWorkers = workerProfiles.filter((w) => w.team === 'governance' || w.team === 'operations');
---

<BaseLayout
  pageTitle="Site map"
  seoTitle={seoTitle}
  description={metaDescription}
  canonical="https://wordpresto.com/sitemap/"
>

  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href="/waitlist" class="nav-link">Sign in</a>
      </nav>
      <a href="/" class="masthead-logo-link" aria-label="WordPresto home">
        <img
          src="/brand/horizontal-lockup-transparent.png"
          alt="Word Presto"
          class="masthead-logo"
          width="160"
          height="40"
        />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href="/waitlist/" class="nav-cta">Get early access</a>
      </nav>
    </div>
  </header>

  <main class="sitemap-main">
    <div class="container">

      <div class="page-header">
        <h1 class="page-title">Site map</h1>
        <p class="page-desc">Every page on wordpresto.com, organised by section.</p>
      </div>

      <!-- Main pages -->
      <section class="sitemap-section">
        <h2 class="section-heading">Main pages</h2>
        <ul class="sitemap-list">
          {mainRoutes.map(p => (
            <li class="sitemap-item">
              <a href={p.path} class="sitemap-link">
                <span class="sitemap-label">{p.label}</span>
                <span class="sitemap-url">{p.path}</span>
              </a>
              <p class="sitemap-desc">{p.description}</p>
            </li>
          ))}
        </ul>
      </section>

      <!-- Content Workers -->
      <section class="sitemap-section">
        <h2 class="section-heading">Content Workers</h2>
        <p class="section-intro">Specialist Workers for every stage of the content workflow.</p>
        <ul class="sitemap-list sitemap-list--workers">
          {contentWorkers.map(w => (
            <li class="sitemap-item">
              <a href={`/workers/${w.slug}/`} class="sitemap-link">
                <span class="sitemap-label">{w.role}</span>
                <span class="sitemap-url">/workers/{w.slug}/</span>
              </a>
              <p class="sitemap-desc">{w.name} &middot; {w.department}</p>
            </li>
          ))}
        </ul>
      </section>

      <!-- SEO Workers -->
      <section class="sitemap-section">
        <h2 class="section-heading">SEO Workers</h2>
        <p class="section-intro">SEO Workers for search, structure and authority. See the <a href="/workers/seo/" class="sitemap-inline-link">SEO Workers directory</a>.</p>
        <ul class="sitemap-list sitemap-list--workers">
          {seoWorkers.map(w => (
            <li class="sitemap-item">
              <a href={`/workers/${w.slug}/`} class="sitemap-link">
                <span class="sitemap-label">{w.role}</span>
                <span class="sitemap-url">/workers/{w.slug}/</span>
              </a>
              <p class="sitemap-desc">{w.name} &middot; {w.department}</p>
            </li>
          ))}
        </ul>
      </section>

      <!-- Approval, Governance & Operations Workers -->
      {governanceOpsWorkers.length > 0 && (
        <section class="sitemap-section">
          <h2 class="section-heading">Approval, Governance &amp; Operations Workers</h2>
          <p class="section-intro">See the <a href="/specialists/approval-governance/" class="sitemap-inline-link">Approval / Governance</a> and <a href="/specialists/operations-management/" class="sitemap-inline-link">Operations / Management</a> team pages.</p>
          <ul class="sitemap-list sitemap-list--workers">
            {governanceOpsWorkers.map(w => (
              <li class="sitemap-item">
                <a href={`/workers/${w.slug}/`} class="sitemap-link">
                  <span class="sitemap-label">{w.role}</span>
                  <span class="sitemap-url">/workers/{w.slug}/</span>
                </a>
                <p class="sitemap-desc">{w.name} &middot; {w.department}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Legal -->
      <section class="sitemap-section">
        <h2 class="section-heading">Legal</h2>
        <ul class="sitemap-list sitemap-list--workers">
          <li class="sitemap-item">
            <a href="/privacy/" class="sitemap-link">
              <span class="sitemap-label">Privacy Policy</span>
              <span class="sitemap-url">/privacy/</span>
            </a>
            <p class="sitemap-desc">How we collect, use and protect personal data.</p>
          </li>
          <li class="sitemap-item">
            <a href="/terms/" class="sitemap-link">
              <span class="sitemap-label">Terms &amp; Conditions</span>
              <span class="sitemap-url">/terms/</span>
            </a>
            <p class="sitemap-desc">The terms that govern use of the site and the app.</p>
          </li>
          <li class="sitemap-item">
            <a href="/cookies/" class="sitemap-link">
              <span class="sitemap-label">Cookie Policy</span>
              <span class="sitemap-url">/cookies/</span>
            </a>
            <p class="sitemap-desc">What cookies we use, and how to control them.</p>
          </li>
          <li class="sitemap-item">
            <a href="/fair-use/" class="sitemap-link">
              <span class="sitemap-label">Fair Use Policy</span>
              <span class="sitemap-url">/fair-use/</span>
            </a>
            <p class="sitemap-desc">What is and is not acceptable use of the platform.</p>
          </li>
          <li class="sitemap-item">
            <a href="/data-deletion/" class="sitemap-link">
              <span class="sitemap-label">Data Deletion Instructions</span>
              <span class="sitemap-url">/data-deletion/</span>
            </a>
            <p class="sitemap-desc">How to request deletion of your personal data.</p>
          </li>
        </ul>
      </section>

      <!-- Machine-readable -->
      <section class="sitemap-section sitemap-section--minor">
        <h2 class="section-heading">Machine-readable</h2>
        <ul class="sitemap-list">
          {machineRoutes.map(p => (
            <li class="sitemap-item">
              <a href={p.path} class="sitemap-link">
                <span class="sitemap-label">{p.label}</span>
                <span class="sitemap-url">{p.path}</span>
              </a>
              <p class="sitemap-desc">{p.description}</p>
            </li>
          ))}
        </ul>
      </section>

    </div>
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="/brand/horizontal-lockup-transparent.png" alt="Word Presto" class="footer-logo" />
        <p class="footer-tagline">The content engine behind better publishing workflows.</p>
      </div>
      <nav class="footer-nav" aria-label="Site">
        <span class="footer-nav-heading">Site</span>
        <a href="/" class="footer-link">Home</a>
        <a href="/workers/" class="footer-link">Workers</a>
        <a href="/workflow-demo/" class="footer-link">Workflow demo</a>
        <a href="/sitemap/" class="footer-link">Sitemap</a>
      </nav>
      <nav class="footer-nav" aria-label="Get access">
        <span class="footer-nav-heading">Get access</span>
        <a href="/waitlist/" class="footer-link">Join now</a>
      </nav>
    </div>
    <div class="footer-bottom container">
      <span>© 2026 Word Presto</span>
      <span>Review-led publishing · Human approval</span>
      <span class="footer-legal-links">
        <a href="/privacy/" class="footer-link">Privacy</a> ·
        <a href="/terms/" class="footer-link">Terms</a> ·
        <a href="/cookies/" class="footer-link">Cookies</a> ·
        <a href="/fair-use/" class="footer-link">Fair use</a> ·
        <a href="/data-deletion/" class="footer-link">Data deletion</a>
      </span>
    </div>
  </footer>

</BaseLayout>

<style>
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ===== MASTHEAD ===== */
  .masthead {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--wp-paper);
    border-bottom: 1px solid var(--wp-rule);
    transform: translateZ(0);
  }
  .masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 24px;
    height: 56px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .masthead-logo-link { display: flex; align-items: center; justify-content: center; }
  .masthead-logo { height: 36px; width: auto; mix-blend-mode: multiply; }
  .masthead-nav { display: flex; align-items: center; gap: 16px; }
  .masthead-nav--right { justify-content: flex-end; }
  .nav-link { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); }
  .nav-link:hover { color: var(--wp-ink); }
  .nav-cta {
    font-size: var(--wp-text-sm);
    font-weight: 600;
    background: var(--wp-ink);
    color: var(--wp-paper);
    padding: 7px 16px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .nav-cta:hover { opacity: 0.85; }

  /* ===== MAIN ===== */
  .sitemap-main {
    padding: 56px 0 80px;
  }

  .page-header {
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 2px solid var(--wp-ink);
  }
  .page-title {
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 12px;
  }
  .page-desc {
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    margin: 0;
  }

  /* ===== SECTIONS ===== */
  .sitemap-section {
    margin-bottom: 48px;
  }
  .sitemap-section--minor {
    margin-top: 8px;
    padding-top: 32px;
    border-top: 1px solid var(--wp-rule);
  }
  .section-heading {
    font-size: var(--wp-text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 8px;
    color: var(--wp-text-tertiary);
  }
  .section-intro {
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    margin: 0 0 24px;
  }
  .sitemap-inline-link {
    color: var(--wp-ink);
    font-weight: 600;
    text-decoration: underline;
  }

  /* ===== LIST ===== */
  .sitemap-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }
  .sitemap-list--workers {
    grid-template-columns: repeat(2, 1fr);
  }
  .sitemap-item {
    background: var(--wp-paper-soft, #f9f6f1);
    border: 1px solid var(--wp-rule, #e0dbd2);
    padding: 16px 20px;
    border-radius: 2px;
  }
  .sitemap-item:hover {
    background: var(--wp-paper);
  }
  .sitemap-link {
    display: flex;
    align-items: baseline;
    gap: 12px;
    text-decoration: none;
    margin-bottom: 4px;
  }
  .sitemap-link:hover .sitemap-label {
    text-decoration: underline;
  }
  .sitemap-label {
    font-size: var(--wp-text-base);
    font-weight: 600;
    color: var(--wp-ink);
    flex-shrink: 0;
  }
  .sitemap-url {
    font-size: var(--wp-text-xs, 11px);
    font-family: var(--wp-font-mono, monospace);
    color: var(--wp-text-tertiary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sitemap-desc {
    font-size: var(--wp-text-sm);
    color: var(--wp-text-secondary);
    margin: 0;
    line-height: 1.4;
  }

  /* ===== FOOTER ===== */
  .footer {
    border-top: 1px solid var(--wp-rule);
    padding: 48px 0 28px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 32px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; max-width: 300px; }
  .footer-logo { display: block; height: 90px; width: auto; align-self: flex-start; margin-left: -4px; }
  .footer-tagline { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); line-height: 1.5; margin: 6px 0 0; }
  .footer-nav { display: flex; flex-direction: column; gap: 10px; }
  .footer-nav-heading { font-size: var(--wp-text-sm); font-weight: 700; }
  .footer-link { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); transition: color 150ms; }
  .footer-link:hover { color: var(--wp-ink); }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px 16px;
    padding-top: 20px;
    border-top: 1px solid var(--wp-rule);
    font-size: var(--wp-text-sm);
    color: var(--wp-text-tertiary);
  }
  .footer-legal-links { font-size: var(--wp-text-sm); }
  .footer-legal-links .footer-link { font-size: var(--wp-text-sm); }

  @media (max-width: 768px) {
    .sitemap-list--workers {
      grid-template-columns: 1fr;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 6px;
    }
  }
</style>
