---
import WorkerProfilePage from '@/components/WorkerProfilePage.astro';
import { workerProfiles } from '@/data/workerProfiles';

export function getStaticPaths() {
  return workerProfiles.map((profile) => ({
    params: { slug: profile.slug },
    props: { englishProfile: profile },
  }));
}

interface Props { englishProfile: (typeof workerProfiles)[number] }
const { englishProfile } = Astro.props;
---

<WorkerProfilePage locale="en" englishProfile={englishProfile} />
