---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { workers, seoWorkers } from '@/data/workers';

const seoTitle = 'Content and SEO workflow Workers | WordPresto';
const metaDescription = 'Meet the specialist Workers in the WordPresto content workflow, from content analysis, brief building and voice review to SEO metadata, schema, search snippets, evidence and CMS handoff.';
---

<BaseLayout
  pageTitle="Specialist Workers for every stage of the content workflow."
  seoTitle={seoTitle}
  description={metaDescription}
  canonical="https://wordpresto.com/workers/"
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href="/waitlist" class="nav-link">Sign in</a>
        <a href="/#product" class="nav-link">Product</a>
        <a href="/#capabilities" class="nav-link">Workflow</a>
      </nav>
      <a href="/" class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href="/#use-cases" class="nav-link">Use cases</a>
        <a href="/workers/" class="nav-link nav-link--active">Workers</a>
        <a href="/waitlist" class="btn btn--primary btn--sm">Join the waitlist</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="section section--hero">
    <div class="container">
      <div class="eyebrow eyebrow--strategy">The team</div>
      <h1 class="page-h1">Specialist Workers for every stage of the content workflow.</h1>
      <p class="page-intro">WordPresto brings in the right specialists for the stage you are at, so each piece of content gets the support it actually needs. Content Workers shape the writing. SEO Workers help that writing be understood, structured, retrieved and approved, without taking the decision away from you.</p>

      <div class="worker-directory-header">
        <span>CONTENT WORKERS</span>
        <span>{workers.length} SPECIALIST ROLES · WRITING, REVIEW &amp; HANDOFF</span>
      </div>
      <div class="workers-grid">
        {workers.map((w) => (
          <a href={`/workers/${w.id.replace(/_/g, '-')}/`} class="worker-card">
            <div class="worker-card-top">
              <img
                src={w.image}
                srcset={`${w.image} 1x, ${w.image2x} 2x`}
                alt={`${w.name} · ${w.role}`}
                class="worker-card-img"
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              />
              <div class="worker-card-info">
                <div class="worker-card-name">{w.name}</div>
                <div class="worker-card-role">{w.role}</div>
              </div>
            </div>
            <div class="worker-card-tags">
              <span class="worker-tag">
                <span class="worker-tag-dot" style={`background: ${w.teamColor}`}></span>
                {w.department}
              </span>
              <span class="worker-tag">Stage · {w.stage}</span>
            </div>
            <p class="worker-card-summary">{w.summary}</p>
            <div class="worker-card-footer">
              <div class="worker-output">
                <span class="worker-output-label">OUTPUT</span>
                <span class="worker-output-value">{w.output}</span>
              </div>
              <span class="worker-view-link">
                View profile
                <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="seo-team-intro">
        <div class="eyebrow eyebrow--seo">Search &amp; SEO</div>
        <h2 class="seo-team-h2">SEO Workers, working inside the writing, not after it.</h2>
        <p class="seo-team-body">These Workers review metadata, schema, search snippets, technical signals, evidence and authority. They surface what matters for search and readers while the writer is still shaping the work, and every suggestion goes through human review before anything moves forward.</p>
      </div>
      <div class="worker-directory-header">
        <span>SEO WORKERS</span>
        <span>{seoWorkers.length} SPECIALIST ROLES · SEARCH, EVIDENCE &amp; AUTHORITY</span>
      </div>
      <div class="workers-grid">
        {seoWorkers.map((w) => (
          <a href={`/workers/${w.id.replace(/_/g, '-')}/`} class="worker-card">
            <div class="worker-card-top">
              <img
                src={w.image}
                srcset={`${w.image} 1x, ${w.image2x} 2x`}
                alt={`${w.name} · ${w.role}`}
                class="worker-card-img"
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              />
              <div class="worker-card-info">
                <div class="worker-card-name">{w.name}</div>
                <div class="worker-card-role">{w.role}</div>
              </div>
            </div>
            <div class="worker-card-tags">
              <span class="worker-tag">
                <span class="worker-tag-dot" style={`background: ${w.teamColor}`}></span>
                {w.department}
              </span>
              <span class="worker-tag">Stage · {w.stage}</span>
            </div>
            <p class="worker-card-summary">{w.summary}</p>
            <div class="worker-card-footer">
              <div class="worker-output">
                <span class="worker-output-label">OUTPUT</span>
                <span class="worker-output-value">{w.output}</span>
              </div>
              <span class="worker-view-link">
                View profile
                <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/brand/main-logo.png" alt="Word Presto" class="footer-logo" loading="lazy" />
        <p class="footer-tagline">The content engine behind better publishing workflows.</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Product</span>
        <a href="/#product" class="footer-link">How it works</a>
        <a href="/#capabilities" class="footer-link">Workflow</a>
        <a href="/workers/" class="footer-link">Workers</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Use cases</span>
        <a href="/#use-cases" class="footer-link">Astro + CMS builds</a>
        <a href="/#use-cases" class="footer-link">CMS-connected</a>
        <a href="/#use-cases" class="footer-link">Standalone engine</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Company</span>
        <a href="/waitlist" class="footer-link">Join the waitlist</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 WordPresto</span>
      <span>Review-led publishing · Human approval</span>
      <a href="/sitemap/" class="footer-link footer-sitemap-link">Sitemap</a>
    </div>
  </footer>

</BaseLayout>

<style>
  /* ===== MASTHEAD ===== */
  .masthead {
    position: sticky;
    top: 0;
    z-index: 60;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
    border-bottom: 2px solid var(--wp-ink);
    transform: translateZ(0);
  }
  .masthead-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 34px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 28px;
  }
  .masthead-logo img { display: block; height: 48px; width: auto; mix-blend-mode: multiply; }
  .masthead-nav { display: flex; align-items: center; gap: 24px; }
  .masthead-nav--left { justify-content: flex-start; }
  .masthead-nav--right { justify-content: flex-end; }
  .nav-link { font-size: var(--wp-text-md); font-weight: 500; color: var(--wp-text-secondary); }
  .nav-link:hover { color: var(--wp-ink); }
  .nav-link--active { color: var(--wp-ink); font-weight: 600; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--wp-text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    border-radius: 5px;
    text-decoration: none;
  }
  .btn--primary {
    padding: 14px 24px;
    background: var(--wp-ink);
    color: #FAF7F0;
    border: 1px solid var(--wp-ink);
    box-shadow: 0 2px 4px rgba(54,44,24,0.12), 0 10px 18px -8px rgba(54,44,24,0.22);
  }
  .btn--sm { padding: 8px 16px; font-size: var(--wp-text-sm); }

  /* ===== LAYOUT ===== */
  .section {
    padding: 92px 0;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
  }
  .section--hero { padding: 56px 0 80px; }
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
  }
  .eyebrow {
    font-size: var(--wp-text-sm);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .eyebrow--strategy { color: var(--team-strategy); }
  .eyebrow--seo { color: var(--team-seo); }
  .page-h1 {
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.04;
    color: var(--wp-ink);
    margin: 0 0 20px;
    max-width: 720px;
  }
  .page-intro {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.5;
    margin: 0 0 36px;
    max-width: 600px;
  }

  /* ===== WORKER DIRECTORY ===== */
  .worker-directory-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--wp-border-strong);
    border-bottom: 1px solid var(--wp-border-strong);
    padding: 10px 2px;
    margin-bottom: 24px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.08em;
    color: var(--wp-text-tertiary);
  }
  .workers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }
  .seo-team-intro {
    max-width: 640px;
    margin: 64px 0 28px;
  }
  .seo-team-h2 {
    font-size: clamp(1.7rem, 3.4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--wp-ink);
    margin: 0 0 14px;
  }
  .seo-team-body {
    font-size: var(--wp-text-lg);
    color: var(--wp-text-secondary);
    line-height: 1.55;
    margin: 0;
  }
  .worker-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(54,44,24,0.05), 0 12px 24px -16px rgba(54,44,24,0.14);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color 200ms, box-shadow 200ms;
  }
  .worker-card:hover {
    border-color: var(--wp-border-strong);
    box-shadow: 0 3px 7px rgba(17,19,24,0.1), 0 20px 36px -16px rgba(17,19,24,0.24);
  }
  .worker-card-top {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 16px 12px;
  }
  .worker-card-img {
    width: 64px; height: 64px;
    border-radius: 4px;
    object-fit: cover;
    box-shadow: 0 0 0 1px var(--wp-border-secondary);
    flex-shrink: 0;
  }
  .worker-card-name { font-size: var(--wp-text-xl); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
  .worker-card-role { font-size: var(--wp-text-sm); color: var(--wp-text-tertiary); margin-top: 3px; }
  .worker-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 16px 6px;
  }
  .worker-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border: 1px solid var(--wp-line);
    border-radius: var(--wp-radius-pill);
    font-size: 10px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-tertiary);
    letter-spacing: 0.04em;
  }
  .worker-tag-dot { width: 6px; height: 6px; border-radius: 50%; }
  .worker-card-summary {
    margin: 0;
    padding: 8px 16px 16px;
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.5;
  }
  .worker-card-footer {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 11px 16px;
    border-top: 1px dashed var(--wp-line);
  }
  .worker-output { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .worker-output-label {
    font-size: 10px;
    font-family: var(--wp-font-mono);
    letter-spacing: 0.08em;
    color: var(--wp-text-muted);
  }
  .worker-output-value {
    font-size: var(--wp-text-xs);
    font-family: var(--wp-font-mono);
    color: var(--wp-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .worker-view-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--wp-text-xs);
    font-weight: 600;
    color: var(--wp-ink);
    white-space: nowrap;
    flex: 0 0 auto;
  }

  /* ===== FOOTER ===== */
  .footer {
    background-color: var(--wp-paper-dark);
    background-image: var(--wp-texture-paper);
    border-top: 2px solid var(--wp-ink);
    padding: 58px 0 42px;
  }
  .footer-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 32px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; max-width: 300px; }
  .footer-logo { display: block; height: 90px; width: auto; align-self: flex-start; mix-blend-mode: multiply; }
  .footer-tagline { margin: 6px 0 0; font-size: var(--wp-text-base); color: var(--wp-text-tertiary); line-height: 1.5; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col-heading { font-size: var(--wp-text-sm); font-weight: 700; }
  .footer-link { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); }
  .footer-link:hover { color: var(--wp-ink); }
  .footer-bottom {
    width: 100%;
    max-width: 1200px;
    margin: 46px auto 0;
    padding: 22px 34px 0;
    border-top: 1px solid var(--wp-border-strong);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: space-between;
    font-size: var(--wp-text-sm);
    color: var(--wp-text-muted);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 940px) {
    .masthead-nav { display: none; }
    .masthead-inner { grid-template-columns: 1fr; justify-items: center; padding: 10px 20px; }
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .container { padding: 0 20px; }
    .workers-grid { grid-template-columns: 1fr; }
    .worker-directory-header { flex-direction: column; align-items: flex-start; gap: 2px; }
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>
