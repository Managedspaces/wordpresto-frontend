---
import HomePage from '@/components/HomePage.astro';
import { LOCALES, DEFAULT_LOCALE } from '@/i18n/locales';

export function getStaticPaths() {
  // English lives unprefixed at src/pages/index.astro; every other locale
  // gets its own "/{locale}/" route here, rendering the same shared
  // HomePage component parameterised by locale (see context.md).
  return LOCALES.filter((l) => l.code !== DEFAULT_LOCALE).map((l) => ({
    params: { locale: l.path },
    props: { locale: l.code },
  }));
}

const { locale } = Astro.props;
---

<HomePage locale={locale} />
