---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { prestobot } from '@/data/staticPages';

const { seoTitle, metaDescription, h1, intro } = prestobot;

const userAgent =
  'Mozilla/5.0 (compatible; WordPrestoBot/1.0; +https://wordpresto.com/prestobot)';

const does = [
  'request publicly accessible pages over normal HTTPS,',
  'identify itself honestly in the User-Agent on every request,',
  'respect robots.txt,',
  'crawl gently, with modest request rates, timeouts and response-size limits.',
];

const doesNot = [
  'log in, submit forms, or interact with your site,',
  'make any changes, post content, or place orders,',
  'attempt to access private, gated, or admin areas,',
  'collect personal data or bypass access controls.',
];

const robotsExamples = [
  {
    label: 'Block it entirely',
    code: `User-agent: WordPrestoBot\nDisallow: /`,
  },
  {
    label: 'Block only specific areas',
    code: `User-agent: WordPrestoBot\nDisallow: /private/\nDisallow: /checkout/`,
  },
  {
    label: 'Or set a crawl delay',
    code: `User-agent: WordPrestoBot\nCrawl-delay: 10`,
  },
];
---

<BaseLayout
  pageTitle={h1}
  seoTitle={seoTitle}
  description={metaDescription}
  canonical="https://wordpresto.com/prestobot/"
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href="/waitlist" class="nav-link">Sign in</a>
        <a href="/#product" class="nav-link">Product</a>
        <a href="/#capabilities" class="nav-link">Workflow</a>
      </nav>
      <a href="/" class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href="/#use-cases" class="nav-link">Use cases</a>
        <a href="/workers/" class="nav-link">Workers</a>
        <a href="/waitlist" class="btn btn--primary btn--sm">Join the waitlist</a>
      </nav>
    </div>
  </header>

  <!-- ===================== 1. HERO ===================== -->
  <section class="section section--hero wp-overflow-hidden">
    <div class="container">
      <nav class="wp-breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="wp-breadcrumb-back">&#8592;</a>
        <a href="/" class="wp-breadcrumb-link">WORD PRESTO</a>
        <span class="wp-breadcrumb-sep">/</span>
        <span class="wp-breadcrumb-current">PRESTOBOT</span>
      </nav>

      <div class="hero-grid">
        <!-- LEFT -->
        <div class="hero-copy">
          <div class="eyebrow eyebrow--strategy">Web crawler</div>
          <div class="hero-pills">
            <span class="hero-pill hero-pill--team">
              <span class="hero-pill-dot" style="background: var(--team-strategy)"></span>
              Token · WordPrestoBot
            </span>
            <span class="hero-pill">Respects robots.txt</span>
            <span class="hero-pill">Read-only</span>
          </div>
          <h1 class="hero-h1">{h1}</h1>
          <p class="hero-body">{intro}</p>
          <div class="hero-ctas">
            <a href="#control" class="btn btn--primary btn--lg">
              How to control it
              <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#recognise" class="btn btn--secondary btn--lg btn--tilt">How to recognise it</a>
          </div>
        </div>

        <!-- RIGHT: log-line slip -->
        <div class="hero-art" aria-hidden="true">
          <div class="log-sheet">
            <span class="folder-tab folder-tab--guidance">ACCESS LOG</span>
            <div class="log-header">
              <span class="log-title">What you saw</span>
              <span class="mono-label">user-agent</span>
            </div>
            <div class="log-body">
              <span class="ruled-margin-vert"></span>
              <code class="log-line">{userAgent}</code>
            </div>
            <div class="log-footer">
              <span class="mono-label">links back to</span>
              <span class="log-stamp">/prestobot</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 2. WHY IT VISITED ===================== -->
  <section class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">Why it visited your site</div>
        <h2 class="section-h2">It only fetches pages on behalf of a Word Presto user.</h2>
        <p class="section-body">In almost every case that is one of two things.</p>
      </div>

      <div class="reason-grid">
        <div class="reason-card reason-card--rot-neg">
          <span class="fold-corner fold-corner--sm"></span>
          <span class="fold-corner-line fold-corner-line--sm"></span>
          <div class="reason-num">01</div>
          <h3 class="reason-h3">A site owner analysing their own site</h3>
          <p class="reason-body">Running an SEO or content review of pages they control.</p>
        </div>
        <div class="reason-card reason-card--rot-pos">
          <span class="fold-corner fold-corner--sm"></span>
          <span class="fold-corner-line fold-corner-line--sm"></span>
          <div class="reason-num">02</div>
          <h3 class="reason-h3">A read-only competitive or research check</h3>
          <p class="reason-body">A user looking at publicly available pages to understand how a topic is covered.</p>
        </div>
      </div>

      <p class="reason-note">
        It reads <strong>public HTML</strong> to extract SEO and content signals: titles, headings, metadata, links and structured data. That is it.
      </p>
    </div>
  </section>

  <!-- ===================== 3. DOES / DOES NOT ===================== -->
  <section class="section section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">Behaviour</div>
        <h2 class="section-h2">What it does, and what it does not do.</h2>
      </div>

      <div class="io-grid">
        <div class="io-panel">
          <span class="folder-tab">WORDPRESTOBOT DOES</span>
          <div class="io-card">
            <span class="fold-corner fold-corner--md"></span>
            <span class="fold-corner-line fold-corner-line--md"></span>
            <div class="io-list">
              {does.map((item) => (
                <div class="io-row io-row--does">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--wp-signal)" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" class="io-icon"><path d="m5 12 5 5L20 7"/></svg>
                  <span class="io-text">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="io-panel">
          <span class="folder-tab folder-tab--neg">WORDPRESTOBOT DOES NOT</span>
          <div class="io-card">
            <span class="fold-corner fold-corner--md"></span>
            <span class="fold-corner-line fold-corner-line--md"></span>
            <div class="io-list">
              {doesNot.map((item) => (
                <div class="io-row io-row--does-not">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--wp-red)" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" class="io-icon"><path d="M6 6l12 12M18 6 6 18"/></svg>
                  <span class="io-text">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 4. HOW TO CONTROL IT ===================== -->
  <section id="control" class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">How to control it</div>
        <h2 class="section-h2">One robots.txt rule controls every crawl.</h2>
        <p class="section-body">All of our crawlers share the single token <strong>WordPrestoBot</strong>, so one rule is enough.</p>
      </div>

      <div class="code-grid">
        {robotsExamples.map((ex) => (
          <div class="code-sheet">
            <div class="code-sheet-header">
              <span class="code-sheet-label">{ex.label}</span>
              <span class="mono-label">robots.txt</span>
            </div>
            <pre class="code-block"><code>{ex.code}</code></pre>
          </div>
        ))}
      </div>

      <p class="reason-note">
        Changes take effect on our next visit. We honour <code class="inline-code">robots.txt</code>, so a disallow is respected without any need to contact us.
      </p>
    </div>
  </section>

  <!-- ===================== 5. HOW TO RECOGNISE IT ===================== -->
  <section id="recognise" class="section section--border-top">
    <div class="container">
      <div class="recognise-grid">
        <div>
          <div class="eyebrow eyebrow--strategy">How to recognise it</div>
          <h2 class="section-h2">Honest on every request.</h2>
          <ul class="recognise-list" role="list">
            <li class="recognise-item">
              <span class="recognise-key">User-Agent token</span>
              <span class="recognise-val"><code class="inline-code">WordPrestoBot</code></span>
            </li>
            <li class="recognise-item">
              <span class="recognise-key">Every request links back here</span>
              <span class="recognise-val"><code class="inline-code">+https://wordpresto.com/prestobot</code></span>
            </li>
            <li class="recognise-item">
              <span class="recognise-key">Some fetches add a short note</span>
              <span class="recognise-val">describing the specific action, for example <code class="inline-code">read-only single page</code> or <code class="inline-code">sitemap and llms.txt only</code>. Same token, same rules.</span>
            </li>
          </ul>
        </div>

        <div class="spoof-note">
          <span class="fold-corner fold-corner--md"></span>
          <span class="fold-corner-line fold-corner-line--md"></span>
          <div class="mono-label spoof-label">SPOOFING</div>
          <p class="spoof-body">If a request claims to be WordPrestoBot but does not link to this page, treat it as spoofed and feel free to block it.</p>
          <span class="hand-note hand-note--amber spoof-hand">not us &#8594;</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 6. QUESTIONS ===================== -->
  <section class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">Questions or concerns?</div>
        <h2 class="section-h2">If it is causing problems, the fastest fix is the robots.txt rule above.</h2>
        <p class="section-body">
          You can also reach us at <a class="text-link" href="mailto:hello@wordpresto.com">hello@wordpresto.com</a>. Tell us the domain and we will help. If you would like WordPrestoBot to stop visiting, a disallow rule stops it on our next visit.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== 7. CTA ===================== -->
  <section class="section section--border-top cta-section">
    <div class="cta-inner">
      <img src="/brand/main-logo.png" alt="Word Presto" class="cta-logo" loading="lazy" />
      <div class="eyebrow eyebrow--strategy">Curious what it was looking at?</div>
      <h2 class="cta-h2">The same content review it runs for our users, it can run for your site.</h2>
      <p class="cta-body">Word Presto helps writers, editors and publishing teams plan, brief, write, review and prepare content for search, readers and CMS handoff.</p>
      <div class="cta-actions">
        <a href="/waitlist" class="btn btn--primary btn--lg">
          Join the waitlist
          <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/" class="btn btn--secondary btn--lg btn--tilt">Back to Word Presto</a>
      </div>
      <div class="cta-rule">
        <span class="cta-rule-line"></span>
        <span class="mono-label cta-rule-text">PAPER · INK · SIGNAL · CONTROL</span>
        <span class="cta-rule-line"></span>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/brand/main-logo.png" alt="Word Presto" class="footer-logo" loading="lazy" />
        <p class="footer-tagline">The content engine behind better publishing workflows.</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Product</span>
        <a href="/#product" class="footer-link">How it works</a>
        <a href="/#capabilities" class="footer-link">Workflow</a>
        <a href="/workers/" class="footer-link">Workers</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Use cases</span>
        <a href="/#use-cases" class="footer-link">Astro + CMS builds</a>
        <a href="/#use-cases" class="footer-link">CMS-connected</a>
        <a href="/#use-cases" class="footer-link">Standalone engine</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Crawler</span>
        <a href="/prestobot/" class="footer-link">WordPrestoBot</a>
        <a href="/sitemap/" class="footer-link">Site map</a>
        <a href="mailto:hello@wordpresto.com" class="footer-link">Contact</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 WordPresto</span>
      <span>Review-led publishing · Human approval</span>
      <a href="/sitemap/" class="footer-link footer-sitemap-link">Sitemap</a>
    </div>
  </footer>

</BaseLayout>

<style>
  /* ===== MASTHEAD ===== */
  .masthead {
    position: sticky;
    top: 0;
    z-index: 60;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
    border-bottom: 2px solid var(--wp-ink);
    transform: translateZ(0);
  }
  .masthead-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 34px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 28px;
  }
  .masthead-logo img { display: block; height: 48px; width: auto; mix-blend-mode: multiply; }
  .masthead-nav { display: flex; align-items: center; gap: 24px; }
  .masthead-nav--left { justify-content: flex-start; }
  .masthead-nav--right { justify-content: flex-end; }
  .nav-link { font-size: var(--wp-text-md); font-weight: 500; color: var(--wp-text-secondary); }
  .nav-link:hover { color: var(--wp-ink); }

  /* ===== SHARED ===== */
  .section {
    padding: 92px 0;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
  }
  .section--hero { padding: 30px 0 84px; }
  .section--paper-dark { background-color: var(--wp-paper-dark); }
  .section--border-top { border-top: 2px solid var(--wp-ink); }
  .wp-overflow-hidden { overflow: hidden; }
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
  }

  .eyebrow {
    font-size: var(--wp-text-sm);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .eyebrow--strategy { color: var(--team-strategy); }

  .section-h2 {
    font-size: clamp(2.1rem, 4.4vw, 3.15rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    margin: 0;
    color: var(--wp-ink);
  }
  .section-body {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.5;
    margin: 22px 0 0;
  }
  .section-intro { max-width: 640px; margin-bottom: 44px; }
  .section-intro--wide { max-width: 720px; margin-bottom: 40px; }

  .text-link { color: var(--wp-ink); text-decoration: underline; text-underline-offset: 3px; }
  .text-link:hover { color: var(--wp-signal); }

  .inline-code {
    font-family: var(--wp-font-mono);
    font-size: 0.92em;
    background: var(--wp-paper-dark);
    border: 1px solid var(--wp-line);
    border-radius: 3px;
    padding: 1px 6px;
    color: var(--wp-ink);
    word-break: break-word;
  }

  /* Breadcrumb */
  .wp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.06em;
    color: var(--wp-text-muted);
    margin-bottom: 30px;
    flex-wrap: wrap;
  }
  .wp-breadcrumb-back { color: var(--wp-text-muted); }
  .wp-breadcrumb-link { color: var(--wp-text-tertiary); }
  .wp-breadcrumb-sep { color: var(--wp-border-strong); }
  .wp-breadcrumb-current { color: var(--wp-text-secondary); }

  /* ===== HERO ===== */
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(0, 0.96fr);
    gap: 52px;
    align-items: center;
  }
  .hero-copy { min-width: 0; }
  .hero-h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.032em;
    margin: 0;
    color: var(--wp-ink);
  }
  .hero-body {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.55;
    margin: 26px 0 0;
    max-width: 520px;
  }
  .hero-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; }
  .hero-pill {
    display: inline-flex;
    align-items: center;
    padding: 4px 11px;
    border: 1px solid var(--wp-line);
    border-radius: var(--wp-radius-pill);
    font-size: 11px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-tertiary);
    letter-spacing: 0.04em;
  }
  .hero-pill--team { padding-left: 9px; gap: 7px; }
  .hero-pill-dot { width: 7px; height: 7px; border-radius: 50%; flex: 0 0 auto; }
  .hero-ctas { display: flex; gap: 12px; margin-top: 32px; flex-wrap: wrap; }

  /* Hero art / log sheet */
  .hero-art { position: relative; min-width: 0; padding-top: 14px; }
  .log-sheet {
    position: relative;
    margin-left: 16px;
    background: #FFFFFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 2px 5px rgba(54,44,24,0.06), 0 26px 50px -18px rgba(54,44,24,0.22);
    transform: rotate(1.2deg);
  }
  .log-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 22px;
    border-bottom: 2px solid var(--wp-ink);
  }
  .log-title { font-size: var(--wp-text-lg); font-weight: 700; letter-spacing: -0.02em; }
  .log-body { position: relative; padding: 22px 22px 22px 38px; }
  .ruled-margin-vert {
    position: absolute;
    left: 26px; top: 0; bottom: 0;
    width: 1px;
    background: rgba(194,65,58,0.4);
  }
  .log-line {
    display: block;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-sm);
    line-height: 1.7;
    color: var(--wp-ink);
    word-break: break-all;
  }
  .log-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 15px 22px;
    border-top: 1px solid var(--wp-line);
    background: #FAF7F0;
  }
  .log-stamp {
    border: 2px solid var(--wp-signal);
    color: var(--wp-signal);
    border-radius: 4px;
    font-family: var(--wp-font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    opacity: 0.86;
    transform: rotate(-3deg);
    display: inline-block;
  }

  /* Folder tabs + folds */
  .folder-tab {
    position: absolute;
    top: -19px;
    left: 22px;
    padding: 7px 20px;
    background: #E3D6B9;
    border: 1px solid #C7B488;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    z-index: 4;
    font-size: var(--wp-text-xs);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.1em;
    color: #5E4F2E;
    white-space: nowrap;
  }
  .folder-tab--guidance { top: -17px; padding: 5px 16px; border-radius: 6px 6px 0 0; }
  .folder-tab--neg { background: #E8D2CC; border-color: #D2A79E; color: #7A3B32; }

  .fold-corner, .fold-corner-line { position: absolute; top: 0; right: 0; pointer-events: none; }
  .fold-corner--sm { width: 0; height: 0; border-top: 18px solid var(--wp-paper-dark); border-left: 18px solid transparent; z-index: 4; }
  .fold-corner-line--sm { width: 18px; height: 18px; border-left: 1px solid var(--wp-line); border-bottom: 1px solid var(--wp-line); z-index: 3; }
  .fold-corner--md { width: 0; height: 0; border-top: 22px solid var(--wp-paper-dark); border-left: 22px solid transparent; z-index: 4; }
  .fold-corner-line--md { width: 22px; height: 22px; border-left: 1px solid var(--wp-line); border-bottom: 1px solid var(--wp-line); z-index: 3; }

  .mono-label {
    font-family: var(--wp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--wp-text-muted);
  }

  /* ===== WHY IT VISITED ===== */
  .reason-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 26px;
  }
  .reason-card {
    position: relative;
    background: #FFFFFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(54,44,24,0.05), 0 12px 24px -14px rgba(54,44,24,0.15);
    padding: 26px 26px 28px;
    overflow: hidden;
  }
  .reason-card--rot-neg { transform: rotate(-0.8deg); }
  .reason-card--rot-pos { transform: rotate(0.7deg); }
  .reason-num { font-family: var(--wp-font-mono); font-size: 11px; color: var(--wp-text-muted); margin-bottom: 12px; }
  .reason-h3 { font-size: var(--wp-text-xl); font-weight: 700; letter-spacing: -0.01em; margin: 0 0 10px; line-height: 1.2; }
  .reason-body { font-size: var(--wp-text-md); color: var(--wp-text-secondary); line-height: 1.55; margin: 0; }
  .reason-note {
    font-size: var(--wp-text-lg);
    color: var(--wp-text-secondary);
    line-height: 1.6;
    margin: 34px 0 0;
    max-width: 760px;
  }
  .reason-note code, .reason-note strong { color: var(--wp-ink); }

  /* ===== DOES / DOES NOT ===== */
  .io-grid {
