---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Masthead from '@/components/Masthead.astro';
import { pricingContent } from '@/data/i18n/pricing';
import { commonStrings } from '@/data/i18n/common';
import { localeHref, type Locale } from '@/i18n/locales';
import { registerUrl } from '@/lib/appLinks';
import { absoluteUrl, breadcrumbList } from '@/lib/schema';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = pricingContent[locale] ?? pricingContent.en;
const c = commonStrings[locale];

const canonical = locale === 'en'
  ? 'https://wordpresto.com/pricing/'
  : `https://wordpresto.com${localeHref(locale, '/pricing/')}`;

const joinHref = registerUrl(locale);

// Everything the client-side script needs: the API base, the join link
// and the locale strings. Serialised into #pricing-config server-side so the
// script never duplicates copy (same pattern as WaitlistPage's #wl-i18n).
// Plan prices and credits are NOT here: they come from the live API.
const clientConfig = {
  apiBase: import.meta.env.PUBLIC_APP_API_BASE || 'https://app.wordpresto.com',
  joinHref,
  usageItems: t.exampleCosts
    .filter((item) => item.onCard)
    .sort((a, b) => (a.cardOrder ?? 99) - (b.cardOrder ?? 99))
    .map(({ credits, singular, plural }) => ({ credits, singular, plural })),
  strings: {
    billingMonthly: t.billingMonthly,
    billingAnnual: t.billingAnnual,
    perMonth: t.perMonth,
    perYear: t.perYear,
    billedMonthly: t.billedMonthly,
    monthlyOnlyNote: t.monthlyOnlyNote,
    oneTimeLabel: t.oneTimeLabel,
    annualEquivalentTemplate: t.annualEquivalentTemplate,
    annualSavingTemplate: t.annualSavingTemplate,
    creditsTemplate: t.creditsTemplate,
    usageHeading: t.usageHeading,
    usageOrPrefix: t.usageOrPrefix,
    topUpsAvailable: t.topUpsAvailable,
    planCta: t.planCta,
    packCreditsSuffix: t.packCreditsSuffix,
    packKindLabel: t.packKindLabel,
  },
};

const jsonLd = [
  breadcrumbList([
    { name: c.home, url: absoluteUrl(locale, '/') },
    { name: t.breadcrumbCurrent, url: canonical },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: t.h1,
    description: t.metaDescription,
    url: canonical,
  },
];
---

<BaseLayout
  pageTitle={t.h1}
  seoTitle={t.seoTitle}
  description={t.metaDescription}
  canonical={canonical}
  jsonLd={jsonLd}
>

  <!-- ===================== MASTHEAD ===================== -->
  <Masthead locale={locale} />

  <!-- ===================== 1. HERO ===================== -->
  <section class="section section--hero">
    <div class="container">
      <nav class="wp-breadcrumb" aria-label="Breadcrumb">
        <a href={localeHref(locale, '/')} class="wp-breadcrumb-back">&#8592;</a>
        <a href={localeHref(locale, '/')} class="wp-breadcrumb-link">{t.breadcrumbHome}</a>
        <span class="wp-breadcrumb-sep">/</span>
        <span class="wp-breadcrumb-current">{t.breadcrumbCurrent}</span>
      </nav>

      <div class="pricing-hero">
        <div class="eyebrow eyebrow--pricing">{t.eyebrow}</div>
        <h1 class="hero-h1">{t.h1}</h1>
        <p class="hero-body">{t.intro}</p>
      </div>
    </div>
  </section>

  <!-- ===================== 2. PLANS ===================== -->
  <section class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--pricing">{t.plansEyebrow}</div>
        <h2 class="section-h2">{t.plansH2}</h2>
        <p class="section-body">{t.plansBody}</p>
      </div>

      <div class="billing-toggle-wrap" id="billing-toggle-wrap" hidden>
        <div class="billing-toggle" role="group" aria-label="Billing period">
          <button type="button" class="billing-toggle-btn is-active" data-billing="monthly" aria-pressed="true">{t.billingMonthly}</button>
          <button type="button" class="billing-toggle-btn" data-billing="annual" aria-pressed="false">{t.billingAnnual}</button>
        </div>
      </div>

      <div class="plans-grid" id="plans-grid" aria-busy="true" aria-live="polite">
        <span class="sr-only">{t.loadingLabel}</span>
        {[0, 1, 2, 3].map(() => (
          <div class="plan-card plan-card--skeleton" aria-hidden="true">
            <span class="skel skel--sm"></span>
            <span class="skel skel--lg"></span>
            <span class="skel skel--md"></span>
            <span class="skel skel--row"></span>
            <span class="skel skel--row"></span>
            <span class="skel skel--row"></span>
            <span class="skel skel--btn"></span>
          </div>
        ))}
      </div>

      <div class="pricing-fallback" id="pricing-fallback" hidden>
        <span class="fold-corner fold-corner--md"></span>
        <span class="fold-corner-line fold-corner-line--md"></span>
        <div class="mono-label pricing-fallback-label">{t.fallbackHeading}</div>
        <p class="pricing-fallback-body">{t.fallbackBody}</p>
        <a href={joinHref} class="btn btn--primary btn--lg pricing-fallback-cta">
          {t.fallbackCta}
          <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <noscript>
        <p class="pricing-noscript">
          {t.noscriptBody}
          <a href={joinHref} class="text-link">{t.fallbackCta}</a>
        </p>
      </noscript>

      <div class="pricing-footnotes">
        <p class="pricing-footnote">{t.footnoteUsage}</p>
        <p class="pricing-footnote">{t.footnoteVat}</p>
      </div>
    </div>
  </section>

  <!-- ===================== 3. TOP-UP PACKS ===================== -->
  <section class="section section--border-top" id="packs-section" hidden>
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--pricing">{t.packsEyebrow}</div>
        <h2 class="section-h2">{t.packsH2}</h2>
        <p class="section-body">{t.packsBody}</p>
      </div>

      <div class="packs-grid" id="packs-grid"></div>
    </div>
  </section>

  <!-- ===================== 4. RATE CARD ===================== -->
  <section class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="rate-grid">
        <div class="rate-intro">
          <div class="eyebrow eyebrow--pricing">{t.rateEyebrow}</div>
          <h2 class="section-h2">{t.rateH2}</h2>
          <p class="section-body">{t.rateBody}</p>
          <span class="hand-note rate-hand">{t.rateHandNote}</span>
        </div>

        <div class="rate-sheet-wrap">
          <div class="rate-sheet">
            <span class="folder-tab">{t.rateTab}</span>
            <span class="fold-corner fold-corner--md"></span>
            <span class="fold-corner-line fold-corner-line--md"></span>
            <ul class="rate-list" role="list">
              {t.exampleCosts.map((item) => (
                <li class="rate-row">
                  <span class="rate-label">{item.label}</span>
                  <span class="rate-dots" aria-hidden="true"></span>
                  <span class="rate-cost">
                    {item.credits.toLocaleString('en-GB')} {t.rateCreditsSuffix}
                    {item.note && <span class="rate-note">({item.note})</span>}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 5. CTA ===================== -->
  <section class="section section--border-top cta-section">
    <div class="cta-inner">
      <img src="/brand/main-logo.png" alt="Word Presto" class="cta-logo" loading="lazy" />
      <div class="eyebrow eyebrow--pricing">{t.ctaEyebrow}</div>
      <h2 class="cta-h2">{t.ctaH2}</h2>
      <p class="cta-body">{t.ctaBody}</p>
      <div class="cta-actions">
        <a href={joinHref} class="btn btn--primary btn--lg">
          {t.ctaButton}
          <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="cta-rule">
        <span class="cta-rule-line"></span>
        <span class="mono-label cta-rule-text">{t.ctaRuleText}</span>
        <span class="cta-rule-line"></span>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/brand/main-logo.png" alt="Word Presto" class="footer-logo" loading="lazy" />
        <p class="footer-tagline">{c.footerTagline}</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{c.product}</span>
        <a href={`${localeHref(locale, '/')}#product`} class="footer-link">{c.howItWorks}</a>
        <a href={`${localeHref(locale, '/')}#capabilities`} class="footer-link">{c.workflow}</a>
        <a href={localeHref(locale, '/workers/')} class="footer-link">{c.workers}</a>
        <a href="/pricing/" class="footer-link">{c.pricing}</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{c.useCases}</span>
        <a href={`${localeHref(locale, '/')}#use-cases`} class="footer-link">{c.astroCms}</a>
        <a href={`${localeHref(locale, '/')}#use-cases`} class="footer-link">{c.cmsConnected}</a>
        <a href={`${localeHref(locale, '/')}#use-cases`} class="footer-link">{c.standaloneEngine}</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{c.contact}</span>
        <a href={joinHref} class="footer-link">{c.joinWaitlist}</a>
        <a href="/sitemap/" class="footer-link">{c.siteMap}</a>
        <a href="mailto:hello@wordpresto.com" class="footer-link">hello@wordpresto.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 WordPresto</span>
      <span>{c.reviewLed}</span>
      <a href="/sitemap/" class="footer-link footer-sitemap-link">{c.siteMap}</a>
      <span class="footer-legal-links">
        <a href="/privacy/" class="footer-link">Privacy</a> ·
        <a href="/terms/" class="footer-link">Terms</a> ·
        <a href="/cookies/" class="footer-link">Cookies</a> ·
        <a href="/fair-use/" class="footer-link">Fair use</a> ·
        <a href="/data-deletion/" class="footer-link">Data deletion</a>
      </span>
    </div>
  </footer>

  <script type="application/json" id="pricing-config" set:html={JSON.stringify(clientConfig)} />

</BaseLayout>

<script>
  // ===== Live pricing loader ==========================================
  // Plan prices, credits and top-up packs come from the app's public
  // pricing API at page load, so pricing changes in the app reflect here
  // without a site redeploy. Nothing on this page invents a number: if the
  // API is unreachable or returns an unusable shape, the page shows an
  // honest fallback and the join CTA (routed to the app signup) instead.

  interface UsageItem {
    credits: number;
    singular: string;
    plural: string;
  }

  interface PricingConfig {
    apiBase: string;
    joinHref: string;
    usageItems: UsageItem[];
    strings: Record<string, string>;
  }

  interface ApiPlan {
    tier?: string;
    label: string;
    monthlyCredits: number;
    monthlyPriceEur: number;
    annualPriceEur?: number | null;
    oneTimePriceEur?: number | null;
    oneTime?: boolean;
    allowsOverage?: boolean;
  }

  interface ApiPack {
    id?: string;
    label?: string;
    credits: number;
    priceEur: number;
  }

  const CONFIG = JSON.parse(
    document.getElementById('pricing-config')!.textContent!
  ) as PricingConfig;
  const S = CONFIG.strings;

  const plansGrid = document.getElementById('plans-grid')!;
  const packsGrid = document.getElementById('packs-grid')!;
  const packsSection = document.getElementById('packs-section')!;
  const toggleWrap = document.getElementById('billing-toggle-wrap')!;
  const fallbackEl = document.getElementById('pricing-fallback')!;

  let currency = 'EUR';
  let billing: 'monthly' | 'annual' = 'monthly';
  let livePlans: ApiPlan[] = [];

  // ----- helpers ------------------------------------------------------

  function isFiniteNumber(v: unknown): v is number {
    return typeof v === 'number' && Number.isFinite(v);
  }

  function fmtMoney(value: number): string {
    const wholeUnits = Math.round(value * 100) % 100 === 0;
    return new Intl.NumberFormat('en-GB', {
      style: 'currency',
      currency,
      minimumFractionDigits: wholeUnits ? 0 : 2,
      maximumFractionDigits: 2,
    }).format(value);
  }

  function fmtCredits(value: number): string {
    return value.toLocaleString('en-GB');
  }

  function fill(template: string, params: Record<string, string>): string {
    return template.replace(/\{(\w+)\}/g, (m, key) => params[key] ?? m);
  }

  function el(tag: string, className?: string, text?: string): HTMLElement {
    const node = document.createElement(tag);
    if (className) node.className = className;
    if (text !== undefined) node.textContent = text;
    return node;
  }

  // Forward compatible: keeps only the fields this page understands and
  // drops any plan the API did not describe fully enough to price honestly.
  function isUsablePlan(p: unknown): p is ApiPlan {
    if (!p || typeof p !== 'object') return false;
    const plan = p as Record<string, unknown>;
    if (typeof plan.label !== 'string' || !plan.label.trim()) return false;
    if (!isFiniteNumber(plan.monthlyCredits) || plan.monthlyCredits <= 0) return false;
    if (plan.oneTime === true) return isFiniteNumber(plan.oneTimePriceEur);
    return isFiniteNumber(plan.monthlyPriceEur);
  }

  function isUsablePack(p: unknown): p is ApiPack {
    if (!p || typeof p !== 'object') return false;
    const pack = p as Record<string, unknown>;
    return isFiniteNumber(pack.credits) && pack.credits > 0 && isFiniteNumber(pack.priceEur);
  }

  // ----- plan cards ----------------------------------------------------

  function foldCorner(card: HTMLElement): void {
    card.appendChild(el('span', 'fold-corner fold-corner--sm'));
    card.appendChild(el('span', 'fold-corner-line fold-corner-line--sm'));
  }

  function planPriceBlock(plan: ApiPlan): HTMLElement {
    const block = el('div', 'plan-price-block');
    const row = el('div', 'plan-price-row');
    const note = el('div', 'plan-price-note');

    if (plan.oneTime === true && isFiniteNumber(plan.oneTimePriceEur)) {
      row.appendChild(el('span', 'plan-price-figure', fmtMoney(plan.oneTimePriceEur)));
      row.appendChild(el('span', 'plan-price-per', S.oneTimeLabel));
    } else if (billing === 'annual' && isFiniteNumber(plan.annualPriceEur)) {
      const annual = plan.annualPriceEur as number;
      row.appendChild(el('span', 'plan-price-figure', fmtMoney(annual)));
      row.appendChild(el('span', 'plan-price-per', S.perYear));
      note.appendChild(
        el('span', 'plan-note-line', fill(S.annualEquivalentTemplate, { price: fmtMoney(annual / 12) }))
      );
      const saving = plan.monthlyPriceEur * 12 - annual;
      if (saving > 0) {
        note.appendChild(
          el('span', 'plan-note-line plan-note-line--saving', fill(S.annualSavingTemplate, { amount: fmtMoney(saving) }))
        );
      }
    } else {
      row.appendChild(el('span', 'plan-price-figure', fmtMoney(plan.monthlyPriceEur)));
      row.appendChild(el('span', 'plan-price-per', S.perMonth));
      note.appendChild(
        el('span', 'plan-note-line', billing === 'annual' ? S.monthlyOnlyNote : S.billedMonthly)
      );
    }

    block.appendChild(row);
    if (note.childNodes.length) block.appendChild(note);
    return block;
  }

  function planUsageList(plan: ApiPlan): HTMLElement | null {
    const rows: string[] = [];
    for (const item of CONFIG.usageItems) {
      const count = Math.floor(plan.monthlyCredits / item.credits);
      if (count < 1) continue;
      const unit = count === 1 ? item.singular : item.plural;
      const prefix = rows.length === 0 ? '' : `${S.usageOrPrefix} `;
      rows.push(`${prefix}${fmtCredits(count)} ${unit}`);
    }
    if (!rows.length) return null;

    const wrap = el('div', 'plan-usage');
    wrap.appendChild(el('span', 'mono-label plan-usage-heading', S.usageHeading));
    const list = el('ul', 'plan-usage-list');
    list.setAttribute('role', 'list');
    for (const row of rows) list.appendChild(el('li', 'plan-usage-row', row));
    wrap.appendChild(list);
    return wrap;
  }

  function planCard(plan: ApiPlan, index: number): HTMLElement {
    const card = el('article', `plan-card plan-card--tilt-${index % 2 === 0 ? 'neg' : 'pos'}`);
    foldCorner(card);

    const head = el('div', 'plan-head');
    head.appendChild(el('h3', 'plan-name', plan.label));
    head.appendChild(el('span', 'mono-label plan-index', `PLAN ${String(index + 1).padStart(2, '0')}`));
    card.appendChild(head);

    card.appendChild(planPriceBlock(plan));
    card.appendChild(el('div', 'plan-credits', fill(S.creditsTemplate, { credits: fmtCredits(plan.monthlyCredits) })));

    const usage = planUsageList(plan);
    if (usage) card.appendChild(usage);

    const foot = el('div', 'plan-foot');
    if (plan.allowsOverage === true) {
      foot.appendChild(el('span', 'mono-label plan-overage', S.topUpsAvailable));
    }
    const cta = el('a', 'btn btn--secondary plan-cta', S.planCta) as HTMLAnchorElement;
    cta.href = CONFIG.joinHref;
    foot.appendChild(cta);
    card.appendChild(foot);

    return card;
  }

  function renderPlans(): void {
    plansGrid.replaceChildren(...livePlans.map((plan, i) => planCard(plan, i)));
    plansGrid.setAttribute('aria-busy', 'false');
  }

  // ----- packs ----------------------------------------------------------

  function packSlip(pack: ApiPack): HTMLElement {
    const slip = el('div', 'pack-slip');
    slip.appendChild(el('span', 'fold-corner fold-corner--sm'));
    slip.appendChild(el('span', 'fold-corner-line fold-corner-line--sm'));
    const label = typeof pack.label === 'string' && pack.label.trim()
      ? pack.label
      : `${fmtCredits(pack.credits)} ${S.packCreditsSuffix}`;
    slip.appendChild(el('span', 'pack-credits', label));
    slip.appendChild(el('span', 'pack-price', fmtMoney(pack.priceEur)));
    slip.appendChild(el('span', 'mono-label pack-kind', S.packKindLabel));
    return slip;
  }

  function renderPacks(packs: ApiPack[]): void {
    if (!packs.length) return; // API sent no usable packs: keep the section hidden.
    packsGrid.replaceChildren(...packs.map(packSlip));
    packsSection.hidden = false;
  }

  // ----- billing toggle --------------------------------------------------

  function setupToggle(): void {
    const hasAnnual = livePlans.some((p) => p.oneTime !== true && isFiniteNumber(p.annualPriceEur));
    if (!hasAnnual) return; // no annual prices in the data: monthly only, no toggle.
    toggleWrap.hidden = false;
    const buttons = toggleWrap.querySelectorAll<HTMLButtonElement>('.billing-toggle-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = btn.dataset.billing === 'annual' ? 'annual' : 'monthly';
        if (next === billing) return;
        billing = next;
        buttons.forEach((b) => {
          const active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-pressed', String(active));
        });
        renderPlans();
      });
    });
  }

  // ----- load ------------------------------------------------------------

  function showFallback(): void {
    plansGrid.replaceChildren();
    plansGrid.setAttribute('aria-busy', 'false');
    plansGrid.hidden = true;
    toggleWrap.hidden = true;
    packsSection.hidden = true;
    fallbackEl.hidden = false;
  }

  async function loadPricing(): Promise<void> {
    const base = CONFIG.apiBase.replace(/\/$/, '');
    // Bound the request so a slow/unreachable backend flips to the graceful fallback instead of leaving
    // the skeleton tiles spinning forever. AbortController fires `abort` at the deadline → fetch rejects
    // → the outer .catch runs showFallback().
    const controller = new AbortController();
    const deadline = setTimeout(() => controller.abort(), 8000);
    let res: Response;
    try {
      res = await fetch(`${base}/api/public/pricing`, {
        headers: { accept: 'application/json' },
        signal: controller.signal,
      });
    } finally {
      clearTimeout(deadline);
    }
    if (!res.ok) throw new Error(`pricing_http_${res.status}`);
    const data: unknown = await res.json();
    const body = (data ?? {}) as Record<string, unknown>;

    if (typeof body.currency === 'string' && /^[A-Z]{3}$/.test(body.currency)) {
      currency = body.currency;
    }

    livePlans = Array.isArray(body.plans) ? body.plans.filter(isUsablePlan) : [];
    if (!livePlans.length) throw new Error('pricing_no_plans');

    renderPlans();
    setupToggle();
    renderPacks(Array.isArray(body.packs) ? body.packs.filter(isUsablePack) : []);
  }

  loadPricing().catch(() => showFallback());
</script>

<style>
  /* Masthead is now a shared component (src/components/Masthead.astro). */

  /* ===== SHARED ===== */
  .section {
    padding: 92px 0;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
  }
  .section--hero { padding: 30px 0 72px; }
  .section--paper-dark { background-color: var(--wp-paper-dark); }
  .section--border-top { border-top: 2px solid var(--wp-ink); }
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
  }

  .eyebrow {
    font-size: var(--wp-text-sm);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .eyebrow--pricing { color: var(--wp-signal); }

  .section-h2 {
    font-size: clamp(2.1rem, 4.4vw, 3.15rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    margin: 0;
    color: var(--wp-ink);
  }
  .section-body {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.5;
    margin: 22px 0 0;
  }
  .section-intro--wide { max-width: 720px; margin-bottom: 40px; }

  .text-link { color: var(--wp-ink); text-decoration: underline; text-underline-offset: 3px; }
  .text-link:hover { color: var(--wp-signal); }

  .mono-label {
    font-family: var(--wp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--wp-text-muted);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* Breadcrumb */
  .wp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.06em;
    color: var(--wp-text-muted);
    margin-bottom: 30px;
