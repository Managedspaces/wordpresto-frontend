  </footer>

</BaseLayout>

<style>
  /* ===== LAYOUT ===== */
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
  }

  .section {
    padding: 92px 0;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
  }
  .section--paper-dark { background-color: var(--wp-paper-dark); }
  .section--border-top { border-top: 2px solid var(--wp-ink); }
  .section--overflow-hidden { overflow: hidden; }

  /* ===== MASTHEAD ===== */
  .masthead {
    position: sticky;
    top: 0;
    z-index: 60;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
    overflow: visible;
    transform: translateZ(0);
  }
  .masthead::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      to right,
      var(--wp-ink) calc(50% - 90px),
      transparent calc(50% - 90px),
      transparent calc(50% + 90px),
      var(--wp-ink) calc(50% + 90px)
    );
  }
  .masthead-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 34px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .masthead-nav {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .masthead-nav--left { justify-content: flex-start; }
  .masthead-nav--right { justify-content: flex-end; }
  .masthead-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0;
    z-index: 61;
  }
  .masthead-logo img { display: block; height: 110px; width: auto; mix-blend-mode: multiply; }

  .nav-link {
    font-size: var(--wp-text-md);
    font-weight: 500;
    color: var(--wp-text-secondary);
    transition: color 150ms;
  }
  .nav-link:hover { color: var(--wp-ink); }

  /* Single current-locale flag inline; the other five reveal in a small
     hover/focus dropdown, so the masthead's width never depends on how long
     a given locale's nav labels happen to run. */
  .locale-switcher { position: relative; display: flex; align-items: center; }
  .locale-switcher-current,
  .locale-switcher-flag {
    display: block;
    width: 16px;
    height: 12px;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--wp-border-secondary);
  }
  .locale-switcher-current { box-shadow: 0 0 0 1.5px var(--wp-ink); }
  .locale-switcher-flag { opacity: 0.7; transition: opacity 150ms; }
  .locale-switcher-flag:hover { opacity: 1; }
  .locale-switcher-current :global(svg),
  .locale-switcher-flag :global(svg) { display: block; width: 100%; height: 100%; }
  .locale-switcher-menu {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    z-index: 62;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 4px 14px rgba(17,19,24,0.14);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 150ms, transform 150ms, visibility 150ms;
  }
  .locale-switcher:hover .locale-switcher-menu,
  .locale-switcher:focus-within .locale-switcher-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--wp-font-sans);
