  .problem-grid--compact { grid-template-columns: repeat(2, 1fr); gap: 20px 18px; }
  .problem-card {
    position: relative;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(17,19,24,0.05), 0 12px 24px -14px rgba(17,19,24,0.15);
    overflow: hidden;
  }
  .problem-card-body {
    position: relative;
    padding: 20px 22px 36px 34px;
  }
  .problem-card-title {
    font-size: var(--wp-text-lg);
    font-weight: 700;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .problem-card-text {
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.5;
  }

  .desk-compare {
    display: grid;
    grid-template-columns: 1.15fr auto 1fr;
    gap: 34px;
    align-items: center;
  }
  .desk-compare-label { margin-bottom: 16px; }
  .desk-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .desk-arrow-img {
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 2px var(--wp-paper-dark), 0 0 0 3.5px var(--wp-ink);
  }
  .desk-arrow-label {
    font-size: var(--wp-text-sm);
    font-weight: 700;
    letter-spacing: -0.01em;
    text-align: center;
    line-height: 1.1;
  }
  .desk-after-card {
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 2px 4px rgba(17,19,24,0.06), 0 20px 40px -18px rgba(17,19,24,0.2);
    overflow: hidden;
  }
  .desk-after-header {
    padding: 15px 18px;
    border-bottom: 2px solid var(--wp-ink);
    font-size: var(--wp-text-md);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .desk-after-list { padding: 6px 18px 10px; }
  .desk-after-item {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 11px 0;
    border-bottom: 1px solid var(--wp-line);
  }
  .desk-after-item:last-child { border-bottom: none; }
  .desk-after-num { width: 18px; }
  .desk-after-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .desk-after-text { font-size: var(--wp-text-base); color: var(--wp-ink); font-weight: 500; }

  /* ===== EMMA RUNS THE DESK ===== */
  .emma-desk-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 28px;
    flex-wrap: wrap;
    margin-bottom: 44px;
  }
  .emma-desk-intro { max-width: 640px; }
  .emma-desk-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(17,19,24,0.05);
    padding: 10px 14px;
    transform: rotate(0.8deg);
  }
  .emma-desk-badge img { border-radius: 50%; object-fit: cover; box-shadow: 0 0 0 1.5px var(--wp-ink); }
  .emma-desk-badge-name { font-size: var(--wp-text-md); font-weight: 700; letter-spacing: -0.01em; }

  .emma-cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  .emma-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(17,19,24,0.05), 0 14px 28px -18px rgba(17,19,24,0.16);
    padding: 22px 22px 24px;
    height: 100%;
  }
  .emma-card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 13px;
    margin-bottom: 15px;
    border-bottom: 1.5px solid var(--wp-ink);
  }
  .emma-card-index {
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: var(--wp-ink);
  }
  .emma-card-title {
    font-size: var(--wp-text-xl);
    font-weight: 700;
    margin: 0 0 9px;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--wp-ink);
  }
  .emma-card-body { margin: 0; font-size: var(--wp-text-base); color: var(--wp-text-secondary); line-height: 1.55; }

  /* ===== FOUR COMMITMENTS ===== */
  .commitments-panel {
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 2px 4px rgba(17,19,24,0.06), 0 22px 44px -20px rgba(17,19,24,0.2);
  }
  .commitments-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 30px;
    border-bottom: 2px solid var(--wp-ink);
  }
  .commitments-panel-title { font-size: var(--wp-text-lg); font-weight: 700; letter-spacing: -0.02em; }
  .commitments-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .commitment-item { padding: 26px 30px; border-right: 1px solid var(--wp-line); border-bottom: 1px solid var(--wp-line); }
  .commitment-item:nth-child(2n) { border-right: none; }
  .commitment-item:nth-last-child(-n+2) { border-bottom: none; }
  .commitment-item-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 8px; }
  .commitment-num { font-family: var(--wp-font-mono); font-size: var(--wp-text-sm); color: var(--wp-signal); font-weight: 600; }
  .commitment-title { font-size: var(--wp-text-xl); font-weight: 700; margin: 0; letter-spacing: -0.02em; color: var(--wp-ink); }
  .commitment-body { margin: 0 0 0 30px; font-size: var(--wp-text-md); color: var(--wp-text-secondary); line-height: 1.55; }

  /* ===== THE CANVAS ===== */
  .canvas-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
    gap: 56px;
    align-items: center;
  }
  .canvas-points { border-top: 1px solid var(--wp-line); }
  .canvas-point { display: flex; align-items: center; gap: 12px; padding: 13px 0; border-bottom: 1px solid var(--wp-line); font-size: var(--wp-text-md); color: var(--wp-ink); }
  .canvas-point:last-child { border-bottom: none; }
  .canvas-point-dot { width: 8px; height: 8px; border-radius: 2px; flex: 0 0 auto; }

  .canvas-doc-wrap { position: relative; min-width: 0; }
  .canvas-doc {
    position: relative;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 2px 5px rgba(17,19,24,0.06), 0 28px 52px -20px rgba(17,19,24,0.24);
    transform: rotate(-0.6deg);
  }
  .canvas-doc-header { display: flex; align-items: center; justify-content: space-between; padding: 15px 24px; border-bottom: 2px solid var(--wp-ink); }
  .canvas-doc-header-left { display: flex; align-items: center; gap: 11px; }
  .canvas-doc-header-left img { border-radius: 50%; object-fit: cover; box-shadow: 0 0 0 1.5px var(--wp-ink); }
  .canvas-doc-title { font-size: var(--wp-text-md); font-weight: 700; letter-spacing: -0.02em; line-height: 1; }
  .canvas-doc-body { display: grid; grid-template-columns: 1fr 190px; }
  .canvas-doc-copy { padding: 24px 26px; border-right: 1px solid var(--wp-line); }
  .canvas-doc-heading { font-size: var(--wp-text-2xl); font-weight: 700; letter-spacing: -0.02em; margin: 0 0 14px; line-height: 1.15; color: var(--wp-ink); }
  .canvas-line { height: 6px; background: var(--wp-line); border-radius: 3px; margin-bottom: 9px; }
  .canvas-line--amber { background: var(--wp-amber-soft); border: 1px solid rgba(196,122,28,0.3); }
  .canvas-line--cyan { background: var(--wp-cyan-soft); border: 1px solid rgba(8,145,178,0.3); }
  .canvas-doc-subhead { margin-bottom: 10px; }
  .canvas-margin-rail { padding: 20px 16px; background: var(--wp-paper-soft); display: flex; flex-direction: column; gap: 12px; }
  .canvas-margin-note { padding: 9px 11px; background: #FFF; border: 1px solid var(--wp-line); border-left: 3px solid var(--wp-border-strong); }
  .canvas-margin-note--amber { border-color: rgba(196,122,28,0.3); border-left-color: var(--wp-amber); }
  .canvas-margin-note--cyan { border-color: rgba(8,145,178,0.3); border-left-color: var(--wp-cyan); }
  .canvas-margin-tag { margin-bottom: 3px; }
  .canvas-margin-tag--amber { color: var(--wp-amber); }
  .canvas-margin-tag--cyan { color: var(--wp-cyan); }
  .canvas-margin-text { font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.4; }
  .canvas-doc-footer { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 14px 24px; border-top: 1px solid var(--wp-line); background: var(--wp-paper); }
  .canvas-doc-footer-left { display: inline-flex; align-items: center; gap: 8px; font-size: var(--wp-text-sm); font-family: var(--wp-font-mono); color: var(--wp-text-secondary); }
  .canvas-doc-annot {
    position: absolute;
    top: -12px; right: 22px;
    z-index: 4;
    transform: rotate(5deg);
    font-family: 'Caveat', cursive;
    font-weight: 600;
    font-size: 19px;
    color: var(--wp-ink);
  }

  /* ===== SPECIALIST BENCH ===== */
  .scale-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 16px;
    border-top: 1px solid var(--wp-border-strong);
    border-bottom: 1px solid var(--wp-border-strong);
    padding: 13px 2px;
    margin-bottom: 26px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-sm);
    letter-spacing: 0.04em;
    color: var(--wp-text-tertiary);
  }
  .scale-strip-strong { font-weight: 700; color: var(--wp-ink); }
  .scale-strip-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--wp-border-strong); }

  .team-cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  .team-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(17,19,24,0.05), 0 14px 28px -18px rgba(17,19,24,0.16);
    overflow: hidden;
    height: 100%;
  }
  .team-card-bar { position: absolute; top: 0; left: 0; width: 4px; height: 100%; }
  .team-card-head { padding: 20px 20px 14px; border-bottom: 1px solid var(--wp-line); }
  .team-card-eyebrow { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 7px; }
  .team-card-dot { width: 8px; height: 8px; border-radius: 50%; }
  .team-card-name { font-size: var(--wp-text-lg); font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; color: var(--wp-ink); }
  .team-card-summary { margin: 0; padding: 14px 20px 14px; font-size: var(--wp-text-sm); color: var(--wp-text-secondary); line-height: 1.5; }
  .team-card-chips-label {
    padding: 0 20px 8px;
    font-size: 11px;
    font-family: var(--wp-font-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--wp-text-muted);
  }
  .team-card-chips { display: flex; flex-wrap: wrap; gap: 6px; padding: 0 20px 18px; }
  .team-chip {
    padding: 3px 10px;
    border: 1px solid var(--wp-line);
    border-radius: var(--wp-radius-pill);
    font-size: 11px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-secondary);
    letter-spacing: 0.02em;
  }
  .team-chip--more {
    color: var(--wp-text-tertiary);
    font-style: italic;
    border-style: dashed;
  }
  .team-card-cta {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 12px 20px;
    border-top: 1px dashed var(--wp-line);
    font-size: var(--wp-text-sm);
    font-weight: 600;
    color: var(--wp-ink);
    text-decoration: none;
  }
  .team-card-cta--secondary { color: var(--wp-text-tertiary); font-weight: 500; }

  /* ===== SAME DESK, NATIVE VOICE ===== */
  .editors-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px; }
  .editor-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(17,19,24,0.05), 0 12px 22px -18px rgba(17,19,24,0.14);
    padding: 20px 12px 18px;
  }
  .editor-card-lead {
    position: absolute;
    top: 10px; right: 10px;
    padding: 2px 6px;
    border: 1px solid var(--wp-signal-border);
    background: var(--wp-signal-soft);
    border-radius: var(--wp-radius-pill);
    font-size: 9px;
    font-family: var(--wp-font-mono);
    color: var(--wp-signal);
    letter-spacing: 0.06em;
  }
  .editor-card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    opacity: 0.75;
  }
  .editor-card-flag {
    position: absolute;
    top: 9px; left: 9px;
    width: 20px;
    height: 14px;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--wp-border-secondary), 0 1px 2px rgba(17,19,24,0.12);
  }
  .editor-card-flag :global(svg) { display: block; width: 100%; height: 100%; }
  .editor-card-img { border-radius: 50%; object-fit: cover; box-shadow: 0 0 0 1.5px var(--wp-border-secondary); margin-bottom: 12px; }
  .editor-card-name { font-size: var(--wp-text-lg); font-weight: 700; letter-spacing: -0.02em; line-height: 1; }
  .editor-card-city { font-size: var(--wp-text-xs); color: var(--wp-text-tertiary); margin-top: 4px; }
  .editor-card-lang {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 11px;
    padding: 3px 9px;
    border: 1px solid var(--wp-line);
    border-radius: var(--wp-radius-pill);
  }
  .editor-card-lang span:first-child { font-weight: 600; color: var(--wp-ink); }
  .editor-card-lang-name { color: var(--wp-text-tertiary); }
  .editors-closing { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 36px; }
  .editors-closing-rule { height: 1px; width: 44px; background: var(--wp-border-strong); }
  .editors-closing-text { font-size: var(--wp-text-lg); font-weight: 700; letter-spacing: -0.02em; color: var(--wp-ink); }

  /* ===== HUMAN APPROVAL ===== */
  .approval-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 56px;
    align-items: center;
  }
  .approval-body { margin-bottom: 18px; }
  .approval-final-line {
    font-size: var(--wp-text-xl);
    color: var(--wp-ink);
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .approval-paper {
    position: relative;
    min-height: 340px;
  }

  .paper-card--approval {
    position: absolute;
    bottom: 0; left: 0;
    width: 340px;
    transform: rotate(-1.4deg);
    z-index: 2;
    box-shadow: 0 2px 5px rgba(17,19,24,0.06), 0 24px 46px -16px rgba(17,19,24,0.24);
  }
  .approval-doc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 22px;
    border-bottom: 2px solid var(--wp-ink);
  }
  .approval-doc-title {
    font-size: var(--wp-text-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .approval-doc-body { padding: 18px 22px; }
  .approval-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--wp-line);
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
  }
  .approval-row--last { border-bottom: none; }
  .approval-awaiting { color: var(--wp-amber); letter-spacing: 0.04em; }
  .approval-doc-footer {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 22px;
    border-top: 1px solid var(--wp-line);
    background: var(--wp-paper);
  }
  .hand-signature {
    font-family: var(--wp-font-hand);
    font-weight: 700;
    font-size: 28px;
    color: var(--wp-ink);
    line-height: 1;
    transform: rotate(-3deg);
    display: inline-block;
  }

  .approval-pill {
    position: absolute;
    bottom: -14px; left: 18px;
    z-index: 3;
    transform: rotate(2deg);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: #FFF;
    border: 1px dashed var(--wp-border-strong);
    border-radius: var(--wp-radius-pill);
  }
  .approval-pill-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--wp-ink);
  }

  /* ===== FINAL CTA ===== */
  .section--cta { padding: 104px 0 112px; }
  .cta-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 34px;
    text-align: center;
  }
  .cta-avatar {
    display: block;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 2px var(--wp-paper), 0 0 0 3.5px var(--wp-ink);
    margin: 0 auto 22px;
  }
  .cta-h2 {
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0;
    line-height: 1.04;
    color: var(--wp-ink);
  }
  .cta-body {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.5;
    margin: 22px auto 0;
    max-width: 560px;
  }
  .cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 34px;
    flex-wrap: wrap;
  }
  .cta-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-top: 44px;
  }
  .cta-rule {
    height: 1px;
    width: 50px;
    background: var(--wp-border-strong);
  }
  .cta-mark-text { letter-spacing: 0.16em; }

  /* ===== FOOTER ===== */
  .footer {
    background-color: var(--wp-paper-dark);
    background-image: var(--wp-texture-paper);
    border-top: 2px solid var(--wp-ink);
    padding: 58px 0 42px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 32px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; max-width: 300px; }
  .footer-logo { display: block; height: 90px; width: auto; align-self: flex-start; margin-left: -4px; }
  .footer-tagline { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); line-height: 1.5; margin: 6px 0 0; }
  .footer-nav { display: flex; flex-direction: column; gap: 10px; }
  .footer-nav-heading { font-size: var(--wp-text-sm); font-weight: 700; }
  .footer-link { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); transition: color 150ms; }
  .footer-link:hover { color: var(--wp-ink); }
  .footer-bottom {
    margin-top: 46px;
    padding-top: 22px;
    border-top: 1px solid var(--wp-border-strong);
    display: flex;
    justify-content: space-between;
    font-size: var(--wp-text-sm);
    color: var(--wp-text-muted);
  }

  /* ============================================================
     RESPONSIVE — tablet landscape / small laptop (≤ 1024px)
  ============================================================ */
  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 36px;
    }

    .emma-cards-grid { grid-template-columns: repeat(2, 1fr); }
    .team-cards-grid { grid-template-columns: repeat(2, 1fr); }
    .editors-grid { grid-template-columns: repeat(3, 1fr); }

    .footer-grid { grid-template-columns: 1.4fr 1fr 1fr; }
    .footer-grid > :last-child { display: none; }
  }

  /* ============================================================
     RESPONSIVE — tablet portrait / large phone (≤ 768px)
  ============================================================ */
  @media (max-width: 768px) {
    .container { padding: 0 24px; }
    .section { padding: 60px 0; }

    /* --- Masthead --- */
    .masthead-inner { padding: 10px 24px; }
    .masthead-nav--left { display: none; }
    .masthead-nav--right .nav-link { display: none; }
    .locale-switcher { display: none; }
    .masthead-logo img { height: 78px; }
    .masthead::after {
      background: linear-gradient(
        to right,
        var(--wp-ink) calc(50% - 72px),
        transparent calc(50% - 72px),
        transparent calc(50% + 72px),
        var(--wp-ink) calc(50% + 72px)
      );
    }

    /* --- Hero --- */
    .section--hero { padding: 48px 0 56px; }
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-body { font-size: var(--wp-text-lg); }
    .hero-board-note { display: none; }
    .hero-board-stamp { display: none; }

    /* --- Operating model / desk compare --- */
    .desk-compare { grid-template-columns: 1fr; gap: 28px; }
    .desk-arrow { flex-direction: row; justify-content: center; }
    .desk-arrow svg { transform: rotate(90deg); }
    .problem-grid--compact { grid-template-columns: repeat(2, 1fr); }

    /* --- Emma runs the desk --- */
    .emma-desk-header { flex-direction: column; align-items: flex-start; }
    .emma-cards-grid { grid-template-columns: 1fr 1fr; }

