---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { homeContent } from '@/data/i18n/home';
import { commonStrings } from '@/data/i18n/common';
import { getTeamGroups, TOTAL_SPECIALISTS, TOTAL_TEAMS } from '@/data/workerRegistry';
import { FLAG_SVG } from '@/i18n/flags';
import { LOCALES, localeHref, type Locale } from '@/i18n/locales';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = homeContent[locale];
const c = commonStrings[locale];
const teamGroups = getTeamGroups(6);

// Flag/accent per language-editor tile. Team names/summaries in the
// specialist bench below still come from workerRegistry.ts (English only
// for now — see context.md, "Phase 2").
const EDITOR_META = [
  { code: 'IE', image: 'emma', lead: true, accent: '#169B62' },
  { code: 'PT', image: 'aurora', lead: false, accent: '#046A38' },
  { code: 'BR', image: 'francisca', lead: false, accent: '#009739' },
  { code: 'ES', image: 'sofia', lead: false, accent: '#AA151B' },
  { code: 'DE', image: 'sabine', lead: false, accent: '#DD0000' },
  { code: 'FR', image: 'ambre', lead: false, accent: '#0055A4' },
];
const editors = t.languages.editors.map((e, i) => ({ ...e, ...EDITOR_META[i] }));

const canonical = locale === 'en' ? 'https://wordpresto.com/' : `https://wordpresto.com${localeHref(locale, '/')}`;
---

<BaseLayout
  pageTitle={t.seo.pageTitle}
  seoTitle={t.seo.seoTitle}
  description={t.seo.metaDescription}
  canonical={canonical}
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href={localeHref(locale, '/waitlist')} class="nav-link">{c.signIn}</a>
        <a href={`${localeHref(locale, '/')}#emma-desk`} class="nav-link">{c.theDesk}</a>
        <a href={`${localeHref(locale, '/')}#canvas`} class="nav-link">{c.canvas}</a>
      </nav>
      <a href={localeHref(locale, '/')} class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href={`${localeHref(locale, '/')}#specialists`} class="nav-link">{c.specialists}</a>
        <a href={`${localeHref(locale, '/')}#languages`} class="nav-link">{c.languages}</a>
        <a href="#" class="nav-link">{c.pricing}</a>
        <div class="locale-switcher">
          <a
            href={localeHref(locale, '/')}
            class="locale-switcher-current"
            aria-label={LOCALES.find((l) => l.code === locale)?.label}
            set:html={FLAG_SVG[LOCALES.find((l) => l.code === locale)?.countryCode ?? 'IE']}
          />
          <div class="locale-switcher-menu">
            {LOCALES.filter((l) => l.code !== locale).map((l) => (
              <a
                href={localeHref(l.code, '/')}
                class="locale-switcher-flag"
                aria-label={l.label}
                set:html={FLAG_SVG[l.countryCode]}
              />
            ))}
          </div>
        </div>
        <a href={localeHref(locale, '/waitlist')} class="btn btn--primary btn--sm">{c.joinWaitlist}</a>
      </nav>
    </div>
  </header>

  <!-- ===================== 1. HERO ===================== -->
  <section id="top" class="section section--hero">
    <div class="container hero-grid">

      <div class="hero-copy">
        <div class="eyebrow eyebrow--strategy">{t.hero.eyebrow}</div>
        <h1 class="hero-h1">{t.hero.h1Prefix}<span class="agentic-mark">{t.hero.h1Agentic}</span>{t.hero.h1Suffix}</h1>
        <p class="hero-body">{t.hero.body}</p>
        <div class="hero-approval-note">
          <p>{t.hero.approvalNoteLine1}<br />{t.hero.approvalNoteLine2}</p>
        </div>
        <div class="hero-ctas">
          <a href={localeHref(locale, '/waitlist')} class="btn btn--primary btn--lg">
            {t.hero.ctaPrimary}
            <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href={`${localeHref(locale, '/')}#emma-desk`} class="btn btn--secondary btn--lg btn--tilt">{t.hero.ctaSecondary}</a>
        </div>
        <p class="hero-demo-link">
          <a href="/workflow-demo/" class="demo-link">{t.hero.demoLink} →</a>
        </p>
        <div class="hero-prepares">
          <span class="hero-prepares-label">{t.hero.preparesLabel}</span>
          <span class="hero-prepares-item">WordPress</span>
          <span class="hero-dot" aria-hidden="true"></span>
          <span class="hero-prepares-item">Astro</span>
          <span class="hero-dot" aria-hidden="true"></span>
          <span class="hero-prepares-item">Payload</span>
          <span class="hero-dot" aria-hidden="true"></span>
          <span class="hero-prepares-item">Sanity</span>
        </div>
      </div>

      <!-- Editorial operations board: Editor → Emma → Canvas + specialists → Approval + CMS -->
      <div class="hero-board-wrap">
        <span class="hero-board-note">{t.board.note}</span>

        <div class="hero-board">
          <div class="board-header">
            <span class="board-header-title">{t.board.title}</span>
            <span class="mono-label board-live"><span class="board-live-dot"></span>{t.board.liveLabel}</span>
          </div>

          <div class="board-body">
            <div class="board-row board-row--editor">
              <span class="board-avatar-icon" aria-hidden="true">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--wp-ink)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>
              </span>
              <div class="board-row-info">
                <div class="mono-label">{t.board.editorInChief}</div>
                <div class="board-row-name">{t.board.you}</div>
              </div>
              <span class="mono-label">{t.board.finalCall}</span>
            </div>

            <div class="board-connector" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="var(--wp-border-strong)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 2 V11 M4 8 L7.5 11.5 L11 8"></path></svg>
            </div>

            <div class="board-row board-row--emma">
              <img src="/editors/emma-192.webp" srcset="/editors/emma-192.webp 1x, /editors/emma-384.webp 2x" alt="Emma, managing editor" class="board-avatar-img" width="52" height="52" loading="eager" decoding="async" />
              <div class="board-row-info">
                <div class="board-row-name-line"><span class="board-row-name">Emma</span><span class="mono-label">{t.board.emmaRole}</span></div>
                <div class="board-row-sub">{t.board.emmaSub}</div>
              </div>
              <span class="board-status-badge"><span class="board-status-dot"></span>{t.board.preparing}</span>
            </div>

            <div class="board-connector" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="var(--wp-border-strong)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 2 V11 M4 8 L7.5 11.5 L11 8"></path></svg>
            </div>

            <div class="board-canvas-card">
              <div class="board-canvas-header">
                <span class="mono-label">{t.board.canvasLabel}</span>
                <span class="mono-label">{t.board.workingSurface}</span>
              </div>
              <div class="board-canvas-line"></div>
              <div class="board-canvas-line" style="width: 82%;"></div>
              <div class="board-canvas-line" style="width: 64%;"></div>
              <div class="board-canvas-chips">
                <span class="board-chip board-chip--amber">{t.board.chip1}</span>
                <span class="board-chip board-chip--cyan">{t.board.chip2}</span>
              </div>
            </div>

            <div class="board-specialist-row">
              <div class="board-avatar-stack">
                <img src="/agents/profiles/profile-08-192.webp" alt="" width="26" height="26" loading="lazy" decoding="async" />
                <img src="/agents/profiles/profile-34-192.webp" alt="" width="26" height="26" loading="lazy" decoding="async" />
                <img src="/agents/profiles/profile-21-192.webp" alt="" width="26" height="26" loading="lazy" decoding="async" />
                <img src="/agents/profiles/profile-25-192.webp" alt="" width="26" height="26" loading="lazy" decoding="async" />
              </div>
              <div class="board-row-info">
                <div class="board-row-name" style="font-size: var(--wp-text-sm);">{t.board.specialistDesk}</div>
                <div class="mono-label">{t.board.reportsThroughEmma}</div>
              </div>
            </div>

            <div class="board-connector" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="var(--wp-border-strong)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 2 V11 M4 8 L7.5 11.5 L11 8"></path></svg>
            </div>

            <div class="board-gate-row">
              <div class="board-gate-approval">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--wp-amber)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg>
                <span>{t.board.gateApproval}</span>
              </div>
              <div class="board-gate-cms">
                <span class="board-gate-cms-dot"></span>
                <span>{t.board.gateCms}</span>
              </div>
            </div>
          </div>
        </div>

        <span class="hero-board-stamp">{t.board.stamp}</span>
      </div>
    </div>
  </section>

  <!-- ===================== 2. THE OPERATING MODEL ===================== -->
  <section id="not-dashboard" class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">{t.operatingModel.eyebrow}</div>
        <h2 class="section-h2">{t.operatingModel.h2}</h2>
        <p class="section-body">{t.operatingModel.body}</p>
        <p class="section-note">{t.operatingModel.note}</p>
      </div>

      <div class="desk-compare">
        <div class="desk-before">
          <div class="mono-label desk-compare-label">{t.operatingModel.beforeLabel}</div>
          <div class="problem-grid problem-grid--compact">
            {t.operatingModel.beforeCards.map(({ title, body, note }, i) => {
              const rots = ['-1.6deg', '1.4deg', '0.8deg', '-0.6deg'];
              const noteColors = [undefined, undefined, 'amber', undefined];
              return (
                <div class="problem-card" style={`transform: rotate(${rots[i]})`}>
                  <div class="problem-card-body">
                    <div class="ruled-margin ruled-margin--sm"></div>
                    <div class="problem-card-title">{title}</div>
                    <div class="problem-card-text">{body}</div>
                    {note && <span class={`hand-note hand-note--${noteColors[i] ?? 'red'} hand-note--card`}>{note}</span>}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="desk-arrow">
          <img src="/editors/emma-192.webp" srcset="/editors/emma-192.webp 1x, /editors/emma-384.webp 2x" alt="Emma, managing editor" class="desk-arrow-img" width="60" height="60" loading="lazy" decoding="async" />
          <div class="desk-arrow-label">Emma<br /><span class="mono-label">{t.operatingModel.emmaRole}</span></div>
          <svg width="46" height="16" viewBox="0 0 46 16" fill="none" aria-hidden="true"><path d="M1 8 H40 M35 3 L41 8 L35 13" stroke="var(--wp-ink)" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </div>

        <div class="desk-after">
          <div class="mono-label desk-compare-label">{t.operatingModel.afterLabel}</div>
          <div class="desk-after-card">
            <div class="desk-after-header">{t.operatingModel.afterHeader}</div>
            <div class="desk-after-list">
              {t.operatingModel.afterItems.map((label, i) => {
                const nums = ['01', '02', '03', '04'];
                const colors = ['var(--wp-signal)', 'var(--wp-cyan)', 'var(--wp-amber)', 'var(--wp-ink)'];
                return (
                  <div class="desk-after-item">
                    <span class="mono-label desk-after-num">{nums[i]}</span>
                    <span class="desk-after-dot" style={`background: ${colors[i]}`}></span>
                    <span class="desk-after-text">{label}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 3. EMMA RUNS THE DESK ===================== -->
  <section id="emma-desk" class="section section--border-top">
    <div class="container">
      <div class="emma-desk-header">
        <div class="emma-desk-intro">
          <div class="eyebrow eyebrow--strategy">{t.emmaDesk.eyebrow}</div>
          <h2 class="section-h2">{t.emmaDesk.h2}</h2>
        </div>
        <div class="emma-desk-badge">
          <img src="/editors/emma-192.webp" srcset="/editors/emma-192.webp 1x, /editors/emma-384.webp 2x" alt="Emma, managing editor" width="46" height="46" loading="lazy" decoding="async" />
          <div>
            <div class="emma-desk-badge-name">Emma</div>
            <div class="mono-label">{t.emmaDesk.badgeRole} · {t.emmaDesk.badgeCity}</div>
          </div>
        </div>
      </div>

      <div class="emma-cards-grid">
        {t.emmaDesk.cards.map(({ title, body }, i) => (
          <div class="emma-card">
            <div class="emma-card-top">
              <span class="emma-card-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="mono-label">EMMA</span>
            </div>
            <h3 class="emma-card-title">{title}</h3>
            <p class="emma-card-body">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 4. FOUR COMMITMENTS ===================== -->
  <section id="commitments" class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow eyebrow--strategy">{t.commitments.eyebrow}</div>
        <h2 class="section-h2" set:html={t.commitments.h2} />
        <p class="section-body">{t.commitments.body}</p>
      </div>

      <div class="commitments-panel">
        <div class="commitments-panel-header">
          <span class="commitments-panel-title">{t.commitments.panelTitle}</span>
          <span class="mono-label">{t.commitments.panelLabel}</span>
        </div>
        <div class="commitments-grid">
          {t.commitments.items.map(({ num, title, body }) => (
            <div class="commitment-item">
              <div class="commitment-item-head">
                <span class="commitment-num">{num}</span>
                <h3 class="commitment-title">{title}</h3>
              </div>
              <p class="commitment-body" set:html={body} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 5. THE CANVAS ===================== -->
  <section id="canvas" class="section section--border-top section--overflow-hidden">
    <div class="container canvas-grid">
      <div>
        <div class="eyebrow eyebrow--strategy">{t.canvas.eyebrow}</div>
        <h2 class="section-h2">{t.canvas.h2}</h2>
        <p class="section-body">{t.canvas.body}</p>
        <div class="canvas-points">
          {t.canvas.points.map((point, i) => {
            const colors = ['var(--wp-amber)', 'var(--wp-cyan)', 'var(--wp-ink)'];
            return (
              <div class="canvas-point"><span class="canvas-point-dot" style={`background: ${colors[i]};`}></span><span>{point}</span></div>
            );
          })}
        </div>
      </div>

      <div class="canvas-doc-wrap">
        <div class="canvas-doc">
          <div class="canvas-doc-header">
            <div class="canvas-doc-header-left">
              <img src="/editors/emma-192.webp" srcset="/editors/emma-192.webp 1x, /editors/emma-384.webp 2x" alt="Emma, managing editor" width="28" height="28" loading="lazy" decoding="async" />
              <div>
                <div class="canvas-doc-title">Canvas</div>
                <div class="mono-label">{t.canvas.docLabel}</div>
              </div>
            </div>
            <span class="mono-label" set:html={t.canvas.draftLabel} />
          </div>

          <div class="canvas-doc-body">
            <div class="canvas-doc-copy">
              <h3 class="canvas-doc-heading">{t.canvas.docHeading}</h3>
              <div class="canvas-line"></div>
              <div class="canvas-line" style="width: 94%;"></div>
              <div class="canvas-line canvas-line--amber" style="width: 88%;"></div>
              <div class="canvas-line" style="width: 76%; margin-bottom: 22px;"></div>
              <div class="mono-label canvas-doc-subhead">{t.canvas.sectionLabel}</div>
              <div class="canvas-line"></div>
              <div class="canvas-line canvas-line--cyan" style="width: 70%;"></div>
              <div class="canvas-line" style="width: 90%;"></div>
            </div>
            <div class="canvas-margin-rail">
              <div class="mono-label">{t.canvas.marginLabel}</div>
              {t.canvas.marginNotes.map(({ tag, text }, i) => {
                const colors = ['amber', 'default', 'cyan', 'default'];
                const color = colors[i];
                return (
                  <div class={`canvas-margin-note canvas-margin-note--${color}`}>
                    <div class={`mono-label canvas-margin-tag canvas-margin-tag--${color}`}>{tag}</div>
                    <div class="canvas-margin-text">{text}</div>
                  </div>
                );
              })}
            </div>
          </div>

          <div class="canvas-doc-footer">
            <span class="canvas-doc-footer-left">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--wp-amber)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg>
              {t.canvas.footerLeft}
            </span>
            <span class="mono-label">{t.canvas.footerRight}</span>
          </div>
        </div>
        <span class="canvas-doc-annot">{t.canvas.annotation}</span>
      </div>
    </div>
  </section>

  <!-- ===================== 6. SPECIALIST BENCH ===================== -->
  <section id="specialists" class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">{t.specialists.eyebrow}</div>
        <h2 class="section-h2">{TOTAL_SPECIALISTS}{t.specialists.h2Suffix}</h2>
        <p class="section-body">{t.specialists.body}</p>
        <p class="section-note" set:html={t.specialists.note} />
      </div>

      <div class="scale-strip">
        <span class="scale-strip-strong">{TOTAL_SPECIALISTS} {c.specialists.toLowerCase()}</span>
        <span class="scale-strip-dot"></span>
        <span>{TOTAL_TEAMS}{t.specialists.teamsSuffix}</span>
        <span class="scale-strip-dot"></span>
        <span>{t.specialists.coordinatedThroughEmma}</span>
        <span class="scale-strip-dot"></span>
        <span>{t.specialists.editorApprovalRequired}</span>
      </div>

      <div class="team-cards-grid">
        {teamGroups.map(({ name, color, summary, examples, moreCount, count, href, cta }) => (
          <div class="team-card">
            <span class="team-card-bar" style={`background: ${color}`}></span>
            <div class="team-card-head">
              <div class="team-card-eyebrow"><span class="team-card-dot" style={`background: ${color}`}></span><span class="mono-label">TEAM · {count} SPECIALIST{count === 1 ? "" : "S"}</span></div>
              <div class="team-card-name">{name}</div>
            </div>
            <p class="team-card-summary">{summary}</p>
            <div class="team-card-chips-label">{t.specialists.chipsLabel}</div>
            <div class="team-card-chips">
              {examples.map((w) => <span class="team-chip">{w.name}</span>)}
              {moreCount > 0 && <span class="team-chip team-chip--more">+ {moreCount}</span>}
            </div>
            <a href={href} class="team-card-cta">
              {cta}
              <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/specialists/" class="team-card-cta team-card-cta--secondary">
              {t.specialists.browseProfiles}
              <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 7. SAME DESK, NATIVE VOICE ===================== -->
  <section id="languages" class="section section--border-top">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow eyebrow--strategy">{t.languages.eyebrow}</div>
        <h2 class="section-h2">{t.languages.h2}</h2>
        <p class="section-body">{t.languages.body}</p>
      </div>

      <div class="editors-grid">
        {editors.map(({ name, city, lang, code, image, lead, accent }) => (
          <div class="editor-card">
            <span class="editor-card-accent" style={`background: ${accent}`}></span>
            <span class="editor-card-flag" set:html={FLAG_SVG[code]} />
            {lead && <span class="editor-card-lead">LEAD</span>}
            <img src={`/editors/${image}-192.webp`} srcset={`/editors/${image}-192.webp 1x, /editors/${image}-384.webp 2x`} alt={`${name}, managing editor`} class="editor-card-img" width="68" height="68" loading="lazy" decoding="async" />
            <div class="editor-card-name">{name}</div>
            <div class="editor-card-city">{city}</div>
            <div class="editor-card-lang"><span class="mono-label" style={`color: ${accent}`}>{code}</span><span class="mono-label editor-card-lang-name">{lang}</span></div>
          </div>
        ))}
      </div>

      <div class="editors-closing">
        <span class="editors-closing-rule"></span>
        <span class="editors-closing-text">{t.languages.closingText}</span>
        <span class="editors-closing-rule"></span>
      </div>
    </div>
  </section>

  <!-- ===================== 8. APPROVAL IS THE GATE ===================== -->
  <section id="approval" class="section section--border-top section--overflow-hidden">
    <div class="container approval-grid">
      <div>
        <div class="eyebrow eyebrow--strategy">{t.approval.eyebrow}</div>
        <h2 class="section-h2">{t.approval.h2}</h2>
        <p class="section-body approval-body">{t.approval.body}</p>
