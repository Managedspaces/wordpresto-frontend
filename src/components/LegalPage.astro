---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Masthead from '@/components/Masthead.astro';
import { legalPages, type LegalPageContent } from '@/data/legal';
import { breadcrumbList, SITE_URL } from '@/lib/schema';

interface Props {
  content: LegalPageContent;
}

const { content } = Astro.props;
const otherPages = legalPages.filter((page) => page.slug !== content.slug);
const canonical = `${SITE_URL}/${content.slug}/`;

const jsonLd = [
  breadcrumbList([
    { name: 'Home', url: `${SITE_URL}/` },
    { name: content.title, url: canonical },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: content.title,
    description: content.metaDescription,
    url: canonical,
  },
];
---

<BaseLayout
  pageTitle={content.title}
  seoTitle={content.seoTitle}
  description={content.metaDescription}
  canonical={canonical}
  jsonLd={jsonLd}
>

  <!-- ===================== MASTHEAD ===================== -->
  <Masthead locale="en" />

  <main class="legal-main">
    <div class="container">

      <div class="page-header">
        <h1 class="page-title">{content.title}</h1>
        <p class="effective-date">Effective {content.effectiveDate}</p>
        {content.intro.map((paragraph) => <p class="intro-para">{paragraph}</p>)}
      </div>

      <div class="legal-body">
        <article class="legal-content">
          {content.sections.map((section) => (
            <section class="legal-section">
              <h2 class="section-heading">{section.heading}</h2>
              {section.blocks.map((block) =>
                block.type === 'p' ? (
                  <p class="section-para">{block.text}</p>
                ) : (
                  <ul class="section-list">
                    {block.items.map((item) => <li>{item}</li>)}
                  </ul>
                )
              )}
            </section>
          ))}
        </article>

        <aside class="legal-nav" aria-label="Other policies">
          <span class="legal-nav-heading">Other policies</span>
          {otherPages.map((page) => (
            <a href={`/${page.slug}/`} class="legal-nav-link">{page.navLabel}</a>
          ))}
        </aside>
      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="/brand/horizontal-lockup-transparent.png" alt="Word Presto" class="footer-logo" />
        <p class="footer-tagline">The content engine behind better publishing workflows.</p>
      </div>
      <nav class="footer-nav" aria-label="Site">
        <span class="footer-nav-heading">Site</span>
        <a href="/" class="footer-link">Home</a>
        <a href="/workers/" class="footer-link">Workers</a>
        <a href="/sitemap/" class="footer-link">Sitemap</a>
      </nav>
      <nav class="footer-nav" aria-label="Legal">
        <span class="footer-nav-heading">Legal</span>
        <a href="/privacy/" class="footer-link">Privacy Policy</a>
        <a href="/terms/" class="footer-link">Terms &amp; Conditions</a>
        <a href="/cookies/" class="footer-link">Cookie Policy</a>
        <a href="/fair-use/" class="footer-link">Fair Use Policy</a>
        <a href="/data-deletion/" class="footer-link">Data Deletion</a>
      </nav>
    </div>
    <div class="footer-bottom container">
      <span>&copy; 2026 Word Presto</span>
      <span>Review-led publishing &middot; Human approval</span>
    </div>
  </footer>

</BaseLayout>

<style>
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Masthead is now a shared component (src/components/Masthead.astro). */

  /* ===== MAIN ===== */
  .legal-main {
    padding: 56px 0 80px;
  }

  .page-header {
    max-width: 760px;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid var(--wp-ink);
  }
  .page-title {
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 8px;
  }
  .effective-date {
    font-size: var(--wp-text-sm);
    font-weight: 600;
    color: var(--wp-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 20px;
  }
  .intro-para {
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .intro-para:last-child { margin-bottom: 0; }

  /* ===== BODY LAYOUT ===== */
  .legal-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .legal-content {
    max-width: 760px;
  }

  .legal-section {
    margin-bottom: 36px;
  }
  .legal-section:last-child { margin-bottom: 0; }

  .section-heading {
    font-size: var(--wp-text-lg, 20px);
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--wp-ink);
  }
  .section-para {
    font-size: var(--wp-text-base);
    line-height: 1.65;
    color: var(--wp-text-secondary);
    margin: 0 0 14px;
  }
  .section-para:last-child { margin-bottom: 0; }
  .section-list {
    margin: 0 0 14px;
    padding-left: 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .section-list li {
    font-size: var(--wp-text-base);
    line-height: 1.55;
    color: var(--wp-text-secondary);
  }
  .section-list:last-child { margin-bottom: 0; }

  /* ===== SIDE NAV ===== */
  .legal-nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 20px;
    background: var(--wp-paper-soft, #f9f6f1);
    border: 1px solid var(--wp-rule, #e0dbd2);
    border-radius: 2px;
    align-self: start;
    max-width: 260px;
  }
  .legal-nav-heading {
    font-size: var(--wp-text-xs, 11px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--wp-text-tertiary);
    margin-bottom: 4px;
  }
  .legal-nav-link {
    font-size: var(--wp-text-sm);
    color: var(--wp-text-secondary);
    text-decoration: none;
  }
  .legal-nav-link:hover {
    color: var(--wp-ink);
    text-decoration: underline;
  }

  /* ===== FOOTER ===== */
  .footer {
    border-top: 1px solid var(--wp-rule);
    padding: 48px 0 28px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 32px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; max-width: 300px; }
  .footer-logo { display: block; height: 90px; width: auto; align-self: flex-start; margin-left: -4px; }
  .footer-tagline { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); line-height: 1.5; margin: 6px 0 0; }
  .footer-nav { display: flex; flex-direction: column; gap: 10px; }
  .footer-nav-heading { font-size: var(--wp-text-sm); font-weight: 700; }
  .footer-link { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); transition: color 150ms; }
  .footer-link:hover { color: var(--wp-ink); }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 20px;
    border-top: 1px solid var(--wp-rule);
    font-size: var(--wp-text-sm);
    color: var(--wp-text-tertiary);
  }

  @media (min-width: 900px) {
    .legal-body {
      grid-template-columns: 1fr 260px;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 6px;
    }
    .legal-nav {
      max-width: none;
    }
  }
</style>
