---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { workerProfiles, type WorkerProfile } from '@/data/workerProfiles';
import { allWorkers } from '@/data/workers';
import { getLocalizedProfile } from '@/data/i18n/workerProfiles';
import { workerProfilePageChrome } from '@/data/i18n/workerProfilePage';
import { commonStrings } from '@/data/i18n/common';
import { workersSharedContent } from '@/data/i18n/workersDirectory';
import { localeHref, type Locale } from '@/i18n/locales';

interface Props {
  locale: Locale;
  englishProfile: WorkerProfile;
}

const { locale, englishProfile } = Astro.props;
const profile = getLocalizedProfile(englishProfile, locale);
const t = workerProfilePageChrome[locale];
const c = commonStrings[locale];
const shared = workersSharedContent[locale];

const relatedProfiles = profile.relatedWorkerIds.map(({ id, description, outputLabel, ctaLabel }) => {
  const w = allWorkers.find((x) => x.id === id);
  const p = workerProfiles.find((x) => x.id === id);
  return w && p ? { worker: w, profile: p, description, outputLabel, ctaLabel } : null;
}).filter(Boolean);

const canonical = locale === 'en'
  ? `https://wordpresto.com/workers/${profile.slug}/`
  : `https://wordpresto.com${localeHref(locale, `/workers/${profile.slug}/`)}`;
---

<BaseLayout
  pageTitle={profile.h1}
  seoTitle={profile.seoTitle}
  description={profile.metaDescription}
  canonical={canonical}
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href={localeHref(locale, '/waitlist')} class="nav-link">{c.signIn}</a>
        <a href={`${localeHref(locale, '/')}#product`} class="nav-link">{c.product}</a>
        <a href={`${localeHref(locale, '/')}#capabilities`} class="nav-link">{c.workflow}</a>
      </nav>
      <a href={localeHref(locale, '/')} class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href={`${localeHref(locale, '/')}#use-cases`} class="nav-link">{c.useCases}</a>
        <a href={localeHref(locale, '/workers/')} class="nav-link nav-link--active">{c.workers}</a>
        <a href={localeHref(locale, '/waitlist')} class="btn btn--primary btn--sm">{c.joinWaitlist}</a>
      </nav>
    </div>
  </header>

  <!-- ===================== 1. HERO ===================== -->
  <section class="section section--hero wp-overflow-hidden">
    <div class="container">
      <nav class="wp-breadcrumb" aria-label="Breadcrumb">
        <a href={localeHref(locale, '/workers/')} class="wp-breadcrumb-back">&#8592;</a>
        <a href={localeHref(locale, '/workers/')} class="wp-breadcrumb-link">{shared.breadcrumbWorkers}</a>
        <span class="wp-breadcrumb-sep">/</span>
        <span class="wp-breadcrumb-current">{profile.name.toUpperCase()}</span>
      </nav>

      <div class="hero-grid">
        <!-- LEFT -->
        <div class="hero-copy">
          <div class="eyebrow eyebrow--strategy">{profile.role}</div>
          <div class="hero-pills">
            <span class="hero-pill hero-pill--team">
              <span class="hero-pill-dot" style={`background: ${profile.teamColor}`}></span>
              {profile.heroTagPills.team}
            </span>
            <span class="hero-pill">{profile.heroTagPills.stage}</span>
            <span class="hero-pill">{profile.heroTagPills.output}</span>
            {profile.planned && <span class="hero-pill hero-pill--planned">{shared.planned}</span>}
          </div>
          <h1 class="hero-h1">{profile.h1}</h1>
          <p class="hero-body">{profile.heroPara1}</p>
          <p class="hero-audience">{profile.heroPara2}</p>
          <div class="hero-ctas">
            {profile.planned ? (
              <a href={localeHref(locale, '/waitlist')} class="btn btn--primary btn--lg">
                {c.joinWaitlist}
                <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            ) : (
              <a href="#problem" class="btn btn--primary btn--lg">
                {t.seeHowWorksPrefix}{profile.name}{t.seeHowWorksSuffix}
                <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            )}
            <a href={localeHref(locale, '/workers/')} class="btn btn--secondary btn--lg btn--tilt">{t.viewAllWorkers}</a>
          </div>
          <div class="hero-alongside">
            <span class="hero-alongside-label">{t.worksAlongsideLabel}</span>
            {profile.heroWorksAlongside.map((name, i) => (
              <>
                <span class="hero-alongside-name">{name}</span>
                {i < profile.heroWorksAlongside.length - 1 && <span class="hero-dot" aria-hidden="true"></span>}
              </>
            ))}
          </div>
        </div>

        <!-- RIGHT: paper composition -->
        <div class="hero-art" aria-hidden="true">

          <!-- Guidance / output sheet -->
          <div class="guidance-sheet">
            <span class="folder-tab folder-tab--guidance">{shared.outputLabel}</span>
            <div class="guidance-header">
              <span class="guidance-title">{profile.heroTagPills.output.replace('Output · ', '')}</span>
              <span class="guidance-worker">{profile.name.toLowerCase()}</span>
            </div>
            <div class="guidance-body">
              <div class="mono-label guidance-meta">PAGE · content-brief.md</div>
              <div class="guidance-rows">
                <div class="guidance-row">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--wp-signal)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" class="guidance-icon"><path d="m5 12 5 5L20 7"/></svg>
                  <span><strong>{profile.checks[0]}</strong></span>
                </div>
                <div class="guidance-row">
                  <span class="guidance-icon guidance-icon--amber">&#9651;</span>
                  <span><strong>{t.guidanceReviewLabel}</strong> {profile.surfaces[0]}</span>
                </div>
                <div class="guidance-row">
                  <span class="guidance-icon guidance-icon--red">&#9472;</span>
                  <span><strong>{t.guidanceFlagLabel}</strong> {profile.surfaces[profile.surfaces.length - 1]}</span>
                </div>
              </div>
            </div>
            <div class="guidance-footer">
              <span class="mono-label">{profile.guidanceFooterLabel}</span>
              <span class="guidance-stamp">{profile.guidanceFooterValue}</span>
            </div>
          </div>

          <!-- Worker slip -->
          <div class="worker-slip-card">
            <span class="fold-corner fold-corner--sm"></span>
            <span class="fold-corner-line fold-corner-line--sm"></span>
            <div class="worker-slip-inner">
              <img
                src={profile.portrait}
                srcset={`${profile.portrait} 1x, ${profile.portrait2x} 2x`}
                alt={profile.name}
                class="worker-slip-portrait"
                width="62"
                height="62"
                loading="eager"
                decoding="async"
              />
              <div>
                <div class="worker-slip-meta">
                  <span class="worker-slip-dot" style={`background: ${profile.teamColor}`}></span>
                  <span class="mono-label">{t.workerLabel} {profile.department.toUpperCase()}</span>
                </div>
                <div class="worker-slip-name">{profile.name}</div>
                <div class="worker-slip-role">{profile.roleTitle ?? profile.role}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 2. PROBLEM ===================== -->
  <section id="problem" class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="prob-grid">
        <!-- LEFT -->
        <div>
          <div class="eyebrow eyebrow--strategy">{profile.problemEyebrow}</div>
          <h2 class="section-h2">{profile.problemH2}</h2>
          <p class="section-body">{profile.problemPara}</p>
          <span class="hand-note hand-note--amber prob-annotation">{profile.problemAnnotation}</span>
        </div>

        <!-- RIGHT: before/after draft sheet -->
        <div class="ba-wrapper" data-state="raw">
          <span class="fold-corner fold-corner--md"></span>
          <span class="fold-corner-line fold-corner-line--md"></span>
          <div class="ba-header">
            <span class="ba-filename mono-label">{profile.name.toLowerCase()}-draft.md</span>
            <div class="ba-tabs">
              <button class="ba-tab ba-tab--raw" data-ba="raw">{t.rawDraftTab}</button>
              <button class="ba-tab ba-tab--pass" data-ba="pass">{t.afterTabPrefix}{profile.name}</button>
            </div>
          </div>
          <div class="ba-body">
            <span class="ruled-margin-vert"></span>
            <!-- RAW -->
            <div class="ba-panel ba-panel--raw">
              <span class="ba-stamp ba-stamp--red">{profile.beforeStamp}</span>
              <div class="ba-text" set:html={profile.beforeHtml} />
              <div class="ba-tags">
                {profile.beforeTags.map(tag => <span class="ba-tag">{tag}</span>)}
              </div>
              <span class="hp-hand ba-note ba-note--red">{profile.beforeNote}</span>
            </div>
            <!-- PASS -->
            <div class="ba-panel ba-panel--pass">
              <span class="ba-stamp ba-stamp--signal">{profile.afterStamp}</span>
              <div class="ba-text" set:html={profile.afterHtml} />
              <div class="ba-tags">
                {profile.afterTags.map(tag => <span class="ba-tag ba-tag--signal">{tag}</span>)}
              </div>
              <span class="hp-hand ba-note ba-note--signal">{profile.afterNote}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 3. HOW WORKER HELPS ===================== -->
  <section class="section section--border-top">
    <div class="container">
      <div class="section-intro section-intro--wide">
        <div class="eyebrow eyebrow--strategy">{profile.helpsEyebrow}</div>
        <h2 class="section-h2">{profile.helpsH2}</h2>
        <p class="section-body">{profile.helpsPara}</p>
      </div>
      <div class="quad-grid">
        <div class="quad-card quad-card--rot-neg">
          <div class="fold-corner fold-corner--sm"></div>
          <div class="fold-corner-line fold-corner-line--sm"></div>
          <div class="quad-label" style={`color: ${profile.teamColor}`}>{t.checksLabel}</div>
          <h3 class="quad-h3">{t.whatItChecksH3}</h3>
          <ul class="quad-list">
            {profile.checks.map(item => <li class="quad-item">{item}</li>)}
          </ul>
        </div>
        <div class="quad-card">
          <div class="fold-corner fold-corner--sm"></div>
          <div class="fold-corner-line fold-corner-line--sm"></div>
          <div class="quad-label" style={`color: ${profile.teamColor}`}>{t.improvesLabel}</div>
          <h3 class="quad-h3">{t.whatItImprovesH3}</h3>
          <ul class="quad-list">
            {profile.improves.map(item => <li class="quad-item">{item}</li>)}
          </ul>
        </div>
        <div class="quad-card quad-card--rot-pos">
          <div class="fold-corner fold-corner--sm"></div>
          <div class="fold-corner-line fold-corner-line--sm"></div>
          <div class="quad-label" style={`color: ${profile.teamColor}`}>{t.preparesLabel}</div>
          <h3 class="quad-h3">{t.whatItPreparesH3}</h3>
          <ul class="quad-list">
            {profile.prepares.map(item => <li class="quad-item">{item}</li>)}
          </ul>
        </div>
        <div class="quad-card quad-card--amber">
          <div class="quad-label quad-label--amber">{t.surfacesLabel}</div>
          <h3 class="quad-h3">{t.forHumanReviewH3}</h3>
          <ul class="quad-list">
            {profile.surfaces.map(item => <li class="quad-item quad-item--amber">{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 4. IO: WORKS FROM / PRODUCES ===================== -->
  <section class="section section--paper-dark section--border-top">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow eyebrow--strategy">{t.onDeskEyebrow}</div>
        <h2 class="section-h2">{profile.ioH2}</h2>
      </div>
      <div class="io-grid">
        <!-- Works from -->
        <div class="io-panel io-panel--from">
          <span class="folder-tab">{t.worksFromTab}</span>
          <div class="io-card">
            <span class="fold-corner fold-corner--md"></span>
            <span class="fold-corner-line fold-corner-line--md"></span>
            <div class="io-list">
              {profile.worksFrom.map((item, i) => (
                <div class="io-row io-row--from">
                  <span class="io-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="io-text">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Connector -->
        <div class="io-connector">
          <img
            src={profile.portrait}
            srcset={`${profile.portrait} 1x, ${profile.portrait2x} 2x`}
            alt={profile.name}
            class="io-portrait"
            width="62"
            height="62"
            loading="lazy"
            decoding="async"
          />
          <span class="io-name mono-label">{profile.name.toUpperCase()}</span>
          <span class="io-arrow">&#8594;</span>
        </div>

        <!-- Produces -->
        <div class="io-panel io-panel--produces">
          <span class="folder-tab">{t.producesTab}</span>
          <div class="io-card">
            <span class="fold-corner fold-corner--md"></span>
            <span class="fold-corner-line fold-corner-line--md"></span>
            <div class="io-list">
              {profile.produces.map((item) => (
                <div class="io-row io-row--produces">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--wp-signal)" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" class="io-check"><path d="m5 12 5 5L20 7"/></svg>
                  <span class="io-text">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 5. WHEN TO USE ===================== -->
  <section class="section section--border-top">
    <div class="container">
      <div class="section-intro">
        <div class="eyebrow eyebrow--strategy">{t.whenToBringInPrefix}{profile.name}{t.whenToBringInSuffix}</div>
        <h2 class="section-h2">{t.specificMomentsH2}</h2>
      </div>
      <div class="scenario-grid">
        {profile.scenarios.map((s, i) => (
          <div class={`scenario-card${i % 2 === 0 ? i % 4 === 0 ? '' : ' scenario-card--rot-neg' : ' scenario-card--rot-pos'}`}>
            <span class="fold-corner fold-corner--sm"></span>
            <span class="fold-corner-line fold-corner-line--sm"></span>
            <span class="ruled-margin-vert"></span>
            <div class="scenario-num">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="scenario-h3">{s.title}</h3>
            <p class="scenario-body">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 6. HUMAN APPROVAL & BOUNDARIES ===================== -->
  <section class="section section--paper-dark section--border-top wp-overflow-hidden">
    <div class="container">
      <div class="boundary-grid">
        <!-- LEFT -->
        <div>
          <div class="eyebrow eyebrow--strategy">{t.humanApprovalEyebrow}</div>
          <h2 class="section-h2">{profile.boundaryH2}</h2>
          <p class="section-body">{profile.boundaryPara}</p>
          <div class="boundary-checklist">
            {profile.boundaryChecklist.map(item => (
              <div class="boundary-check-row">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--wp-signal)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="boundary-check-icon"><path d="m5 12 5 5L20 7"/></svg>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- RIGHT: visual -->
        <div class="boundary-art" aria-hidden="true">
          <!-- Will not slip -->
          <div class="will-not-slip">
            <div class="mono-label will-not-label">{profile.name.toUpperCase()}{t.willNotSuffix}</div>
            {profile.willNot.map(item => (
              <div class="will-not-row">
                <span class={`will-not-dot will-not-dot--${item.color}`}></span>
                <span class="will-not-text">{item.text}</span>
              </div>
            ))}
          </div>

          <!-- Voice review sheet -->
          <div class="review-sheet">
            <div class="review-sheet-header">
              <span class="review-sheet-title">{t.outputReviewTitle}</span>
              <span class="mono-label review-sheet-file">{profile.name.toLowerCase()}-output.md</span>
            </div>
            <div class="review-sheet-body">
              <div class="review-sheet-row">
                <span>{t.qualityCheckedLabel}</span>
                <span class="review-badge review-badge--ready">{t.readyBadge}</span>
              </div>
              <div class="review-sheet-row">
                <span>{t.briefAlignedLabel}</span>
                <span class="review-badge review-badge--ready">{t.readyBadge}</span>
              </div>
              <div class="review-sheet-row">
                <span>{t.finalApprovalLabel}</span>
                <span class="mono-label review-awaiting">{t.awaitingEditorLabel}</span>
              </div>
            </div>
            <div class="review-sheet-footer">
              <span class="mono-label review-sheet-label">{t.approvedByLabel}</span>
              <span class="hp-hand review-signature">R. Hale</span>
            </div>
            <span class="review-stamp">{t.approvedStamp}</span>
          </div>

          <span class="human-pill">
            <span class="human-pill-dot"></span>
            <span class="mono-label">{t.humanApprovalRequiredPill}</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== 7. RELATED WORKERS ===================== -->
  {relatedProfiles.length > 0 && (
    <section id="related" class="section section--border-top">
      <div class="container">
        <div class="section-intro section-intro--wide">
          <div class="eyebrow eyebrow--strategy">{t.earlierLaterEyebrow}</div>
          <h2 class="section-h2">{profile.relatedH2}</h2>
        </div>
        <div class="related-header">
          <span>{t.relatedWorkersLabel}</span>
          <span>{t.byWorkflowSequenceLabel}</span>
        </div>
        <div class="related-grid">
          {relatedProfiles.map((rel) => rel && (
            <a href={localeHref(locale, `/workers/${rel.profile.slug}/`)} class="related-card">
              <span class="fold-corner fold-corner--sm"></span>
              <span class="fold-corner-line fold-corner-line--sm"></span>
              <div class="related-card-top">
                <img
                  src={rel.worker.image}
                  srcset={`${rel.worker.image} 1x, ${rel.worker.image2x} 2x`}
                  alt={rel.worker.name}
                  class="related-portrait"
                  width="64"
                  height="64"
                  loading="lazy"
                  decoding="async"
                />
                <div>
                  <div class="related-name">{rel.worker.name}</div>
                  <div class="related-role">{rel.worker.role}</div>
                </div>
              </div>
              <div class="related-pills">
                <span class="hero-pill hero-pill--team">
                  <span class="hero-pill-dot" style={`background: ${rel.worker.teamColor}`}></span>
                  {rel.profile.heroTagPills.team}
                </span>
                <span class="hero-pill">{shared.stagePrefix}{rel.worker.stage}</span>
              </div>
              <p class="related-desc">{rel.description}</p>
              <div class="related-footer">
                <div class="related-output">
                  <span class="mono-label related-output-label">{shared.outputLabel}</span>
                  <span class="related-output-value">{rel.outputLabel}</span>
                </div>
                <span class="related-cta">
                  {rel.ctaLabel}
                  <svg width="15" height="10" viewBox="0 0 16 10" fill="none"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===================== 8. CTA ===================== -->
  <section class="section section--paper-dark section--border-top cta-section">
    <div class="cta-inner">
      <img src="/brand/main-logo.png" alt="Word Presto" class="cta-logo" loading="lazy" />
      <div class="eyebrow eyebrow--strategy">{profile.role}</div>
      <h2 class="cta-h2">{profile.ctaH2}</h2>
      <p class="cta-body">{profile.ctaPara}</p>
      <div class="cta-actions">
        <a href={localeHref(locale, '/waitlist')} class="btn btn--primary btn--lg">
          {c.joinWaitlist}
          <svg width="20" height="11" viewBox="0 0 20 11" fill="none" aria-hidden="true"><path d="M1 5.5 H17 M13 1.8 L17.8 5.5 L13 9.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href={localeHref(locale, '/workers/')} class="btn btn--secondary btn--lg btn--tilt">{t.seeFullWorkflowCta}</a>
      </div>
      <div class="cta-rule">
        <span class="cta-rule-line"></span>
        <span class="mono-label cta-rule-text">{t.ctaRuleText}</span>
        <span class="cta-rule-line"></span>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/brand/main-logo.png" alt="Word Presto" class="footer-logo" loading="lazy" />
        <p class="footer-tagline">{c.footerTagline}</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{c.product}</span>
        <a href={`${localeHref(locale, '/')}#product`} class="footer-link">{c.howItWorks}</a>
        <a href={`${localeHref(locale, '/')}#capabilities`} class="footer-link">{c.workflow}</a>
        <a href={localeHref(locale, '/workers/')} class="footer-link">{c.workers}</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{c.useCases}</span>
        <a href={`${localeHref(locale, '/')}#use-cases`} class="footer-link">{c.astroCms}</a>
        <a href={`${localeHref(locale, '/')}#use-cases`} class="footer-link">{c.cmsConnected}</a>
        <a href={`${localeHref(locale, '/')}#use-cases`} class="footer-link">{c.standaloneEngine}</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{c.workers}</span>
        <a href={localeHref(locale, `/workers/${profile.slug}/`)} class="footer-link">{profile.name} · {profile.role}</a>
        <a href={localeHref(locale, '/workers/')} class="footer-link">{t.allWorkersFooterLink}</a>
        <a href={`${localeHref(locale, '/')}#workers`} class="footer-link">{t.theWorkflowFooterLink}</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 WordPresto</span>
      <span>{c.reviewLed}</span>
      <a href="/sitemap/" class="footer-link footer-sitemap-link">{c.siteMap}</a>
      <span class="footer-legal-links">
        <a href="/privacy/" class="footer-link">Privacy</a> ·
