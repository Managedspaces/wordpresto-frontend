---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { seoWorkers } from '@/data/workers';
import { seoWorkersContent, workersSharedContent } from '@/data/i18n/workersDirectory';
import { commonStrings } from '@/data/i18n/common';
import { localeHref, type Locale } from '@/i18n/locales';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const meta = seoWorkersContent[locale];
const shared = workersSharedContent[locale];
const c = commonStrings[locale];

const canonical = locale === 'en'
  ? 'https://wordpresto.com/workers/seo/'
  : `https://wordpresto.com${localeHref(locale, '/workers/seo/')}`;
---

<BaseLayout
  pageTitle={meta.h1}
  seoTitle={meta.seoTitle}
  description={meta.metaDescription}
  canonical={canonical}
>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="masthead-inner">
      <nav class="masthead-nav masthead-nav--left">
        <a href={localeHref(locale, '/waitlist')} class="nav-link">{c.signIn}</a>
        <a href={`${localeHref(locale, '/')}#product`} class="nav-link">{c.product}</a>
        <a href={`${localeHref(locale, '/')}#capabilities`} class="nav-link">{c.workflow}</a>
      </nav>
      <a href={localeHref(locale, '/')} class="masthead-logo">
        <img src="/brand/main-logo.png" alt="Word Presto — the content engine behind publishing" height="110" />
      </a>
      <nav class="masthead-nav masthead-nav--right">
        <a href={`${localeHref(locale, '/')}#use-cases`} class="nav-link">{c.useCases}</a>
        <a href={localeHref(locale, '/workers/')} class="nav-link nav-link--active">{c.workers}</a>
        <a href={localeHref(locale, '/waitlist')} class="btn btn--primary btn--sm">{c.joinWaitlist}</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="section section--hero">
    <div class="container">
      <nav class="wp-breadcrumb" aria-label="Breadcrumb">
        <a href={localeHref(locale, '/workers/')} class="wp-breadcrumb-back">&#8592;</a>
        <a href={localeHref(locale, '/workers/')} class="wp-breadcrumb-link">{shared.breadcrumbWorkers}</a>
        <span class="wp-breadcrumb-sep">/</span>
        <span class="wp-breadcrumb-current">{meta.breadcrumbCurrent}</span>
      </nav>

      <div class="eyebrow eyebrow--seo">{meta.eyebrow}</div>
      <h1 class="page-h1">{meta.h1}</h1>
      <p class="page-intro">{meta.intro}</p>
      <div class="worker-directory-header">
        <span>{meta.directoryLabel}</span>
        <span>{seoWorkers.length}{meta.rolesCountSuffix}</span>
      </div>
      <div class="workers-grid">
        {seoWorkers.map((w) => (
          <a href={localeHref(locale, `/workers/${w.id.replace(/_/g, '-')}/`)} class="worker-card">
            <div class="worker-card-top">
              <img
                src={w.image}
                srcset={`${w.image} 1x, ${w.image2x} 2x`}
                alt={`${w.name} · ${w.role}`}
                class="worker-card-img"
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              />
              <div class="worker-card-info">
                <div class="worker-card-name">{w.name}</div>
                <div class="worker-card-role">{w.role}</div>
              </div>
            </div>
            <div class="worker-card-tags">
              <span class="worker-tag">
                <span class="worker-tag-dot" style={`background: ${w.teamColor}`}></span>
                {w.department}
              </span>
              <span class="worker-tag">{shared.stagePrefix}{w.stage}</span>
            </div>
            <p class="worker-card-summary">{w.summary}</p>
            <div class="worker-card-footer">
              <div class="worker-output">
                <span class="worker-output-label">{shared.outputLabel}</span>
                <span class="worker-output-value">{w.output}</span>
              </div>
              <span class="worker-view-link">
                {shared.viewProfile}
                <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <a href={localeHref(locale, '/workers/')} class="workers-crosslink">
        <span class="workers-crosslink-label">{meta.crosslinkLabel}</span>
        <span class="workers-crosslink-title">{meta.crosslinkTitle}</span>
        <span class="workers-crosslink-cta">
          {meta.crosslinkCta}
          <svg width="15" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true"><path d="M1 5h12M9.5 1.5 13.5 5 9.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/brand/main-logo.png" alt="Word Presto" class="footer-logo" loading="lazy" />
        <p class="footer-tagline">{c.footerTagline}</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{c.product}</span>
        <a href={`${localeHref(locale, '/')}#product`} class="footer-link">{c.howItWorks}</a>
        <a href={`${localeHref(locale, '/')}#capabilities`} class="footer-link">{c.workflow}</a>
        <a href={localeHref(locale, '/workers/')} class="footer-link">{c.workers}</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">{meta.footerWorkersHeading}</span>
        <a href={localeHref(locale, '/workers/')} class="footer-link">{meta.footerContentWorkers}</a>
        <a href={localeHref(locale, '/workers/seo/')} class="footer-link">{meta.footerSeoWorkers}</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-heading">Company</span>
        <a href={localeHref(locale, '/waitlist')} class="footer-link">{c.joinWaitlist}</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 WordPresto</span>
      <span>{c.reviewLed}</span>
      <a href="/sitemap/" class="footer-link footer-sitemap-link">{c.siteMap}</a>
    </div>
  </footer>

</BaseLayout>

<style>
  /* ===== MASTHEAD ===== */
  .masthead {
    position: sticky;
    top: 0;
    z-index: 60;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
    border-bottom: 2px solid var(--wp-ink);
    transform: translateZ(0);
  }
  .masthead-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 34px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 28px;
  }
  .masthead-logo img { display: block; height: 48px; width: auto; mix-blend-mode: multiply; }
  .masthead-nav { display: flex; align-items: center; gap: 24px; }
  .masthead-nav--left { justify-content: flex-start; }
  .masthead-nav--right { justify-content: flex-end; }
  .nav-link { font-size: var(--wp-text-md); font-weight: 500; color: var(--wp-text-secondary); }
  .nav-link:hover { color: var(--wp-ink); }
  .nav-link--active { color: var(--wp-ink); font-weight: 600; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--wp-text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    border-radius: 5px;
    text-decoration: none;
  }
  .btn--primary {
    padding: 14px 24px;
    background: var(--wp-ink);
    color: #FAF7F0;
    border: 1px solid var(--wp-ink);
    box-shadow: 0 2px 4px rgba(54,44,24,0.12), 0 10px 18px -8px rgba(54,44,24,0.22);
  }
  .btn--sm { padding: 8px 16px; font-size: var(--wp-text-sm); }

  /* ===== LAYOUT ===== */
  .section {
    padding: 92px 0;
    background-color: var(--wp-bg-primary);
    background-image: var(--wp-texture-paper);
  }
  .section--hero { padding: 56px 0 80px; }
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
  }
  .eyebrow {
    font-size: var(--wp-text-sm);
    font-family: var(--wp-font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .eyebrow--seo { color: var(--team-seo); }

  /* Breadcrumb */
  .wp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.06em;
    color: var(--wp-text-muted);
    margin-bottom: 26px;
  }
  .wp-breadcrumb-back { color: var(--wp-text-muted); }
  .wp-breadcrumb-link { color: var(--wp-text-tertiary); }
  .wp-breadcrumb-sep { color: var(--wp-border-strong); }
  .wp-breadcrumb-current { color: var(--wp-text-secondary); }

  .page-h1 {
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.04;
    color: var(--wp-ink);
    margin: 0 0 20px;
    max-width: 720px;
  }
  .page-intro {
    font-size: var(--wp-text-xl);
    color: var(--wp-text-secondary);
    line-height: 1.5;
    margin: 0 0 36px;
    max-width: 640px;
  }

  /* ===== WORKER DIRECTORY ===== */
  .worker-directory-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--wp-border-strong);
    border-bottom: 1px solid var(--wp-border-strong);
    padding: 10px 2px;
    margin-bottom: 24px;
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.08em;
    color: var(--wp-text-tertiary);
  }
  .workers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }
  .worker-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #FFF;
    border: 1px solid var(--wp-line);
    box-shadow: 0 1px 2px rgba(54,44,24,0.05), 0 12px 24px -16px rgba(54,44,24,0.14);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color 200ms, box-shadow 200ms;
  }
  .worker-card:hover {
    border-color: var(--wp-border-strong);
    box-shadow: 0 3px 7px rgba(17,19,24,0.1), 0 20px 36px -16px rgba(17,19,24,0.24);
  }
  .worker-card-top {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 16px 12px;
  }
  .worker-card-img {
    width: 64px; height: 64px;
    border-radius: 4px;
    object-fit: cover;
    box-shadow: 0 0 0 1px var(--wp-border-secondary);
    flex-shrink: 0;
  }
  .worker-card-name { font-size: var(--wp-text-xl); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
  .worker-card-role { font-size: var(--wp-text-sm); color: var(--wp-text-tertiary); margin-top: 3px; }
  .worker-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 16px 6px;
  }
  .worker-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border: 1px solid var(--wp-line);
    border-radius: var(--wp-radius-pill);
    font-size: 10px;
    font-family: var(--wp-font-mono);
    color: var(--wp-text-tertiary);
    letter-spacing: 0.04em;
  }
  .worker-tag-dot { width: 6px; height: 6px; border-radius: 50%; }
  .worker-card-summary {
    margin: 0;
    padding: 8px 16px 16px;
    font-size: var(--wp-text-base);
    color: var(--wp-text-secondary);
    line-height: 1.5;
  }
  .worker-card-footer {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 11px 16px;
    border-top: 1px dashed var(--wp-line);
  }
  .worker-output { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .worker-output-label {
    font-size: 10px;
    font-family: var(--wp-font-mono);
    letter-spacing: 0.08em;
    color: var(--wp-text-muted);
  }
  .worker-output-value {
    font-size: var(--wp-text-xs);
    font-family: var(--wp-font-mono);
    color: var(--wp-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .worker-view-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--wp-text-xs);
    font-weight: 600;
    color: var(--wp-ink);
    white-space: nowrap;
    flex: 0 0 auto;
  }

  /* ===== CROSS-LINK ===== */
  .workers-crosslink {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 16px;
    margin-top: 28px;
    padding: 18px 22px;
    background: #FFF;
    border: 1px dashed var(--wp-border-strong);
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms, box-shadow 200ms;
  }
  .workers-crosslink:hover {
    border-color: var(--wp-ink);
    box-shadow: 0 3px 7px rgba(54,44,24,0.08), 0 16px 30px -18px rgba(54,44,24,0.2);
  }
  .workers-crosslink-label {
    font-family: var(--wp-font-mono);
    font-size: var(--wp-text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--team-strategy);
  }
  .workers-crosslink-title { font-size: var(--wp-text-lg); font-weight: 700; letter-spacing: -0.01em; }
  .workers-crosslink-cta {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--wp-text-sm);
    font-weight: 600;
    color: var(--wp-ink);
    white-space: nowrap;
  }

  /* ===== FOOTER ===== */
  .footer {
    background-color: var(--wp-paper-dark);
    background-image: var(--wp-texture-paper);
    border-top: 2px solid var(--wp-ink);
    padding: 58px 0 42px;
  }
  .footer-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 34px;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 32px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; max-width: 300px; }
  .footer-logo { display: block; height: 90px; width: auto; align-self: flex-start; mix-blend-mode: multiply; }
  .footer-tagline { margin: 6px 0 0; font-size: var(--wp-text-base); color: var(--wp-text-tertiary); line-height: 1.5; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col-heading { font-size: var(--wp-text-sm); font-weight: 700; }
  .footer-link { font-size: var(--wp-text-base); color: var(--wp-text-tertiary); }
  .footer-link:hover { color: var(--wp-ink); }
  .footer-bottom {
    width: 100%;
    max-width: 1200px;
    margin: 46px auto 0;
    padding: 22px 34px 0;
    border-top: 1px solid var(--wp-border-strong);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: space-between;
    font-size: var(--wp-text-sm);
    color: var(--wp-text-muted);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 940px) {
    .masthead-nav { display: none; }
    .masthead-inner { grid-template-columns: 1fr; justify-items: center; padding: 10px 20px; }
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .container { padding: 0 20px; }
    .workers-grid { grid-template-columns: 1fr; }
    .worker-directory-header { flex-direction: column; align-items: flex-start; gap: 2px; }
    .workers-crosslink-cta { margin-left: 0; }
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>
